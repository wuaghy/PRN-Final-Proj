# =============================================================================
# Template cấu hình môi trường
# Sao chép file này thành .env và điền thông tin thực tế
# KHÔNG bao giờ commit file .env lên Git!
# =============================================================================

# PostgreSQL Connection String
DB_CONNECTION_STRING=Host=localhost;Port=5433;Database=RagChatbotDb;Username=postgres;Password=Password123!

# Google AI Studio API Key (https://aistudio.google.com/app/apikey)
OPENAI_API_KEY=your_google_ai_studio_api_key_here

# Google Drive Configuration
GOOGLE_DRIVE_CLIENT_ID=your_google_drive_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_google_drive_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=your_google_drive_refresh_token
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Embedding model:
OPENAI_EMBEDDING_MODEL=text-embedding-004

# Chat model (RAG response generation):
OPENAI_CHAT_MODEL=gemma-4-26b-a4b-it

# Fast Chat model (Context rewriting):
OPENAI_FAST_CHAT_MODEL=gemini-1.5-flash

# Vector Search Cosine Distance Threshold (default is 0.35)
VECTOR_DISTANCE_THRESHOLD=0.35
