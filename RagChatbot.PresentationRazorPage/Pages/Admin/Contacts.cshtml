@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.ContactsModel
@{
    ViewData["Title"] = "Quản lý Yêu cầu Hỗ trợ";
    // ĐÃ FIX: Chuyển đường dẫn Layout về đúng thư mục Pages
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="p-6 max-w-7xl mx-auto w-full space-y-6 overflow-y-auto h-full">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-slate-200 dark:border-slate-800 pb-5">
        <div>
            <h1 class="text-xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
                <i class="fa-solid fa-headset text-indigo-500"></i> Danh Sách Yêu Cầu Hỗ Trợ
            </h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Nơi tiếp nhận báo lỗi Chatbot RAG và góp ý từ học sinh.</p>
        </div>
        <a asp-page="/Admin/Dashboard" class="flex items-center gap-1.5 px-3 py-2 text-xs font-semibold text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 dark:bg-slate-900 dark:text-slate-300 dark:border-slate-800 dark:hover:bg-slate-800 transition-colors">
            <i class="fa-solid fa-arrow-left"></i> Quay lại Dashboard
        </a>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-950/50 border-b border-slate-200 dark:border-slate-800 text-xs font-semibold uppercase tracking-wider text-slate-400">
                        <th class="p-4 w-20 text-center">STT</th>
                        <th class="p-4">Người gửi</th>
                        <th class="p-4">Loại yêu cầu</th>
                        <th class="p-4">Nội dung tóm tắt</th>
                        <th class="p-4">Thời gian</th>
                        <th class="p-4 text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-150 dark:divide-slate-800/60 text-sm">
                    @if (Model == null || !Model.ContactMessages.Any())
                    {
                        <tr>
                            <td colspan="6" class="p-8 text-center text-slate-400 dark:text-slate-500">
                                <i class="fa-solid fa-folder-open text-3xl mb-2 block"></i>
                                Hiện tại chưa có phiếu hỗ trợ nào từ học sinh.
                            </td>
                        </tr>
                    }
                    else
                    {
                        int index = 1;
                        foreach (var item in Model.ContactMessages)
                        {
                            var studentFullName = item.User != null ? $"{item.User.LastName} {item.User.FirstName}".Trim() : "Học sinh";

                            <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-950/20 transition-colors">
                                <td class="p-4 text-center font-medium text-slate-400">@(index++)</td>
                                <td class="p-4">
                                    <div class="font-semibold text-slate-800 dark:text-slate-200 truncate max-w-[180px]" title="@studentFullName">
                                        @studentFullName
                                    </div>
                                    <div class="text-xs text-slate-400">ID: @item.UserId</div>
                                </td>
                                <td class="p-4">
                                    @if (item.Type == "GeneralFeedback")
                                    {
                                        <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-teal-50 text-teal-700 dark:bg-teal-500/10 dark:text-teal-400 border border-teal-200/30">Góp ý hệ thống</span>
                                    }
                                    else if (item.Type == "ChatIssue")
                                    {
                                        <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-amber-50 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border border-amber-200/30">Lỗi Chatbot RAG</span>
                                    }
                                    else if (item.Type == "DocumentIssue")
                                    {
                                        <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-rose-50 text-rose-700 dark:bg-rose-500/10 dark:text-rose-400 border border-rose-200/30">Lỗi tài liệu</span>
                                    }
                                    else if (item.Type == "AccountIssue")
                                    {
                                        <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-indigo-50 text-indigo-700 dark:bg-indigo-500/10 dark:text-indigo-400 border border-indigo-200/30">Lỗi tài khoản / Premium</span>
                                    }
                                    else
                                    {
                                        <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300">Khác</span>
                                    }
                                </td>
                                <td class="p-4 max-w-xs truncate text-slate-600 dark:text-slate-400">
                                    @item.Content
                                </td>
                                <td class="p-4 text-xs text-slate-500 dark:text-slate-400">
                                    @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="p-4 text-center">
                                    <div class="hidden ticket-stored-data"
                                         data-sender="@studentFullName"
                                         data-type="@item.Type"
                                         data-content="@item.Content">
                                    </div>

                                    <button onclick="viewTicketDetail(this)"
                                            class="px-3 py-1.5 bg-indigo-50 hover:bg-indigo-100 dark:bg-indigo-500/10 dark:hover:bg-indigo-500/20 text-indigo-600 dark:text-indigo-400 text-xs font-semibold rounded-md transition-colors cursor-pointer">
                                        <i class="fa-solid fa-eye"></i> Xem chi tiết
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="detailTicketModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 dark:bg-slate-950/80 backdrop-blur-sm p-4">
    <div class="bg-white dark:bg-slate-900 w-full max-w-lg rounded-2xl border border-slate-200 dark:border-slate-800 shadow-2xl overflow-hidden">
        <div class="p-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 flex items-center justify-between">
            <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2 text-sm sm:text-base">
                <i class="fa-solid fa-circle-info text-indigo-500"></i> Chi Tiết Ý Kiến Đóng Góp
            </h3>
            <button onclick="closeTicketModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
        <div class="p-5 space-y-4 text-left text-sm">
            <div class="grid grid-cols-2 gap-4 border-b border-slate-100 dark:border-slate-800 pb-3">
                <div>
                    <span class="block text-xs font-semibold text-slate-400 uppercase">Người gửi</span>
                    <span id="modalSender" class="font-semibold text-slate-800 dark:text-slate-200">...</span>
                </div>
                <div>
                    <span class="block text-xs font-semibold text-slate-400 uppercase">Phân loại</span>
                    <span id="modalType" class="inline-block mt-0.5">...</span>
                </div>
            </div>
            <div>
                <span class="block text-xs font-semibold text-slate-400 uppercase mb-1.5">Nội dung phản hồi</span>
                <div id="modalContent" class="w-full p-3 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-700 dark:text-slate-300 whitespace-pre-wrap max-h-60 overflow-y-auto leading-relaxed">
                    ...
                </div>
            </div>
        </div>
        <div class="p-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end bg-slate-50/50 dark:bg-slate-900/30">
            <button onclick="closeTicketModal()" class="px-5 py-2 text-sm font-semibold text-white bg-slate-700 hover:bg-slate-600 dark:bg-slate-800 dark:hover:bg-slate-700 rounded-lg transition-colors shadow-md cursor-pointer">
                Đóng lại
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function viewTicketDetail(buttonElement) {
            const dataContainer = buttonElement.parentElement.querySelector('.ticket-stored-data');

            const sender = dataContainer.getAttribute('data-sender');
            const type = dataContainer.getAttribute('data-type');
            const content = dataContainer.getAttribute('data-content');

            document.getElementById("modalSender").innerText = sender;
            document.getElementById("modalContent").innerText = content;

            const typeSpan = document.getElementById("modalType");
            if (type === "GeneralFeedback") {
                typeSpan.className = "px-2.5 py-0.5 text-xs font-medium rounded-full bg-teal-50 text-teal-700 dark:bg-teal-500/10 dark:text-teal-400 border border-teal-200/30";
                typeSpan.innerText = "Góp ý hệ thống";
            } else if (type === "ChatIssue") {
                typeSpan.className = "px-2.5 py-0.5 text-xs font-medium rounded-full bg-amber-50 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border border-amber-200/30";
                typeSpan.innerText = "Lỗi Chatbot RAG";
            } else if (type === "DocumentIssue") {
                typeSpan.className = "px-2.5 py-0.5 text-xs font-medium rounded-full bg-rose-50 text-rose-700 dark:bg-rose-500/10 dark:text-rose-400 border border-rose-200/30";
                typeSpan.innerText = "Lỗi tài liệu";
            } else if (type === "AccountIssue") {
                typeSpan.className = "px-2.5 py-0.5 text-xs font-medium rounded-full bg-indigo-50 text-indigo-700 dark:bg-indigo-500/10 dark:text-indigo-400 border border-indigo-200/30";
                typeSpan.innerText = "Lỗi tài khoản / Premium";
            } else {
                typeSpan.className = "px-2.5 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300";
                typeSpan.innerText = "Khác";
            }

            const modal = document.getElementById("detailTicketModal");
            modal.classList.remove("hidden");
            modal.classList.add("flex");
        }

        function closeTicketModal() {
            const modal = document.getElementById("detailTicketModal");
            modal.classList.add("hidden");
            modal.classList.remove("flex");
        }
    </script>
}