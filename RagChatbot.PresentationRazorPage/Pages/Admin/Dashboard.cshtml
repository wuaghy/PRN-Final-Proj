@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.DashboardModel

@{
    ViewData["Title"] = "Dashboard Giám sát Hệ thống";
    var departments = ViewBag.Departments as List<RagChatbot.Business.DTOs.DepartmentDto> ?? new List<RagChatbot.Business.DTOs.DepartmentDto>();
    int procCount = ViewBag.ProcessingCount ?? 0;

    // --- ĐỌC DỮ LIỆU DOANH THU & PREMIUM TỪ CONTROLLER BẮN QUA ---
    long totalRevenue = ViewBag.TotalRevenue ?? 0; // Đơn vị: VND
    int premiumCount = ViewBag.PremiumCount ?? 0;   // Số lượng user Premium

    // --- ĐỌC ĐOẠN MỚI: SỐ LƯỢNG YÊU CẦU HỖ TRỢ CHỜ XỬ LÝ ---
    int pendingContactsCount = ViewBag.PendingContactsCount ?? 0;
}

<div class="flex-1 p-6 overflow-y-auto bg-slate-50 dark:bg-slate-950">

    <div class="mb-6 flex flex-col xl:flex-row xl:items-center xl:justify-between gap-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
                <i class="fa-solid fa-chart-pie text-emerald-500"></i> Tổng quan Hệ thống Quản trị
            </h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Giám sát hoạt động đóng góp học liệu RAG kết hợp theo dõi doanh thu gói Premium thực tế.</p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 w-full xl:w-auto shrink-0">

            <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 flex items-center gap-3.5 shadow-sm min-w-[160px]">
                <span class="w-10 h-10 rounded-lg bg-amber-100 dark:bg-amber-500/10 flex items-center justify-center text-amber-600 dark:text-amber-400 shrink-0">
                    <i class="fa-solid fa-money-bill-wave text-base"></i>
                </span>
                <div>
                    <p class="text-xs text-slate-400 dark:text-slate-500 font-medium">Tổng doanh thu</p>
                    <p class="text-base font-bold text-slate-800 dark:text-slate-200 mt-0.5">
                        @totalRevenue.ToString("N0") <span class="text-xs font-normal text-slate-400">đ</span>
                    </p>
                </div>
            </div>

            <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 flex items-center gap-3.5 shadow-sm min-w-[160px]">
                <span class="w-10 h-10 rounded-lg bg-indigo-100 dark:bg-indigo-500/10 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shrink-0">
                    <i class="fa-solid fa-crown text-sm"></i>
                </span>
                <div>
                    <p class="text-xs text-slate-400 dark:text-slate-500 font-medium">Gói Premium</p>
                    <p class="text-lg font-bold text-slate-800 dark:text-slate-200">@premiumCount <span class="text-xs font-normal text-slate-400">User</span></p>
                </div>
            </div>

            <a asp-page="/Admin/Contacts" class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 flex items-center gap-3.5 shadow-sm min-w-[160px] hover:shadow-md hover:border-orange-400 dark:hover:border-orange-500/40 transition-all cursor-pointer">
                <span class="w-10 h-10 rounded-lg bg-orange-100 dark:bg-orange-500/10 flex items-center justify-center text-orange-600 dark:text-orange-400 shrink-0">
                    <i class="fa-solid fa-envelope-open-text text-sm"></i>
                </span>
                <div>
                    <p class="text-xs text-slate-400 dark:text-slate-500 font-medium">Yêu cầu hỗ trợ</p>
                    <p class="text-lg font-bold text-slate-800 dark:text-slate-200">
                        @pendingContactsCount <span class="text-xs font-normal text-slate-400">Phiếu</span>
                    </p>
                </div>
            </a>

            <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 flex items-center gap-3.5 shadow-sm min-w-[160px]">
                <span class="w-10 h-10 rounded-lg bg-emerald-100 dark:bg-emerald-500/10 flex items-center justify-center text-emerald-600 dark:text-emerald-400 shrink-0">
                    <i class="fa-solid fa-file-circle-check text-base"></i>
                </span>
                <div>
                    <p class="text-xs text-slate-400 dark:text-slate-500 font-medium">Tài liệu Active</p>
                    <p class="text-lg font-bold text-slate-800 dark:text-slate-200">@ViewBag.ActiveCount</p>
                </div>
            </div>

            <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 flex items-center gap-3.5 shadow-sm min-w-[160px]">
                <span class="w-10 h-10 rounded-lg bg-rose-100 dark:bg-rose-500/10 flex items-center justify-center text-rose-600 dark:text-rose-400 shrink-0">
                    <i class="fa-solid fa-spinner @(procCount > 0 ? "fa-spin" : "") text-base"></i>
                </span>
                <div>
                    <p class="text-xs text-slate-400 dark:text-slate-500 font-medium">Đang xử lý / Khóa</p>
                    <p class="text-lg font-bold text-slate-800 dark:text-slate-200">@procCount</p>
                </div>
            </div>

        </div>
    </div>

    <div class="mb-4 flex flex-col sm:flex-row gap-3 bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <div class="flex-1 relative">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
            <input type="text" id="searchKeyword" placeholder="Tìm tên học liệu, môn học, email người đăng..."
                   class="w-full pl-9 pr-4 py-2 text-sm bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:border-indigo-500 text-slate-800 dark:text-slate-100 transition-colors" />
        </div>
        <div class="w-full sm:w-64 relative">
            <i class="fa-solid fa-filter absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
            <select id="filterDept"
                    class="w-full pl-9 pr-8 py-2 text-sm bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:border-indigo-500 text-slate-800 dark:text-slate-100 transition-colors appearance-none cursor-pointer">
                <option value="all">Tất cả bộ môn</option>
                @foreach (var d in departments)
                {
                    <option value="@d.Id">@d.Name</option>
                }
            </select>
            <i class="fa-solid fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs pointer-events-none"></i>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
        <div class="p-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 flex items-center justify-between">
            <h3 class="font-semibold text-slate-800 dark:text-slate-200">Kho Học liệu Toàn trường</h3>
            <span class="text-xs text-slate-400">Danh sách tài liệu thời gian thực</span>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-200 dark:border-slate-800 text-slate-400 text-xs font-semibold uppercase bg-slate-50/50 dark:bg-slate-900/50">
                        <th class="p-4">Tên học liệu / File</th>
                        <th class="p-4">Môn học</th>
                        <th class="p-4">Bộ môn quản lý</th>
                        <th class="p-4">Người đăng tải</th>
                        <th class="p-4">Trạng thái RAG</th>
                        
                    </tr>
                </thead>
                <tbody id="documentTableBody" class="divide-y divide-slate-200 dark:divide-slate-800 text-sm text-slate-600 dark:text-slate-300">
                    @if (Model != null && Model.Documents.Any())
                    {
                        foreach (var item in Model.Documents)
                        {
                            var docName = string.IsNullOrEmpty(item.DisplayName) ? item.FileName : item.DisplayName;
                            var subjectInfo = item.Subject != null ? $"{item.Subject.Code} {item.Subject.Name}" : "";
                            var uploaderDisplay = item.UploaderFullName;
                            var dept = departments.FirstOrDefault(d => d.Id == (item.Subject?.DepartmentId ?? 0));
                            var searchText = $"{docName} {subjectInfo} {uploaderDisplay}".ToLower();

                            <tr class="document-row hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors"
                                data-dept-id="@(dept?.Id ?? 0)"
                                data-search="@searchText">

                                <td class="p-4 font-medium text-slate-900 dark:text-white">
                                    <i class="fa-regular fa-file-lines text-indigo-500 mr-2"></i>
                                    <a asp-page="/Document/Index" asp-page-handler="ViewDocument" asp-route-id="@item.Id" target="_blank"
                                       class="text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300 hover:underline transition-colors">
                                        @docName
                                    </a>
                                </td>
                                <td class="p-4">
                                    <span class="text-slate-600 dark:text-slate-400">
                                        @(item.Subject != null ? $"{item.Subject.Code} - {item.Subject.Name}" : "N/A")
                                    </span>
                                </td>
                                <td class="p-4">
                                    <span class="font-medium text-slate-700 dark:text-slate-300">
                                        @(dept != null ? dept.Name : "Chưa phân bộ môn")
                                    </span>
                                </td>
                                <td class="p-4 font-medium text-slate-500 dark:text-slate-400">
                                    @uploaderDisplay
                                </td>
                                <td class="p-4">
                                    @if (item.IsActive && item.Status == "Indexed")
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20">
                                            <i class="fa-solid fa-spinner fa-spin text-xs"></i> @item.Status
                                        </span>
                                    }
                                </td>
                                
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="p-8 text-center text-slate-400 italic">
                                Chưa có giảng viên hay trưởng bộ môn nào tải học liệu lên hệ thống.
                            </td>
                        </tr>
                    }
                    <tr id="noResultsRow" style="display: none;">
                        <td colspan="6" class="p-8 text-center text-slate-400 italic">
                            Không tìm thấy học liệu nào phù hợp với bộ lọc hiện tại.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const inputKeyword = document.getElementById("searchKeyword");
        const selectDept = document.getElementById("filterDept");
        const rows = document.querySelectorAll(".document-row");
        const noResultsRow = document.getElementById("noResultsRow");

        function performFilter() {
            const keyword = inputKeyword.value.toLowerCase().trim();
            const selectedDeptId = selectDept.value;
            let visibleRowsCount = 0;

            rows.forEach(row => {
                const rowSearchText = row.getAttribute("data-search") || "";
                const rowDeptId = row.getAttribute("data-dept-id") || "0";

                const matchesKeyword = rowSearchText.includes(keyword);
                const matchesDept = (selectedDeptId === "all") || (rowDeptId === selectedDeptId);

                if (matchesKeyword && matchesDept) {
                    row.style.display = "";
                    visibleRowsCount++;
                } else {
                    row.style.display = "none";
                }
            });

            if (visibleRowsCount === 0 && rows.length > 0) {
                noResultsRow.style.display = "";
            } else {
                noResultsRow.style.display = "none";
            }
        }

        inputKeyword.addEventListener("input", performFilter);
        selectDept.addEventListener("change", performFilter);
    });
</script>