@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.DepartmentsModel
@{
    ViewData["Title"] = "Quản lý Bộ môn";
}

<div class="max-w-6xl mx-auto p-4 sm:p-6 lg:p-8 transition-colors duration-200">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-blue-500/10 text-blue-600 dark:text-blue-400 flex items-center justify-center">
                <i class="fa-solid fa-building"></i>
            </span>
            Quản lý Bộ môn
        </h1>
        
        <a asp-page="/Admin/Index" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition">
            <i class="fa-solid fa-arrow-left mr-2"></i>Quay lại QL Tài khoản
        </a>
    </div>

    
    
    

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Form Tạo Bộ môn -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm sticky top-20">
                <h2 class="text-base font-bold text-gray-900 dark:text-white mb-5 flex items-center gap-2">
                    <i class="fa-solid fa-folder-plus text-blue-500 dark:text-blue-400"></i>
                    Tạo Bộ môn mới
                </h2>
                
                <form asp-page="/Admin/Departments" asp-page-handler="CreateDepartment" method="post" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Tên Bộ môn</label>
                        <input type="text" name="name" required placeholder="Công nghệ Thông tin"
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 outline-none transition-all" />
                    </div>
                    
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Mô tả</label>
                        <textarea name="description" rows="3" placeholder="Khoa CNTT - Đào tạo lập trình viên"
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 outline-none transition-all"></textarea>
                    </div>
                    
                    <button type="submit"
                        class="w-full mt-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-blue-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Tạo bộ môn</span>
                        <i class="fa-solid fa-plus text-xs"></i>
                    </button>
                </form>
            </div>
        </div>

        <!-- Danh sách Bộ môn -->
        <div class="lg:col-span-2">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-800/60 bg-slate-50/50 dark:bg-slate-900/50 flex items-center justify-between">
                    <h3 class="text-base font-bold text-gray-900 dark:text-white flex items-center gap-2">
                        <i class="fa-solid fa-layer-group text-blue-500 dark:text-blue-400"></i>
                        Danh sách Bộ môn
                    </h3>
                    <span class="bg-blue-100 dark:bg-blue-500/20 text-blue-700 dark:text-blue-400 text-xs font-bold px-2.5 py-1 rounded-full">
                        @Model.DepartmentsList.Count() bộ môn
                    </span>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-slate-600 dark:text-slate-300">
                        <thead class="bg-slate-50 dark:bg-slate-950/50 text-xs uppercase font-semibold text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-slate-800">
                            <tr>
                                <th scope="col" class="px-6 py-4">ID</th>
                                <th scope="col" class="px-6 py-4">Tên Bộ môn</th>
                                <th scope="col" class="px-6 py-4">Mô tả</th>
                                <th scope="col" class="px-6 py-4">Ngày tạo</th>
                                <!-- <th scope="col" class="px-6 py-4 text-center">Trạng thái</th> -->
                                <th scope="col" class="px-6 py-4 text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                            @if (!Model.DepartmentsList.Any())
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-12 text-center text-slate-500">Chưa có bộ môn nào.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var dept in Model.DepartmentsList)
                                {
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
                                        <td class="px-6 py-4 font-mono text-xs text-slate-400">#@dept.Id</td>
                                        <td class="px-6 py-4 font-bold text-gray-900 dark:text-slate-100"><a href="javascript:void(0)" onclick="openDeptTermHistoryModal(@dept.Id, '@dept.Name.Replace("'", "\\'")')" class="hover:text-blue-500 transition-colors cursor-pointer decoration-blue-500/30 underline-offset-4 hover:underline">@dept.Name</a></td>
                                        <td class="px-6 py-4">@dept.Description</td>
                                        <td class="px-6 py-4 text-xs">@dept.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <!-- <td class="px-6 py-4 text-center">
                                            <form asp-page="/Admin/Departments" asp-page-handler="ToggleActive" method="post" class="m-0">
                                                <input type="hidden" name="id" value="@dept.Id" />
                                                <button type="submit" class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors @(dept.IsActive ? "bg-blue-600" : "bg-slate-200 dark:bg-slate-700")" title="@(dept.IsActive ? "Vô hiệu hóa" : "Kích hoạt")">
                                                    <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform @(dept.IsActive ? "translate-x-6" : "translate-x-1") shadow-sm"></span>
                                                </button>
                                            </form>
                                        </td> -->
                                        <td class="px-6 py-4">
                                            <div class="flex items-center justify-end gap-1">
                                                <button onclick="openEditModal(@dept.Id, '@dept.Name.Replace("'", "\\'")', '@dept.Description?.Replace("'", "\\'")')"
                                                    class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-500/10 transition-colors"
                                                    title="Sửa bộ môn">
                                                    <i class="fa-solid fa-pen text-sm"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="fixed inset-0 z-50 hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl w-full max-w-md flex flex-col shadow-2xl transition-all scale-95 duration-200" id="editModalContainer">
        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <div>
                <h3 class="text-base font-bold text-gray-800 dark:text-slate-100">Chỉnh sửa Bộ môn</h3>
            </div>
            <button onclick="closeEditModal()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form asp-page="/Admin/Departments" asp-page-handler="UpdateDepartment" method="post">
            <input type="hidden" name="id" id="editDeptId" />
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Tên Bộ môn</label>
                    <input type="text" name="name" id="editDeptName" required
                            class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 outline-none transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Mô tả</label>
                    <textarea name="description" id="editDeptDesc" rows="3"
                            class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 outline-none transition-all"></textarea>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end gap-3 bg-slate-50 dark:bg-slate-800/50 rounded-b-3xl">
                <button type="button" onclick="closeEditModal()" class="px-5 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors">Hủy</button>
                <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 shadow-md shadow-blue-500/20 rounded-xl transition-all">Lưu Thay Đổi</button>
            </div>
        </form>
    </div>
</div>

<!-- Dept Term History Modal -->
<div id="deptTermHistoryModal" class="fixed inset-0 z-50 hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl w-full max-w-lg flex flex-col shadow-2xl transition-all scale-95 duration-200" id="deptTermHistoryModalContainer">
        <!-- Header -->
        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-900/50 rounded-t-3xl">
            <div>
                <h3 class="text-lg font-bold text-slate-800 dark:text-slate-100" id="deptTermHistoryTitle">Lịch sử Quản lý</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Danh sách các Trưởng bộ môn qua từng nhiệm kỳ.</p>
            </div>
            <button onclick="closeDeptTermHistoryModal()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <!-- Body -->
        <div class="p-6 overflow-y-auto max-h-[60vh]">
            <ul id="deptTermHistoryList" class="space-y-3">
                <li class="text-center text-slate-500 text-sm py-4">Đang tải...</li>
            </ul>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 rounded-b-3xl flex justify-end">
            <button type="button" onclick="closeDeptTermHistoryModal()" class="px-5 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors">Đóng</button>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    function openEditModal(id, name, desc) {
        document.getElementById('editDeptId').value = id;
        document.getElementById('editDeptName').value = name;
        document.getElementById('editDeptDesc').value = desc || '';
        
        const modal = document.getElementById('editModal');
        const containerEl = document.getElementById('editModalContainer');
        modal.classList.remove('hidden');
        setTimeout(() => {
            containerEl.classList.remove('scale-95');
            containerEl.classList.add('scale-100');
        }, 10);
    }

    function closeEditModal() {
        const modal = document.getElementById('editModal');
        const container = document.getElementById('editModalContainer');
        container.classList.remove('scale-100');
        container.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 200);
    }

    async function openDeptTermHistoryModal(deptId, deptName) {
        document.getElementById('deptTermHistoryTitle').innerText = 'Lịch sử HOD của: ' + deptName;
        const list = document.getElementById('deptTermHistoryList');
        list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4"><i class="fa-solid fa-circle-notch fa-spin text-blue-500 text-2xl"></i></li>';
        
        const modal = document.getElementById('deptTermHistoryModal');
        const containerEl = document.getElementById('deptTermHistoryModalContainer');
        modal.classList.remove('hidden');
        setTimeout(() => {
            containerEl.classList.remove('scale-95');
            containerEl.classList.add('scale-100');
        }, 10);

        try {
            const res = await fetch(`?handler=DepartmentTermHistory&deptId=${deptId}`);
            if (res.ok) {
                const data = await res.json();
                
                list.innerHTML = '';
                if (data.length === 0) {
                    list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4">Chưa có lịch sử HOD.</li>';
                    return;
                }

                data.forEach(item => {
                    const endAtStr = item.endAt ? item.endAt : '...';
                    const statusClass = item.endAt ? 'bg-slate-100 text-slate-600' : 'bg-emerald-100 text-emerald-700 font-bold';
                    
                    list.innerHTML += `
                        <li class="flex items-center justify-between p-3 rounded-xl border border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/30">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-500/20 text-blue-600 dark:text-blue-400 flex items-center justify-center">
                                    <i class="fa-solid fa-user-tie"></i>
                                </span>
                                <span class="text-sm font-semibold text-slate-800 dark:text-slate-200">${item.hodName}</span>
                            </div>
                            <span class="text-xs px-2.5 py-1 rounded-lg ${statusClass}">
                                ${item.startAt} - ${endAtStr}
                            </span>
                        </li>
                    `;
                });
            } else {
                list.innerHTML = '<li class="text-center text-red-500 text-sm py-4">Lỗi khi tải dữ liệu.</li>';
            }
        } catch (error) {
            list.innerHTML = '<li class="text-center text-red-500 text-sm py-4">Đã xảy ra lỗi mạng.</li>';
        }
    }

    function closeDeptTermHistoryModal() {
        const modal = document.getElementById('deptTermHistoryModal');
        const container = document.getElementById('deptTermHistoryModalContainer');
        container.classList.remove('scale-100');
        container.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 200);
    }
</script>

