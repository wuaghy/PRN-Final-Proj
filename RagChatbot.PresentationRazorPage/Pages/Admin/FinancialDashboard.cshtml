@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.FinancialDashboardModel
@{
    ViewData["Title"] = "Báo cáo tài chính & Hạ tầng AI";
}

<div class="p-6 bg-[#0f172a] min-h-screen text-white">
    <div class="max-w-7xl mx-auto">

        <!-- Header -->
        <div class="mb-8 border-b border-slate-800 pb-4">
            <h1 class="text-3xl font-bold text-teal-400">📊 Hệ thống giám sát Tài chính & Chỉ số AI</h1>
            <p class="text-slate-400 text-sm mt-1">Dữ liệu thời gian thực được tổng hợp dựa trên lượng Token tiêu thụ thực tế và cổng thanh toán VNPAY.</p>
        </div>

        <!-- Metric Grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">

            <!-- Box Doanh thu -->
            <div class="bg-slate-900 border border-slate-800 p-5 rounded-xl shadow-lg">
                <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Tổng doanh thu (VNPAY)</div>
                <div class="text-2xl font-bold text-emerald-400 mt-2">@Model.TotalRevenueVnd.ToString("N0") <span class="text-sm font-normal text-slate-400">VND</span></div>
                <div class="text-xs text-slate-500 mt-1">Nâng cấp Premium tài khoản</div>
            </div>

            <!-- Box Chi phí Hạ tầng -->
            <div class="bg-slate-900 border border-slate-800 p-5 rounded-xl shadow-lg">
                <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Chi phí API (Gemini Flash)</div>
                <div class="text-2xl font-bold text-rose-400 mt-2">@Model.TotalCostVnd.ToString("N0") <span class="text-sm font-normal text-slate-400">VND</span></div>
                <div class="text-xs text-slate-400 mt-1">≈ $@Model.TotalCostUsd.ToString("N4") USD</div>
            </div>

            <!-- Box Lợi nhuận ròng -->
            <div class="bg-slate-900 border border-slate-800 p-5 rounded-xl shadow-lg">
                <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Lợi nhuận ròng (Net Profit)</div>
                <div class="text-2xl font-bold @(Model.NetProfitVnd >= 0 ? "text-cyan-400" : "text-amber-500") mt-2">
                    @Model.NetProfitVnd.ToString("N0") <span class="text-sm font-normal text-slate-400">VND</span>
                </div>
                <div class="text-xs text-slate-500 mt-1">Doanh thu trừ chi phí vận hành</div>
            </div>

            <!-- Box Tiêu thụ Token -->
            <div class="bg-slate-900 border border-slate-800 p-5 rounded-xl shadow-lg">
                <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Tổng Token tiêu thụ</div>
                <div class="text-lg font-bold text-amber-400 mt-2">🡦 In: @Model.TotalInputTokens.ToString("N0")</div>
                <div class="text-lg font-bold text-orange-400">🡧 Out: @Model.TotalOutputTokens.ToString("N0")</div>
            </div>
        </div>

        <!-- Section 2: Thống kê vận hành & tri thức học tập -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">

            <!-- Cột trái: Top Môn Học & Học Liệu -->
            <div class="space-y-8">
                
                <!-- Môn học hoạt động năng nổ nhất -->
                <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-lg">
                    <h2 class="text-xl font-bold mb-5 text-slate-200 flex items-center gap-2">
                        <span class="text-teal-400 text-lg">🎓</span> Top Môn học thảo luận nhiều nhất
                    </h2>
                    
                    <div class="space-y-4">
                        @if (!Model.TopSubjects.Any())
                        {
                            <p class="text-slate-500 italic text-sm">Chưa có phiên hội thoại thảo luận nào.</p>
                        }
                        else
                        {
                            var maxCount = Model.TopSubjects.First().QuestionCount;
                            if (maxCount == 0) maxCount = 1;

                            foreach (var item in Model.TopSubjects)
                            {
                                var pct = (double)item.QuestionCount * 100.0 / maxCount;
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="font-medium text-slate-300">@item.SubjectCode - @item.SubjectName</span>
                                        <span class="text-teal-400 font-semibold">@item.QuestionCount lượt hỏi</span>
                                    </div>
                                    <div class="w-full bg-slate-850 rounded-full h-2">
                                        <div class="bg-gradient-to-r from-teal-500 to-emerald-400 h-2 rounded-full" style="width: @pct%"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Top Học liệu được trích dẫn nhiều nhất -->
                <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-lg">
                    <h2 class="text-xl font-bold mb-5 text-slate-200 flex items-center gap-2">
                        <span class="text-teal-400 text-lg">📚</span> Top Học liệu được trích dẫn nhiều nhất (RAG)
                    </h2>

                    <div class="space-y-4">
                        @if (!Model.TopDocuments.Any())
                        {
                            <p class="text-slate-500 italic text-sm">Học liệu chưa được trích dẫn trong hội thoại nào.</p>
                        }
                        else
                        {
                            var maxCitations = Model.TopDocuments.First().CitationCount;
                            if (maxCitations == 0) maxCitations = 1;

                            foreach (var item in Model.TopDocuments)
                            {
                                var pct = (double)item.CitationCount * 100.0 / maxCitations;
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="font-medium text-slate-300 truncate max-w-[70%]" title="@item.DocumentName">
                                            @item.DocumentName
                                        </span>
                                        <span class="text-orange-400 font-semibold">@item.CitationCount lần trích dẫn</span>
                                    </div>
                                    <div class="w-full bg-slate-850 rounded-full h-2">
                                        <div class="bg-gradient-to-r from-orange-500 to-amber-400 h-2 rounded-full" style="width: @pct%"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

            </div>

            <!-- Cột phải: Phản hồi & Tỷ lệ Premium -->
            <div class="space-y-8">
                
                <!-- Tỷ lệ Premium Conversion -->
                <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-lg">
                    <h2 class="text-xl font-bold mb-4 text-slate-200 flex items-center gap-2">
                        <span class="text-teal-400 text-lg">👑</span> Tỷ lệ chuyển đổi Premium học sinh
                    </h2>
                    
                    <div class="flex items-center gap-6 py-2">
                        <div class="relative flex items-center justify-center shrink-0">
                            <!-- Circular progress representation using premium design -->
                            <div class="w-24 h-24 rounded-full bg-slate-950 flex items-center justify-center border-4 border-indigo-500/40">
                                <div class="text-center">
                                    <span class="text-2xl font-black text-indigo-400">@Model.PremiumConversionRate.ToString("N1")%</span>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-1">
                            <p class="text-sm text-slate-300">
                                Học sinh Premium: <span class="font-bold text-indigo-400">@Model.PremiumStudentsCount</span> / @Model.TotalStudentsCount
                            </p>
                            <p class="text-xs text-slate-400 leading-relaxed">
                                Tỷ lệ học sinh đã trả phí nâng cấp tài khoản để xem trực tuyến tài liệu gốc và mở khóa không giới hạn lượt hỏi chatbot AI.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Thống kê phản hồi/báo cáo lỗi -->
                <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-lg">
                    <h2 class="text-xl font-bold mb-5 text-slate-200 flex items-center gap-2">
                        <span class="text-teal-400 text-lg">💬</span> Phân loại ý kiến đóng góp của Học sinh
                    </h2>

                    <div class="space-y-4">
                        @if (!Model.FeedbackStats.Any())
                        {
                            <p class="text-slate-500 italic text-sm">Chưa nhận được góp ý hoặc phản hồi nào từ học sinh.</p>
                        }
                        else
                        {
                            foreach (var item in Model.FeedbackStats)
                            {
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="font-medium text-slate-300">@item.TypeName</span>
                                        <span class="text-slate-400">@item.Count ý kiến (@item.Percentage.ToString("N1")%)</span>
                                    </div>
                                    <div class="w-full bg-slate-850 rounded-full h-2">
                                        <div class="bg-indigo-500 h-2 rounded-full" style="width: @item.Percentage%"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

            </div>
        </div>

        <!-- Biến động Token theo ngày trong 7 ngày gần nhất -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-lg mb-8">
            <h2 class="text-xl font-bold mb-4 text-slate-200 flex items-center gap-2">
                📈 Xu hướng sử dụng Token & Tin nhắn AI (7 ngày gần nhất)
            </h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm text-slate-300">
                    <thead class="text-xs text-slate-400 uppercase bg-slate-950 border-b border-slate-800">
                        <tr>
                            <th class="px-6 py-3.5">Ngày</th>
                            <th class="px-6 py-3.5">Số câu hỏi thảo luận</th>
                            <th class="px-6 py-3.5">Lượng Input Tokens</th>
                            <th class="px-6 py-3.5">Lượng Output Tokens</th>
                            <th class="px-6 py-3.5">Tổng lượng Tokens</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @foreach (var day in Model.DailyTrends)
                        {
                            var totalTokens = day.InputTokens + day.OutputTokens;
                            <tr class="hover:bg-slate-800/50 transition">
                                <td class="px-6 py-4 font-semibold text-slate-200">@day.Date.ToString("dd/MM/yyyy")</td>
                                <td class="px-6 py-4 text-cyan-400 font-semibold">@day.MessageCount.ToString("N0") câu hỏi</td>
                                <td class="px-6 py-4 text-slate-400">@day.InputTokens.ToString("N0")</td>
                                <td class="px-6 py-4 text-slate-400">@day.OutputTokens.ToString("N0")</td>
                                <td class="px-6 py-4 text-amber-400 font-semibold">@totalTokens.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Top 10 Sinh viên tiêu thụ nhiều Token nhất -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-lg mb-8">
            <h2 class="text-xl font-bold mb-4 text-slate-200 flex items-center gap-2">
                🏆 Top 10 Sinh viên tiêu thụ nhiều Token nhất
            </h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm text-slate-300">
                    <thead class="text-xs text-slate-400 uppercase bg-slate-950 border-b border-slate-800">
                        <tr>
                            <th class="px-6 py-3.5">Học sinh</th>
                            <th class="px-6 py-3.5">Token In</th>
                            <th class="px-6 py-3.5">Token Out</th>
                            <th class="px-6 py-3.5">Tổng Token</th>
                            <th class="px-6 py-3.5">Ước tính Chi phí</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @if (!Model.TopTokenConsumers.Any())
                        {
                            <tr>
                                <td colspan="5" class="px-6 py-8 text-center text-slate-500 italic">Chưa có dữ liệu tiêu thụ token.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var user in Model.TopTokenConsumers)
                            {
                                var totalTokens = user.TokenIn + user.TokenOut;
                                <tr class="hover:bg-slate-800/50 transition">
                                    <td class="px-6 py-4">
                                        <div class="font-medium text-slate-200">@user.LastName @user.FirstName</div>
                                        <div class="text-xs text-slate-500">@user.Email</div>
                                    </td>
                                    <td class="px-6 py-4 text-emerald-400">@user.TokenIn.ToString("N0")</td>
                                    <td class="px-6 py-4 text-rose-400">@user.TokenOut.ToString("N0")</td>
                                    <td class="px-6 py-4 text-amber-400 font-semibold">@totalTokens.ToString("N0")</td>
                                    <td class="px-6 py-4 text-cyan-400 font-semibold">~@user.CostVnd.ToString("N0") VNĐ</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Chi tiết giao dịch -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-lg">
            <h2 class="text-xl font-bold mb-4 text-slate-200 flex items-center gap-2">
                ⏱️ Lịch sử nâng cấp tài khoản gần đây
            </h2>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm text-slate-300">
                    <thead class="text-xs text-slate-400 uppercase bg-slate-950 border-b border-slate-800">
                        <tr>
                            <th class="px-6 py-3.5">Tài khoản người dùng</th>
                            <th class="px-6 py-3.5">Số tiền thanh toán</th>
                            <th class="px-6 py-3.5">Tỷ giá quy đổi hệ thống</th>
                            <th class="px-6 py-3.5">Thời gian giao dịch</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @if (!Model.RecentTransactions.Any())
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-8 text-center text-slate-500 italic">Hiện tại hệ thống chưa ghi nhận giao dịch nào.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var tx in Model.RecentTransactions)
                            {
                                <tr class="hover:bg-slate-800/50 transition">
                                    <td class="px-6 py-4 font-medium text-slate-200">@tx.UserEmail</td>
                                    <td class="px-6 py-4 text-emerald-400 font-semibold">+@tx.Amount.ToString("N0") VND</td>
                                    <td class="px-6 py-4 text-slate-400">1 USD = @tx.Rate.ToString("N0") VND</td>
                                    <td class="px-6 py-4 text-slate-400">@tx.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>