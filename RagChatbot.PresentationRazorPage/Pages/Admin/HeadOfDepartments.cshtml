@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.HeadOfDepartmentsModel
@{
    ViewData["Title"] = "Quản lý Trưởng Bộ môn (HOD)";
}

<div class="max-w-6xl mx-auto p-4 sm:p-6 lg:p-8 transition-colors duration-200">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-orange-500/10 text-orange-600 dark:text-orange-400 flex items-center justify-center">
                <i class="fa-solid fa-user-tie"></i>
            </span>
            Quản lý Trưởng Bộ môn
        </h1>
        
        <a asp-page="/Admin/Index" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition">
            <i class="fa-solid fa-arrow-left mr-2"></i>Quay lại QL Tài khoản
        </a>
    </div>

    
    

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Form Tạo HOD -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm sticky top-20">
                <h2 class="text-base font-bold text-gray-900 dark:text-white mb-5 flex items-center gap-2">
                    <i class="fa-solid fa-user-plus text-orange-500 dark:text-orange-400"></i>
                    Tạo tài khoản HOD
                </h2>
                
                <form asp-page="/Admin/HeadOfDepartments" asp-page-handler="CreateHod" method="post" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Họ</label>
                            <input type="text" name="lastName" required placeholder="Nguyễn"
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 outline-none transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Tên</label>
                            <input type="text" name="firstName" required placeholder="Văn A"
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 outline-none transition-all" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Email</label>
                        <div class="relative">
                            <i class="fa-solid fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input type="email" name="email" required placeholder="hod01@gmail.com"
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl pl-10 pr-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 outline-none transition-all" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Chọn Bộ môn</label>
                        <select name="departmentId" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 transition-all">
                            <option value="">-- Vui lòng chọn --</option>
                            @if(ViewBag.Departments != null)
                            {
                                foreach(var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <p class="text-xs text-slate-500">Mật khẩu mặc định sẽ là <b>123456</b></p>
                    
                    <button type="submit"
                        class="w-full mt-2 bg-orange-600 hover:bg-orange-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-orange-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Tạo HOD</span>
                        <i class="fa-solid fa-arrow-right text-xs"></i>
                    </button>
                </form>
            </div>
        </div>

        <!-- Danh sách HOD -->
        <div class="lg:col-span-2">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
                <div class="px-6 py-3 border-b border-slate-100 dark:border-slate-800/60 bg-slate-50 dark:bg-slate-800/50 flex items-center justify-between">
                    <h3 class="text-base font-bold text-gray-900 dark:text-white flex items-center gap-2">
                        <i class="fa-solid fa-users-tie text-orange-500 dark:text-orange-400"></i>
                        Danh sách Trưởng Bộ môn
                    </h3>
                    <span class="bg-orange-100 dark:bg-orange-500/20 text-orange-700 dark:text-orange-400 text-xs font-bold px-2.5 py-1 rounded-full">
                        @Model.Hods.Count() Trưởng bộ môn
                    </span>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-slate-600 dark:text-slate-300">
                        <thead class="bg-slate-50 dark:bg-slate-950/50 text-xs uppercase font-semibold text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-slate-800">
                            <tr>
                                <th scope="col" class="px-6 py-4">Tài khoản</th>
                                <th scope="col" class="px-6 py-4">Bộ môn quản lý</th>
                                <th scope="col" class="px-6 py-4 text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                            @if (!Model.Hods.Any())
                            {
                                <tr>
                                    <td colspan="3" class="px-6 py-12 text-center text-slate-500">Chưa có Trưởng bộ môn nào.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var user in Model.Hods)
                                {
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-400 to-amber-500 flex items-center justify-center text-white font-bold text-sm shadow-sm">
                                                    @(user.LastName?.FirstOrDefault())@(user.FirstName?.FirstOrDefault())
                                                </div>
                                                <div>
                                                    <div class="font-bold text-gray-900 dark:text-slate-100">
                                                        <a href="javascript:void(0)" onclick="openTermHistoryModal(@user.Id, '@user.LastName @user.FirstName')" class="hover:text-orange-500 transition-colors cursor-pointer">
                                                            @user.LastName @user.FirstName
                                                        </a>
                                                        <span class="text-[10px] text-slate-400 font-mono ml-1">#@user.Id</span>
                                                    </div>
                                                    <div class="text-xs text-slate-500 mt-0.5">
                                                        <i class="fa-solid fa-at text-[10px] opacity-70"></i>@user.Email
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 font-bold text-gray-900 dark:text-slate-100">
                                            @if (user.Department != null)
                                            {
                                                <a href="javascript:void(0)" onclick="openDeptTermHistoryModal(@user.Department.Id, '@user.Department.Name.Replace("'", "\\'")')" class="hover:text-blue-500 transition-colors cursor-pointer decoration-blue-500/30 underline-offset-4 hover:underline">
                                                    @user.Department.Name
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-slate-500 font-normal">Chưa gắn bộ môn</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                                <div class="flex items-center justify-end gap-1">
                                                    <button onclick="openEditHodModal(@user.Id, @(user.DepartmentId.HasValue ? user.DepartmentId.Value.ToString() : "null"), '@user.Email')"
                                                        class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-500/10 transition-colors"
                                                        title="Sửa bộ môn">
                                                        <i class="fa-solid fa-pen text-sm"></i>
                                                    </button>
                                                    
                                                    @if (user.DepartmentId.HasValue)
                                                    {
                                                        <form asp-page="/Admin/HeadOfDepartments" asp-page-handler="EndHodTerm" method="post" class="m-0">
                                                            <input type="hidden" name="id" value="@user.Id" />
                                                            <button type="submit" 
                                                                onclick="return confirm('Bạn có chắc chắn muốn kết thúc nhiệm kỳ của người này?');"
                                                                class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-orange-600 hover:bg-orange-50 dark:hover:bg-orange-500/10 transition-colors"
                                                                title="Kết thúc nhiệm kỳ">
                                                                <i class="fa-solid fa-stopwatch text-sm"></i>
                                                            </button>
                                                        </form>
                                                    }
                                                    
                                                    <form asp-page="/Admin/Index" asp-page-handler="DeleteUser" method="post" class="m-0">
                                                        <input type="hidden" name="id" value="@user.Id" />
                                                        <button type="submit" 
                                                            onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này?');"
                                                            class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors"
                                                            title="Xóa tài khoản">
                                                            <i class="fa-solid fa-trash-can text-sm"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit HOD Modal -->
<div id="editHodModal" class="fixed inset-0 z-50 hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl w-full max-w-md flex flex-col shadow-2xl transition-all scale-95 duration-200" id="editHodModalContainer">
        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <div>
                <h3 class="text-base font-bold text-gray-800 dark:text-slate-100">Chuyển Bộ môn</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5" id="editHodEmailDisplay"></p>
            </div>
            <button onclick="closeEditHodModal()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form asp-page="/Admin/HeadOfDepartments" asp-page-handler="UpdateHodDepartment" method="post">
            <input type="hidden" name="id" id="editHodId" />
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Chọn Bộ môn mới</label>
                    <select name="departmentId" id="editHodDepartmentId" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all">
                        <option value="">-- Không quản lý bộ môn nào --</option>
                        @if(ViewBag.Departments != null)
                        {
                            foreach(var dept in ViewBag.Departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end gap-3 bg-slate-50 dark:bg-slate-800/50 rounded-b-3xl">
                <button type="button" onclick="closeEditHodModal()" class="px-5 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors">Hủy</button>
                <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 shadow-md shadow-blue-500/20 rounded-xl transition-all">Lưu Thay Đổi</button>
            </div>
        </form>
    </div>
</div>

<!-- Term History Modal -->
<div id="termHistoryModal" class="fixed inset-0 z-50 hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl w-full max-w-lg flex flex-col shadow-2xl transition-all scale-95 duration-200" id="termHistoryModalContainer">
        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <div>
                <h3 class="text-base font-bold text-gray-800 dark:text-slate-100">Lịch sử Nhiệm kỳ</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5" id="termHistoryUserName"></p>
            </div>
            <button onclick="closeTermHistoryModal()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="p-6">
            <ul id="termHistoryList" class="space-y-4">
                <!-- Dynamically populated -->
            </ul>
        </div>
        <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end bg-slate-50 dark:bg-slate-800/50 rounded-b-3xl">
            <button type="button" onclick="closeTermHistoryModal()" class="px-5 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors">Đóng</button>
        </div>
    </div>
</div>

<!-- Dept Term History Modal -->
<div id="deptTermHistoryModal" class="fixed inset-0 z-50 hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl w-full max-w-lg flex flex-col shadow-2xl transition-all scale-95 duration-200" id="deptTermHistoryModalContainer">
        <!-- Header -->
        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-900/50 rounded-t-3xl">
            <div>
                <h3 class="text-lg font-bold text-slate-800 dark:text-slate-100" id="deptTermHistoryTitle">Lịch sử Quản lý</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Danh sách các Trưởng bộ môn qua từng nhiệm kỳ.</p>
            </div>
            <button onclick="closeDeptTermHistoryModal()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <!-- Body -->
        <div class="p-6 overflow-y-auto max-h-[60vh]">
            <ul id="deptTermHistoryList" class="space-y-3">
                <li class="text-center text-slate-500 text-sm py-4">Đang tải...</li>
            </ul>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 rounded-b-3xl flex justify-end">
            <button type="button" onclick="closeDeptTermHistoryModal()" class="px-5 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors">Đóng</button>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    function openEditHodModal(id, departmentId, email) {
        document.getElementById('editHodId').value = id;
        document.getElementById('editHodEmailDisplay').textContent = email;
        
        const select = document.getElementById('editHodDepartmentId');
        if (departmentId) {
            select.value = departmentId;
        } else {
            select.value = "";
        }
        
        const modal = document.getElementById('editHodModal');
        const containerEl = document.getElementById('editHodModalContainer');
        modal.classList.remove('hidden');
        setTimeout(() => {
            containerEl.classList.remove('scale-95');
            containerEl.classList.add('scale-100');
        }, 10);
    }

    function closeEditHodModal() {
        const modal = document.getElementById('editHodModal');
        const container = document.getElementById('editHodModalContainer');
        container.classList.remove('scale-100');
        container.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 200);
    }

    async function openTermHistoryModal(userId, userName) {
        document.getElementById('termHistoryUserName').textContent = userName;
        const list = document.getElementById('termHistoryList');
        list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4"><i class="fa-solid fa-circle-notch fa-spin"></i> Đang tải...</li>';
        
        const modal = document.getElementById('termHistoryModal');
        const containerEl = document.getElementById('termHistoryModalContainer');
        modal.classList.remove('hidden');
        setTimeout(() => {
            containerEl.classList.remove('scale-95');
            containerEl.classList.add('scale-100');
        }, 10);

        try {
            const res = await fetch(`?handler=HodTermHistory&userId=${userId}`);
            if (res.ok) {
                const data = await res.json();
                
                list.innerHTML = '';
                if (data.length === 0) {
                    list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4">Không có dữ liệu lịch sử.</li>';
                } else {
                    data.forEach(item => {
                        const endAtStr = item.endAt ? item.endAt : '...';
                        const statusClass = item.endAt ? 'bg-slate-100 text-slate-600' : 'bg-emerald-100 text-emerald-700 font-bold';
                        
                        list.innerHTML += `
                            <li class="flex items-center justify-between p-3 rounded-xl border border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/30">
                                <div class="flex items-center gap-3">
                                    <span class="w-8 h-8 rounded-lg bg-orange-100 dark:bg-orange-500/20 text-orange-600 dark:text-orange-400 flex items-center justify-center">
                                        <i class="fa-solid fa-building"></i>
                                    </span>
                                    <span class="text-sm font-semibold text-slate-800 dark:text-slate-200">${item.departmentName}</span>
                                </div>
                                <span class="text-xs px-2.5 py-1 rounded-lg ${statusClass}">
                                    ${item.startAt} - ${endAtStr}
                                </span>
                            </li>
                        `;
                    });
                }
            } else {
                list.innerHTML = '<li class="text-center text-red-500 text-sm py-4">Lỗi khi tải dữ liệu!</li>';
            }
        } catch (e) {
            list.innerHTML = '<li class="text-center text-red-500 text-sm py-4">Lỗi khi tải dữ liệu!</li>';
        }
    }

    function closeTermHistoryModal() {
        const modal = document.getElementById('termHistoryModal');
        const container = document.getElementById('termHistoryModalContainer');
        container.classList.remove('scale-100');
        container.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 200);
    }

    async function openDeptTermHistoryModal(deptId, deptName) {
        document.getElementById('deptTermHistoryTitle').innerText = 'Lịch sử HOD của: ' + deptName;
        const list = document.getElementById('deptTermHistoryList');
        list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4"><i class="fa-solid fa-circle-notch fa-spin text-blue-500 text-2xl"></i></li>';
        
        const modal = document.getElementById('deptTermHistoryModal');
        const containerEl = document.getElementById('deptTermHistoryModalContainer');
        modal.classList.remove('hidden');
        setTimeout(() => {
            containerEl.classList.remove('scale-95');
            containerEl.classList.add('scale-100');
        }, 10);

        try {
            const res = await fetch(`?handler=DepartmentTermHistory&deptId=${deptId}`);
            if (res.ok) {
                const data = await res.json();
                
                list.innerHTML = '';
                if (data.length === 0) {
                    list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4">Chưa có lịch sử HOD.</li>';
                    return;
                }

                data.forEach(item => {
                    const endAtStr = item.endAt ? item.endAt : '...';
                    const statusClass = item.endAt ? 'bg-slate-100 text-slate-600' : 'bg-emerald-100 text-emerald-700 font-bold';
                    
                    list.innerHTML += `
                        <li class="flex items-center justify-between p-3 rounded-xl border border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/30">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-500/20 text-blue-600 dark:text-blue-400 flex items-center justify-center">
                                    <i class="fa-solid fa-user-tie"></i>
                                </span>
                                <span class="text-sm font-semibold text-slate-800 dark:text-slate-200">${item.hodName}</span>
                            </div>
                            <span class="text-xs px-2.5 py-1 rounded-lg ${statusClass}">
                                ${item.startAt} - ${endAtStr}
                            </span>
                        </li>
                    `;
                });
            } else {
                list.innerHTML = '<li class="text-center text-red-500 text-sm py-4">Lỗi khi tải dữ liệu.</li>';
            }
        } catch (error) {
            list.innerHTML = '<li class="text-center text-red-500 text-sm py-4">Đã xảy ra lỗi mạng.</li>';
        }
    }

    function closeDeptTermHistoryModal() {
        const modal = document.getElementById('deptTermHistoryModal');
        const container = document.getElementById('deptTermHistoryModalContainer');
        container.classList.remove('scale-100');
        container.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 200);
    }
</script>

