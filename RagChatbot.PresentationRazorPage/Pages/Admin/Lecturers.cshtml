@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.LecturersModel
@{
    ViewData["Title"] = "Quản lý Giảng viên";
}

<div class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8 transition-colors duration-200">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center">
                <i class="fa-solid fa-graduation-cap"></i>
            </span>
            Quản lý Giảng viên
        </h1>
        
        <div class="flex items-center gap-3">
            <a asp-page="/Admin/HeadOfDepartments" class="px-4 py-2 bg-orange-100 dark:bg-orange-500/20 text-orange-700 dark:text-orange-400 rounded-lg text-sm font-semibold hover:bg-orange-200 dark:hover:bg-orange-500/30 transition">
                <i class="fa-solid fa-user-tie mr-2"></i>Quản lý HOD
            </a>
            <a asp-page="/Admin/Departments" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition">
                <i class="fa-solid fa-building mr-2"></i>Quản lý Bộ môn
            </a>
            <a asp-page="/Admin/Subjects" class="px-4 py-2 bg-blue-100 dark:bg-blue-500/20 text-blue-700 dark:text-blue-400 rounded-lg text-sm font-semibold hover:bg-blue-200 dark:hover:bg-blue-500/30 transition">
                <i class="fa-solid fa-book mr-2"></i>Quản lý Môn học
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-6 p-4 bg-emerald-50 border border-emerald-200 dark:bg-emerald-500/10 dark:border-emerald-500/30 text-emerald-800 dark:text-emerald-400 rounded-xl flex items-center gap-3 animate-fadeIn">
            <i class="fa-solid fa-circle-check text-lg"></i>
            <span class="text-sm font-semibold">@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-6 p-4 bg-rose-50 border border-rose-200 dark:bg-rose-500/10 dark:border-rose-500/30 text-rose-800 dark:text-rose-400 rounded-xl flex items-center gap-3 animate-fadeIn">
            <i class="fa-solid fa-circle-exclamation text-lg"></i>
            <span class="text-sm font-semibold">@TempData["Error"]</span>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left Panel: Create Account -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm sticky top-20">
                <h2 class="text-base font-bold text-gray-900 dark:text-white mb-5 flex items-center gap-2">
                    <i class="fa-solid fa-user-plus text-emerald-500 dark:text-emerald-400"></i>
                    Tạo tài khoản Giảng viên
                </h2>

                <!-- Form Type Tabs -->
                <div class="flex gap-2 mb-6 p-1 bg-slate-100 dark:bg-slate-800/50 rounded-xl">
                    <button type="button" onclick="switchFormTab('manual')" id="tabManual" class="flex-1 py-2 px-3 text-sm font-semibold rounded-lg bg-white dark:bg-slate-700 shadow-sm text-gray-900 dark:text-white transition-all">Tạo thủ công</button>
                    <button type="button" onclick="switchFormTab('bulk')" id="tabBulk" class="flex-1 py-2 px-3 text-sm font-semibold rounded-lg text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-all">Import File</button>
                </div>

                <!-- Form 1: Manual Single Creation -->
                <form asp-page-handler="CreateSingleLecturer" method="post" id="formManual" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Họ</label>
                            <input type="text" name="firstName" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Tên</label>
                            <input type="text" name="lastName" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Email</label>
                        <input type="email" name="email" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Mật khẩu</label>
                        <input type="text" name="password" value="123456" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Bộ môn / Khoa</label>
                        <select name="departmentId" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all cursor-pointer">
                            <option value="">— Chọn bộ môn —</option>
                            @foreach (var dept in Model.Departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="w-full mt-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-emerald-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Tạo giảng viên</span>
                        <i class="fa-solid fa-plus text-xs"></i>
                    </button>
                </form>

                <!-- Form 2: Bulk CSV Import -->
                <form asp-page-handler="CreateLecturersBulk" method="post" enctype="multipart/form-data" id="formBulk" class="space-y-4 hidden">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Bộ môn / Khoa</label>
                        <select name="departmentId" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all cursor-pointer">
                            <option value="">— Chọn bộ môn —</option>
                            @foreach (var dept in Model.Departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">File .CSV / .TXT</label>
                        <p class="text-[10px] text-slate-450 mb-2">Mỗi dòng 1 giảng viên: <code class="bg-slate-100 dark:bg-slate-800 px-1 rounded">Email, Họ, Tên</code><br>Mật khẩu mặc định: <b>123456</b></p>
                        <input type="file" name="file" accept=".csv,.txt" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none transition-all" />
                    </div>
                    <button type="submit" class="w-full mt-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-emerald-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Import File</span>
                        <i class="fa-solid fa-file-import text-xs"></i>
                    </button>
                </form>
            </div>
        </div>

        <!-- Right Panel: Filters and List -->
        <div class="lg:col-span-2 space-y-6">
            
            <!-- Filters -->
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm">
                <form method="get" class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-magnifying-glass text-slate-400 text-xs"></i>
                        </div>
                        <input type="text" name="searchEmail" value="@Model.SearchEmail" class="w-full pl-9 pr-4 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl text-xs focus:border-emerald-500 outline-none transition-all dark:text-white" placeholder="Tìm theo email..." />
                    </div>
                    <div>
                        <select name="departmentId" class="w-full py-2 px-3 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl text-xs outline-none focus:border-emerald-500 transition-all dark:text-white cursor-pointer">
                            <option value="">— Lọc theo bộ môn —</option>
                            @foreach (var dept in Model.Departments)
                            {
                                <option value="@dept.Id" selected="@(Model.SelectedDepartmentId == dept.Id)">@dept.Name</option>
                            }
                        </select>
                    </div>
                    <div class="flex gap-2">
                        <select name="subjectId" class="flex-1 min-w-0 py-2 px-3 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl text-xs outline-none focus:border-emerald-500 transition-all dark:text-white cursor-pointer">
                            <option value="">— Lọc theo môn học —</option>
                            @foreach (var sub in Model.AllSubjects.Where(s => s.IsActive))
                            {
                                <option value="@sub.Id" selected="@(Model.SelectedSubjectId == sub.Id)">@sub.Code - @sub.Name</option>
                            }
                        </select>
                        <button type="submit" class="bg-slate-800 hover:bg-slate-950 dark:bg-slate-800 dark:hover:bg-slate-700 text-white text-xs font-semibold py-2 px-4 rounded-xl transition">
                            Lọc
                        </button>
                        @if (Model.SelectedDepartmentId.HasValue || Model.SelectedSubjectId.HasValue || !string.IsNullOrEmpty(Model.SearchEmail))
                        {
                            <a asp-page="/Admin/Lecturers" class="bg-rose-100 text-rose-600 hover:bg-rose-200 dark:bg-rose-500/20 dark:text-rose-450 dark:hover:bg-rose-500/30 py-2 px-3 rounded-xl transition flex items-center justify-center">
                                <i class="fa-solid fa-xmark text-sm"></i>
                            </a>
                        }
                    </div>
                </form>
            </div>

            <!-- List: Active Lecturers -->
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800/60 flex items-center justify-between bg-slate-50 dark:bg-slate-800/30">
                    <h3 class="text-sm font-bold text-gray-900 dark:text-white flex items-center gap-2">
                        <i class="fa-solid fa-users text-emerald-500"></i>
                        Danh sách Giảng viên đang hoạt động
                    </h3>
                    <span class="bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 text-[10px] font-bold px-2.5 py-1 rounded-full">
                        @Model.Users.Count() giảng viên
                    </span>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-xs text-slate-650 dark:text-slate-300">
                        <thead class="bg-slate-50/50 dark:bg-slate-900/50 border-b border-slate-150 dark:border-slate-800">
                            <tr>
                                <th class="px-6 py-3 font-semibold text-slate-500">Thông tin Giảng viên</th>
                                <th class="px-6 py-3 font-semibold text-slate-500">Môn học phụ trách</th>
                                <th class="px-6 py-3 text-right font-semibold text-slate-500">Hành động</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                            @if (!Model.Users.Any())
                            {
                                <tr>
                                    <td colspan="3" class="px-6 py-12 text-center text-slate-400">
                                        <i class="fa-solid fa-user-slash text-3xl mb-2 opacity-30"></i>
                                        <p class="font-medium text-xs">Không tìm thấy giảng viên nào</p>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var user in Model.Users)
                                {
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/20 transition group">
                                        <td class="px-6 py-3">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center text-white font-bold text-xs shadow-sm">
                                                    @(!string.IsNullOrEmpty(user.LastName) ? user.LastName.Substring(0, 1) : "")@(!string.IsNullOrEmpty(user.FirstName) ? user.FirstName.Substring(0, 1) : "")
                                                </div>
                                                <div>
                                                    <div class="font-bold text-gray-900 dark:text-slate-100 group-hover:text-emerald-600 transition-colors flex items-center gap-1.5">
                                                        @user.LastName @user.FirstName
                                                        <span class="text-[9px] text-slate-400 font-mono">#@user.Id</span>
                                                    </div>
                                                    <div class="text-[10px] text-slate-400 flex flex-col gap-0.5 mt-0.5">
                                                        <span class="flex items-center gap-1"><i class="fa-solid fa-envelope opacity-70"></i>@user.Email</span>
                                                        <span class="text-emerald-600 dark:text-emerald-450 font-bold flex items-center gap-1">
                                                            <i class="fa-solid fa-building"></i> BM: @(user.Department?.Name ?? "Chưa gán")
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-3">
                                            <div class="flex flex-wrap gap-1 max-w-[200px]">
                                                @if (Model.LecturerSubjects.ContainsKey(user.Id) && Model.LecturerSubjects[user.Id].Any())
                                                {
                                                    @foreach (var sub in Model.LecturerSubjects[user.Id])
                                                    {
                                                        <span class="px-2 py-0.5 rounded bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border border-emerald-250 dark:border-emerald-500/20 text-[9px] font-bold" title="@sub.Name">
                                                            @sub.Code
                                                        </span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-[10px] text-slate-400 italic">Chưa phân công</span>
                                                }
                                            </div>
                                        </td>
                                        <td class="px-6 py-3">
                                            <div class="flex items-center justify-end gap-1.5 opacity-80 group-hover:opacity-100 transition-opacity">
                                                <button type="button" onclick="toggleSubjectsModal(@user.Id, true)" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 hover:text-emerald-600 hover:bg-emerald-50 dark:text-slate-350 dark:hover:text-emerald-400 dark:hover:bg-emerald-500/10 transition shadow-sm" title="Phân công môn học">
                                                    <i class="fa-solid fa-book text-[13px]"></i>
                                                </button>
                                                <button type="button" onclick="toggleEditModal(@user.Id, true)" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 hover:text-blue-600 hover:bg-blue-50 dark:text-slate-350 dark:hover:text-blue-400 dark:hover:bg-blue-500/10 transition shadow-sm" title="Chỉnh sửa thông tin">
                                                    <i class="fa-solid fa-user-pen text-[13px]"></i>
                                                </button>
                                                <form asp-page-handler="ResetPassword" method="post" class="m-0">
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <button type="submit" onclick="return confirm('Đặt lại mật khẩu giảng viên này về 123456?');" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 hover:text-orange-600 hover:bg-orange-50 dark:text-slate-350 dark:hover:text-orange-400 dark:hover:bg-orange-500/10 transition shadow-sm" title="Reset Mật khẩu">
                                                        <i class="fa-solid fa-key text-[13px]"></i>
                                                    </button>
                                                </form>
                                                <form asp-page-handler="DeleteLecturer" method="post" class="m-0">
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <button type="submit" onclick="return confirm('Khóa tài khoản giảng viên này?');" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-650 hover:text-rose-600 hover:bg-rose-50 dark:text-slate-350 dark:hover:text-rose-400 dark:hover:bg-rose-500/10 transition shadow-sm" title="Vô hiệu hóa tài khoản">
                                                        <i class="fa-solid fa-user-lock text-[13px]"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>

                                    <!-- Modals per user -->
                                    <!-- Modal 1: Change Subjects -->
                                    <div id="editSubjectsModal-@user.Id" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 dark:bg-slate-950/80 backdrop-blur-sm">
                                        <div class="bg-white dark:bg-slate-900 w-full max-w-md mx-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-2xl overflow-hidden animate-fadeIn">
                                            <form method="post" asp-page-handler="ChangeSubjects">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <div class="p-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 flex items-center justify-between">
                                                    <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2 text-sm sm:text-base">
                                                        <i class="fa-solid fa-book text-emerald-500"></i> Phân công môn giảng dạy
                                                    </h3>
                                                    <button type="button" onclick="toggleSubjectsModal(@user.Id, false)" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                                                        <i class="fa-solid fa-xmark text-lg"></i>
                                                    </button>
                                                </div>
                                                <div class="p-5 space-y-4 text-left max-h-[60vh] overflow-y-auto custom-scrollbar">
                                                    <p class="text-xs text-slate-500 dark:text-slate-400">Chọn môn học giảng viên <strong>@user.LastName @user.FirstName</strong> đảm nhiệm giảng dạy:</p>
                                                    
                                                    <div class="space-y-4">
                                                        @foreach (var deptGroup in Model.AllSubjects.GroupBy(s => s.DepartmentName))
                                                        {
                                                            <div class="space-y-1.5">
                                                                <h4 class="text-[10px] font-bold text-slate-450 dark:text-slate-500 uppercase tracking-wider mb-1">Bộ môn: @(string.IsNullOrEmpty(deptGroup.Key) ? "Khác" : deptGroup.Key)</h4>
                                                                <div class="grid grid-cols-1 gap-1.5">
                                                                    @foreach (var sub in deptGroup.Where(s => s.IsActive))
                                                                    {
                                                                        var isChecked = Model.LecturerSubjects.ContainsKey(user.Id) && Model.LecturerSubjects[user.Id].Any(s => s.Id == sub.Id);
                                                                        <label class="flex items-center gap-2.5 p-2 rounded-xl border border-slate-100 dark:border-slate-850 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition cursor-pointer">
                                                                            <input type="checkbox" name="subjectIds" value="@sub.Id" @(isChecked ? "checked" : "")
                                                                                    data-subject-code="@sub.Code"
                                                                                    data-subject-name="@sub.Name"
                                                                                    data-currently-assigned="@(sub.LecturerId.HasValue && sub.LecturerId.Value != user.Id ? "true" : "false")"
                                                                                    data-current-lecturer-name="@sub.LecturerName"
                                                                                    onchange="handleSubjectCheckboxChange(this)"
                                                                                    class="rounded border-slate-350 dark:border-slate-700 text-emerald-600 focus:ring-emerald-500 w-4 h-4 cursor-pointer" />
                                                                            <div class="text-xs">
                                                                                <span class="font-bold text-gray-800 dark:text-slate-200">@sub.Code</span>
                                                                                <span class="text-slate-500 dark:text-slate-400 ml-1.5">— @sub.Name</span>
                                                                            </div>
                                                                        </label>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="p-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end gap-2 bg-slate-50/50 dark:bg-slate-900/30">
                                                    <button type="button" onclick="toggleSubjectsModal(@user.Id, false)" class="px-4 py-2 text-xs font-semibold text-slate-500 hover:text-slate-750 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
                                                        Hủy bỏ
                                                    </button>
                                                    <button type="submit" class="px-4 py-2 text-xs font-bold text-white bg-emerald-600 hover:bg-emerald-550 rounded-xl transition shadow-md shadow-emerald-500/10 flex items-center gap-1.5">
                                                        <i class="fa-solid fa-circle-check"></i> Lưu thay đổi
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>

                                    <!-- Modal 2: Edit Lecturer Details -->
                                    <div id="editLecturerModal-@user.Id" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 dark:bg-slate-950/80 backdrop-blur-sm">
                                        <div class="bg-white dark:bg-slate-900 w-full max-w-md mx-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-2xl overflow-hidden animate-fadeIn">
                                            <form method="post" asp-page-handler="EditLecturer">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <div class="p-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 flex items-center justify-between">
                                                    <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2 text-sm sm:text-base">
                                                        <i class="fa-solid fa-user-pen text-emerald-500"></i> Chỉnh sửa giảng viên
                                                    </h3>
                                                    <button type="button" onclick="toggleEditModal(@user.Id, false)" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                                                        <i class="fa-solid fa-xmark text-lg"></i>
                                                    </button>
                                                </div>
                                                <div class="p-5 space-y-4 text-left">
                                                    <div class="grid grid-cols-2 gap-4">
                                                        <div>
                                                            <label class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Họ</label>
                                                            <input type="text" name="firstName" value="@user.FirstName" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-3 py-2 text-xs text-gray-900 dark:text-white outline-none focus:border-emerald-500 transition" />
                                                        </div>
                                                        <div>
                                                            <label class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Tên</label>
                                                            <input type="text" name="lastName" value="@user.LastName" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-3 py-2 text-xs text-gray-900 dark:text-white outline-none focus:border-emerald-500 transition" />
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <label class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Bộ môn / Khoa</label>
                                                        <select name="departmentId" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-3 py-2 text-xs text-gray-900 dark:text-white outline-none focus:border-emerald-500 transition cursor-pointer">
                                                            @foreach (var dept in Model.Departments)
                                                            {
                                                                <option value="@dept.Id" selected="@(user.DepartmentId == dept.Id)">@dept.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="p-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end gap-2 bg-slate-50/50 dark:bg-slate-900/30">
                                                    <button type="button" onclick="toggleEditModal(@user.Id, false)" class="px-4 py-2 text-xs font-semibold text-slate-500 hover:text-slate-750 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
                                                        Hủy bỏ
                                                    </button>
                                                    <button type="submit" class="px-4 py-2 text-xs font-bold text-white bg-emerald-600 hover:bg-emerald-550 rounded-xl transition shadow-md shadow-emerald-500/10 flex items-center gap-1.5">
                                                        <i class="fa-solid fa-circle-check"></i> Lưu lại
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- List: Banned Lecturers -->
            @if (Model.BannedUsers != null && Model.BannedUsers.Any())
            {
                <div class="bg-white dark:bg-slate-900 border border-rose-200 dark:border-rose-900/40 rounded-2xl shadow-sm overflow-hidden mt-6 animate-fadeIn">
                    <div class="px-6 py-4 border-b border-rose-100 dark:border-rose-950/40 flex items-center justify-between bg-rose-50/50 dark:bg-rose-900/10">
                        <h3 class="text-sm font-bold text-gray-900 dark:text-white flex items-center gap-2">
                            <i class="fa-solid fa-user-lock text-rose-500"></i>
                            Tài khoản Giảng viên đã bị Khóa
                        </h3>
                        <span class="bg-rose-100 dark:bg-rose-500/20 text-rose-700 dark:text-rose-450 text-[10px] font-bold px-2.5 py-1 rounded-full">
                            @Model.BannedUsers.Count() giảng viên
                        </span>
                    </div>
                    
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-xs text-slate-650 dark:text-slate-300">
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                                @foreach (var user in Model.BannedUsers)
                                {
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/20 transition group opacity-75 hover:opacity-100">
                                        <td class="px-6 py-3">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-lg bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-slate-500 dark:text-slate-400 font-bold text-xs shadow-sm">
                                                    @(!string.IsNullOrEmpty(user.LastName) ? user.LastName.Substring(0, 1) : "")@(!string.IsNullOrEmpty(user.FirstName) ? user.FirstName.Substring(0, 1) : "")
                                                </div>
                                                <div>
                                                    <div class="font-bold text-slate-500 dark:text-slate-400 flex items-center gap-1.5 line-through">
                                                        @user.LastName @user.FirstName
                                                        <span class="text-[9px] text-slate-400 font-mono no-underline">#@user.Id</span>
                                                    </div>
                                                    <div class="text-[10px] text-slate-450 flex flex-col gap-0.5 mt-0.5">
                                                        <span class="flex items-center gap-1"><i class="fa-solid fa-envelope opacity-70"></i>@user.Email</span>
                                                        <span class="text-slate-500 flex items-center gap-1">
                                                            <i class="fa-solid fa-building"></i> BM: @(user.Department?.Name ?? "Chưa gán")
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-3">
                                            <div class="flex items-center justify-end gap-2">
                                                <form asp-page-handler="RestoreLecturer" method="post" class="m-0">
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <button type="submit" onclick="return confirm('Mở khóa tài khoản giảng viên này?');" class="px-3 py-1.5 flex items-center gap-1.5 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-100 dark:hover:bg-emerald-500/20 transition font-semibold text-2xs shadow-sm">
                                                        <i class="fa-solid fa-unlock"></i> Mở khóa
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function switchFormTab(tab) {
        const tabManual = document.getElementById('tabManual');
        const tabBulk = document.getElementById('tabBulk');
        const formManual = document.getElementById('formManual');
        const formBulk = document.getElementById('formBulk');

        const activeClasses = ['bg-white', 'dark:bg-slate-700', 'shadow-sm', 'text-gray-900', 'dark:text-white'];
        const inactiveClasses = ['text-slate-500', 'hover:text-slate-700', 'dark:text-slate-400', 'dark:hover:text-slate-200'];

        if (tab === 'manual') {
            formManual.classList.remove('hidden');
            formBulk.classList.add('hidden');
            
            tabManual.classList.add(...activeClasses);
            tabManual.classList.remove(...inactiveClasses);
            
            tabBulk.classList.remove(...activeClasses);
            tabBulk.classList.add(...inactiveClasses);
        } else {
            formManual.classList.add('hidden');
            formBulk.classList.remove('hidden');
            
            tabBulk.classList.add(...activeClasses);
            tabBulk.classList.remove(...inactiveClasses);
            
            tabManual.classList.remove(...activeClasses);
            tabManual.classList.add(...inactiveClasses);
        }
    }

    function toggleSubjectsModal(userId, show) {
        const modal = document.getElementById(`editSubjectsModal-${userId}`);
        if (modal) {
            if (show) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
    }

    function toggleEditModal(userId, show) {
        const modal = document.getElementById(`editLecturerModal-${userId}`);
        if (modal) {
            if (show) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
    }

    function handleSubjectCheckboxChange(checkbox) {
        if (checkbox.checked && checkbox.getAttribute('data-currently-assigned') === 'true') {
            const subjectCode = checkbox.getAttribute('data-subject-code');
            const subjectName = checkbox.getAttribute('data-subject-name');
            const currentLecturer = checkbox.getAttribute('data-current-lecturer-name');
            
            // Tạm thời bỏ chọn checkbox cho đến khi người dùng xác nhận
            checkbox.checked = false;

            if (typeof showConfirmModal === 'function') {
                showConfirmModal(
                    'Xác nhận gán môn học',
                    `Môn học "${subjectCode} - ${subjectName}" đang được phân công cho giảng viên "${currentLecturer}". Bạn có chắc chắn muốn chuyển quyền phụ trách môn này sang giảng viên hiện tại?`,
                    () => {
                        // Nếu đồng ý, đánh dấu lại checkbox và cho phép đổi trạng thái
                        checkbox.checked = true;
                    },
                    'Đồng ý',
                    false // isDanger = false để hiện màu xanh (emerald) của hệ thống
                );
            } else {
                const confirmed = confirm(`Môn học "${subjectCode} - ${subjectName}" đang được phân công cho giảng viên "${currentLecturer}". Bạn có chắc chắn muốn chuyển quyền phụ trách môn này sang giảng viên hiện tại?`);
                if (confirmed) {
                    checkbox.checked = true;
                }
            }
        }
    }
</script>

