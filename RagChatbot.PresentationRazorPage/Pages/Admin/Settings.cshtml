@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = "Cấu hình Giá & API";
}

<div class="max-w-4xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-white flex items-center gap-2">
                <i class="fa-solid fa-gear text-emerald-500"></i> Cấu hình Hệ thống
            </h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1">Quản lý tỷ giá, chi phí token và các thiết lập lõi của hệ thống.</p>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
        <form method="post" class="p-6 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- UsdVndRate -->
                <div class="space-y-2 md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Tỷ giá USD sang VNĐ</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-money-bill-wave text-slate-400"></i>
                        </div>
                        <input type="number" step="0.01" asp-for="Input.UsdVndRate" 
                               class="pl-10 w-full rounded-xl border-slate-200 dark:border-slate-700 dark:bg-slate-800 focus:ring-emerald-500 focus:border-emerald-500 sm:text-sm h-11" placeholder="25000">
                    </div>
                    <p class="text-xs text-slate-500">Dùng để quy đổi chi phí AI từ USD sang VNĐ để hiển thị lên Dashboard.</p>
                </div>

                <div class="md:col-span-2 border-t border-slate-200 dark:border-slate-800 my-4"></div>

                <!-- Token In -->
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Giá Token Đầu vào (Input)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="text-slate-400">$</span>
                        </div>
                        <input type="number" step="0.001" asp-for="Input.TokenInCostPerMillion" 
                               class="pl-8 pr-12 w-full rounded-xl border-slate-200 dark:border-slate-700 dark:bg-slate-800 focus:ring-emerald-500 focus:border-emerald-500 sm:text-sm h-11" placeholder="0.075">
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <span class="text-slate-400 text-xs">/ 1M Token</span>
                        </div>
                    </div>
                </div>

                <!-- Token Out -->
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Giá Token Đầu ra (Output)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="text-slate-400">$</span>
                        </div>
                        <input type="number" step="0.001" asp-for="Input.TokenOutCostPerMillion" 
                               class="pl-8 pr-12 w-full rounded-xl border-slate-200 dark:border-slate-700 dark:bg-slate-800 focus:ring-emerald-500 focus:border-emerald-500 sm:text-sm h-11" placeholder="0.30">
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <span class="text-slate-400 text-xs">/ 1M Token</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex justify-end pt-4 border-t border-slate-200 dark:border-slate-800">
                <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-xl transition-colors shadow-sm">
                    <i class="fa-solid fa-floppy-disk"></i> Lưu cấu hình
                </button>
            </div>
        </form>
    </div>
</div>
