@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.StudentModel
@{
    ViewData["Title"] = "Quản lý Học sinh";
    var roleText = "Học sinh";
}

    <div class="max-w-6xl mx-auto p-4 sm:p-6 lg:p-8 transition-colors duration-200">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center">
                <i class="fa-solid fa-users-gear"></i>
            </span>
            Quản lý Học sinh
        </h1>
        
        <div class="flex items-center gap-3">
            <a asp-page="/Admin/HeadOfDepartments" class="px-4 py-2 bg-orange-100 dark:bg-orange-500/20 text-orange-700 dark:text-orange-400 rounded-lg text-sm font-semibold hover:bg-orange-200 dark:hover:bg-orange-500/30 transition">
                <i class="fa-solid fa-user-tie mr-2"></i>Quản lý HOD
            </a>
            <a asp-page="/Admin/Departments" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition">
                <i class="fa-solid fa-building mr-2"></i>Quản lý Bộ môn
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    
    

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm sticky top-20">
                <h2 class="text-base font-bold text-gray-900 dark:text-white mb-5 flex items-center gap-2">
                    <i class="fa-solid fa-user-plus text-emerald-500 dark:text-emerald-400"></i>
                    Tạo tài khoản mới
                </h2>

                <!-- Tabs -->
                <div class="flex gap-2 mb-6 p-1 bg-slate-100 dark:bg-slate-800/50 rounded-xl">
                    <button type="button" onclick="switchUserTab('manual')" id="tabUserManual" class="flex-1 py-2 px-3 text-sm font-semibold rounded-lg bg-white dark:bg-slate-700 shadow-sm text-gray-900 dark:text-white transition-all">Tạo thủ công</button>
                    <button type="button" onclick="switchUserTab('bulk')" id="tabUserBulk" class="flex-1 py-2 px-3 text-sm font-semibold rounded-lg text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-all">Import File</button>
                </div>

                <!-- Manual Form -->
                <form asp-page="/Admin/Student" asp-page-handler="CreateSingleUser" method="post" id="formUserManual" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Họ</label>
                            <input type="text" name="firstName" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Tên</label>
                            <input type="text" name="lastName" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Email</label>
                        <input type="email" name="email" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Mật khẩu</label>
                        <input type="text" name="password" value="123456" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all" />
                    </div>
                    <input type="hidden" name="role" value="Student" />
                    
                    <button type="submit" class="w-full mt-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-emerald-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Tạo tài khoản</span>
                        <i class="fa-solid fa-plus text-xs"></i>
                    </button>
                </form>

                <!-- Bulk Form -->
                <form asp-page="/Admin/Student" asp-page-handler="CreateUsers" method="post" enctype="multipart/form-data" id="formUserBulk" class="space-y-4 hidden">
                    <input type="hidden" name="role" value="Student" />
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">
                            File .CSV / .TXT
                        </label>
                        <p class="text-[10px] text-slate-400 mb-2">Mỗi dòng 1 người. Định dạng: <code class="bg-slate-100 dark:bg-slate-800 px-1 rounded">Email, Họ, Tên</code><br>Mật khẩu mặc định: <b>123456</b></p>
                        <input type="file" name="file" accept=".csv,.txt" required
                               class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all" />
                    </div>
                    <button type="submit" class="w-full mt-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-emerald-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Import File</span>
                        <i class="fa-solid fa-file-import text-xs"></i>
                    </button>
                </form>
            </div>
        </div>

        <!-- Danh sách Học sinh -->
        <div class="lg:col-span-2 space-y-4">
            
            <!-- Form Tìm kiếm -->
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-4 shadow-sm">
                <form asp-page="/Admin/Student" method="get" class="flex gap-2">
                    <div class="relative flex-1">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-magnifying-glass text-slate-400"></i>
                        </div>
                        <input type="text" name="searchEmail" value="@ViewContext.HttpContext.Request.Query["searchEmail"]" class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl text-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all dark:text-white" placeholder="Tìm kiếm theo Email..." />
                    </div>
                    <button type="submit" class="bg-slate-800 hover:bg-slate-900 dark:bg-slate-700 dark:hover:bg-slate-600 text-white text-sm font-semibold py-2.5 px-6 rounded-xl transition-all">
                        Tìm kiếm
                    </button>
                    @if(!string.IsNullOrEmpty(ViewContext.HttpContext.Request.Query["searchEmail"]))
                    {
                        <a asp-page="/Admin/Student" class="bg-rose-100 text-rose-600 hover:bg-rose-200 dark:bg-rose-500/20 dark:text-rose-400 dark:hover:bg-rose-500/30 text-sm font-semibold py-2.5 px-4 rounded-xl transition-all flex items-center">
                            <i class="fa-solid fa-xmark"></i>
                        </a>
                    }
                </form>
            </div>
            
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
                <div class="px-6 py-3 border-b border-slate-100 dark:border-slate-800/60 flex items-center justify-between bg-slate-50 dark:bg-slate-800/50">
                    <h3 class="text-base font-bold text-gray-900 dark:text-white flex items-center gap-2">
                        <i class="fa-solid fa-users text-emerald-500 dark:text-emerald-400"></i>
                        Danh sách @roleText
                    </h3>
                    <span class="bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 text-xs font-bold px-2.5 py-1 rounded-full">
                        @Model.Users.Count() @roleText.ToLower()
                    </span>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-slate-600 dark:text-slate-300">
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                            @if (!Model.Users.Any())
                            {
                                <tr>
                                    <td colspan="2" class="px-6 py-12 text-center">
                                        <div class="flex flex-col items-center justify-center text-slate-400 dark:text-slate-500">
                                            <i class="fa-solid fa-user-slash text-4xl mb-3 opacity-20"></i>
                                            <p class="font-medium">Chưa có dữ liệu</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var user in Model.Users)
                                {
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
                                        <td class="px-6 py-2.5">
                                            <div class="flex items-center gap-3">
                                                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center text-white font-bold text-sm shadow-sm">
                                                    @(!string.IsNullOrEmpty(user.LastName) ? user.LastName.Substring(0, 1) : "")@(!string.IsNullOrEmpty(user.FirstName) ? user.FirstName.Substring(0, 1) : "")
                                                </div>
                                                <div>
                                                    <div class="font-bold text-gray-900 dark:text-slate-100 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors flex items-center gap-2">
                                                        @user.LastName @user.FirstName
                                                        <span class="text-[10px] text-slate-400 font-mono">#@user.Id</span>
                                                    </div>
                                                    <div class="text-xs text-slate-550 dark:text-slate-400 mt-0.5 flex flex-col gap-0.5">
                                                        <span class="flex items-center gap-1"><i class="fa-solid fa-envelope text-[10px] opacity-70"></i>@user.Email</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="px-6 py-2.5">
                                            <div class="flex flex-col gap-1">
                                                <span class="text-xs font-semibold text-emerald-600 dark:text-emerald-400">
                                                    @user.TokenIn.ToString("N0") <span class="font-normal opacity-70">In</span>
                                                </span>
                                                <span class="text-xs font-semibold text-rose-600 dark:text-rose-400">
                                                    @user.TokenOut.ToString("N0") <span class="font-normal opacity-70">Out</span>
                                                </span>
                                                <span class="text-[10px] text-slate-500 font-mono mt-0.5">
                                                    ~@user.CostVnd.ToString("N0") VNĐ
                                                </span>
                                            </div>
                                        </td>
                                        
                                        <td class="px-6 py-2.5">
                                            <div class="flex items-center justify-end gap-2 opacity-80 group-hover:opacity-100 transition-opacity">
                                                <button type="button" 
                                                        style="display:none;"
                                                        class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-500 hover:text-emerald-600 hover:bg-emerald-50 dark:hover:text-emerald-400 dark:hover:bg-emerald-500/20 transition-all shadow-sm"
                                                        title="Xem chi tiết Token">
                                                    <i class="fa-solid fa-chart-line text-sm"></i>
                                                </button>
                                                <form asp-page="/Admin/Student" asp-page-handler="ResetPassword" method="post" class="m-0">
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <button type="submit" 
                                                        onclick="return confirm('Bạn có chắc chắn muốn đặt lại mật khẩu về 123456 cho @roleText.ToLower() này?');"
                                                        class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-500 hover:text-blue-600 hover:bg-blue-50 dark:hover:text-blue-400 dark:hover:bg-blue-500/20 transition-all shadow-sm"
                                                        title="Đặt lại mật khẩu">
                                                        <i class="fa-solid fa-key text-sm"></i>
                                                    </button>
                                                </form>
                                                <form asp-page="/Admin/Student" asp-page-handler="DeleteUser" method="post" class="m-0">
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <button type="submit" 
                                                        onclick="return confirm('Bạn có chắc chắn muốn xóa @roleText.ToLower() này?');"
                                                        class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-500 hover:text-red-600 hover:bg-red-50 dark:hover:text-red-400 dark:hover:bg-red-500/20 transition-all shadow-sm"
                                                        title="Xóa tài khoản">
                                                        <i class="fa-solid fa-trash-can text-sm"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Danh sách Người dùng Bị Khóa -->
            @if (Model.BannedUsers != null && Model.BannedUsers.Any())
            {
                <div class="bg-white dark:bg-slate-900 border border-rose-200 dark:border-rose-900/50 rounded-2xl shadow-sm overflow-hidden mt-6">
                    <div class="px-6 py-3 border-b border-rose-100 dark:border-rose-900/50 flex items-center justify-between bg-rose-50/50 dark:bg-rose-900/20">
                        <h3 class="text-base font-bold text-gray-900 dark:text-white flex items-center gap-2">
                            <i class="fa-solid fa-user-lock text-rose-500 dark:text-rose-400"></i>
                            Tài khoản @roleText bị Khóa / Đã xóa
                        </h3>
                        <span class="bg-rose-100 dark:bg-rose-500/20 text-rose-700 dark:text-rose-400 text-xs font-bold px-2.5 py-1 rounded-full">
                            @Model.BannedUsers.Count() @roleText.ToLower()
                        </span>
                    </div>
                    
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-sm text-slate-600 dark:text-slate-300">
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                                @foreach (var user in Model.BannedUsers)
                                {
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group opacity-75 hover:opacity-100">
                                        <td class="px-6 py-2.5">
                                            <div class="flex items-center gap-3">
                                                <div class="w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-slate-500 dark:text-slate-400 font-bold text-sm shadow-sm">
                                                    @(!string.IsNullOrEmpty(user.LastName) ? user.LastName.Substring(0, 1) : "")@(!string.IsNullOrEmpty(user.FirstName) ? user.FirstName.Substring(0, 1) : "")
                                                </div>
                                                <div>
                                                    <div class="font-bold text-gray-500 dark:text-slate-400 flex items-center gap-2 line-through">
                                                        @user.LastName @user.FirstName
                                                        <span class="text-[10px] text-slate-400 font-mono no-underline">#@user.Id</span>
                                                    </div>
                                                    <div class="text-xs text-slate-500 mt-0.5 flex flex-col gap-0.5">
                                                        <span class="flex items-center gap-1"><i class="fa-solid fa-envelope text-[10px] opacity-70"></i>@user.Email</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        
                                        <td class="px-6 py-2.5">
                                            <div class="flex items-center justify-end gap-2 opacity-80 group-hover:opacity-100 transition-opacity">
                                                <form asp-page="/Admin/Student" asp-page-handler="RestoreUser" method="post" class="m-0">
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <button type="submit" 
                                                        onclick="return confirm('Bạn có chắc chắn muốn khôi phục hoạt động cho @roleText.ToLower() này?');"
                                                        class="w-auto h-9 px-3 flex items-center justify-center gap-2 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-100 dark:hover:bg-emerald-500/20 transition-all shadow-sm font-semibold text-xs"
                                                        title="Khôi phục tài khoản">
                                                        <i class="fa-solid fa-unlock text-sm"></i> Khôi phục
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
    </div>

<script>
    function switchUserTab(tab) {
        const manualTab = document.getElementById('tabUserManual');
        const bulkTab = document.getElementById('tabUserBulk');
        const manualForm = document.getElementById('formUserManual');
        const bulkForm = document.getElementById('formUserBulk');

        const activeClasses = ['bg-white', 'dark:bg-slate-700', 'shadow-sm', 'text-gray-900', 'dark:text-white'];
        const inactiveClasses = ['text-slate-500', 'hover:text-slate-700', 'dark:text-slate-400', 'dark:hover:text-slate-200'];

        if (tab === 'manual') {
            manualForm.classList.remove('hidden');
            bulkForm.classList.add('hidden');
            
            manualTab.classList.add(...activeClasses);
            manualTab.classList.remove(...inactiveClasses);
            
            bulkTab.classList.remove(...activeClasses);
            bulkTab.classList.add(...inactiveClasses);
        } else {
            manualForm.classList.add('hidden');
            bulkForm.classList.remove('hidden');
            
            bulkTab.classList.add(...activeClasses);
            bulkTab.classList.remove(...inactiveClasses);
            
            manualTab.classList.remove(...activeClasses);
            manualTab.classList.add(...inactiveClasses);
        }
    }
</script>

<style>
    /* Custom Animation for alerts */
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 20px;
    }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #334155;
    }
</style>

