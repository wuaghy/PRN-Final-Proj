@page
@model RagChatbot.PresentationRazorPage.Pages.Admin.SubjectsModel
@{
    ViewData["Title"] = "Quản lý Môn học";
    var departments = ViewBag.Departments as IEnumerable<RagChatbot.Business.DTOs.DepartmentDto>;
}

<div class="max-w-6xl mx-auto p-4 sm:p-6 lg:p-8 transition-colors duration-200">

    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center">
                <i class="fa-solid fa-book"></i>
            </span>
            Quản lý Môn học
        </h1>
        
        <a asp-page="/Admin/Index" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition">
            <i class="fa-solid fa-arrow-left mr-2"></i>Quay lại QL Tài khoản
        </a>
    </div>

    

    

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        
        <!-- Form Tạo Môn học -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 shadow-sm sticky top-20">
                <h2 class="text-base font-bold text-gray-900 dark:text-white mb-5 flex items-center gap-2">
                    <i class="fa-solid fa-plus text-emerald-500 dark:text-emerald-400"></i>
                    Tạo Môn học mới
                </h2>
                
                <!-- Tabs -->
                <div class="flex gap-2 mb-6 p-1 bg-slate-100 dark:bg-slate-800/50 rounded-xl">
                    <button type="button" onclick="switchSubjectTab('manual')" id="tabSubManual" class="flex-1 py-2 px-3 text-sm font-semibold rounded-lg bg-white dark:bg-slate-700 shadow-sm text-gray-900 dark:text-white transition-all">Tạo thủ công</button>
                    <button type="button" onclick="switchSubjectTab('bulk')" id="tabSubBulk" class="flex-1 py-2 px-3 text-sm font-semibold rounded-lg text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-all">Import File</button>
                </div>
                
                <form asp-page="/Admin/Subjects" asp-page-handler="CreateSubject" method="post" id="formSubManual" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Mã môn</label>
                        <input type="text" name="code" required placeholder="VD: TRIET01"
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all" />
                    </div>
                    
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Tên môn học</label>
                        <input type="text" name="name" required placeholder="VD: Triết học Mác – Lê Nin"
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all" />
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Bộ môn</label>
                        <select name="departmentId" required
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                            <option value="">-- Chọn bộ môn --</option>
                            @if (departments != null)
                            {
                                foreach (var dept in departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <button type="submit"
                        class="w-full mt-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-emerald-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Tạo môn học</span>
                        <i class="fa-solid fa-plus text-xs"></i>
                    </button>
                </form>
                
                <form asp-page="/Admin/Subjects" asp-page-handler="CreateSubjectsBulk" method="post" enctype="multipart/form-data" id="formSubBulk" class="space-y-4 hidden">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">Bộ môn</label>
                        <select name="departmentId" required
                                class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all">
                            <option value="">-- Chọn bộ môn --</option>
                            @if (departments != null)
                            {
                                foreach (var dept in departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 uppercase tracking-wider">
                            File .TXT / .CSV
                        </label>
                        <p class="text-[10px] text-slate-400 mb-2">Định dạng mỗi dòng: <code class="bg-slate-100 dark:bg-slate-800 px-1 rounded">CODE, Tên môn học</code></p>
                        <input type="file" name="file" accept=".txt,.csv" required
                               class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all" />
                    </div>
                    
                    <button type="submit"
                        class="w-full mt-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-3 px-4 rounded-xl shadow-sm shadow-emerald-500/30 transition-all flex items-center justify-center gap-2">
                        <span>Import File</span>
                        <i class="fa-solid fa-file-import text-xs"></i>
                    </button>
                </form>
            </div>
        </div>

        <!-- Danh sách Môn học -->
        <div class="lg:col-span-3">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-800/60 bg-slate-50/50 dark:bg-slate-900/50 flex items-center justify-between">
                    <h3 class="text-base font-bold text-gray-900 dark:text-white flex items-center gap-2">
                        <i class="fa-solid fa-layer-group text-emerald-500 dark:text-emerald-400"></i>
                        Danh sách Môn học
                    </h3>
                    <span class="bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 text-xs font-bold px-2.5 py-1 rounded-full">
                        @Model.SubjectsList.Count() môn học
                    </span>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-slate-600 dark:text-slate-300">
                        <thead class="bg-slate-50 dark:bg-slate-950/50 text-xs uppercase font-semibold text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-slate-800">
                            <tr>
                                <th scope="col" class="px-6 py-4">Mã Môn</th>
                                <th scope="col" class="px-6 py-4">Tên Môn học</th>
                                <th scope="col" class="px-6 py-4">Bộ môn</th>
                                <th scope="col" class="px-6 py-4">Người quản lý</th>
                                <th scope="col" class="px-6 py-4">Trạng thái</th>
                                <th scope="col" class="px-6 py-4 text-right">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60">
                            @if (!Model.SubjectsList.Any())
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-12 text-center text-slate-500">Chưa có môn học nào.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var subject in Model.SubjectsList)
                                {
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
                                        <td class="px-6 py-4 font-mono text-xs font-bold text-slate-500 dark:text-slate-400 whitespace-nowrap">@subject.Code</td>

                                        <td class="px-6 py-4 font-bold text-gray-900 dark:text-slate-100">
                                            <a href="javascript:void(0)" onclick="openSubjectHistoryModal(@subject.Id, '@subject.Name.Replace("'", "\\'")')" class="hover:text-blue-500 transition-colors cursor-pointer decoration-blue-500/30 underline-offset-4 hover:underline">@subject.Name</a>
                                        </td>

                                        <td class="px-6 py-4">
                                            @if (!string.IsNullOrEmpty(subject.DepartmentName))
                                            {
                                                <span class="px-2 py-1 bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 rounded text-xs font-medium border border-blue-100 dark:border-blue-500/20 whitespace-nowrap">
                                                    @subject.DepartmentName
                                                </span>
                                            }
                                        </td>

                                        <td class="px-6 py-4">
                                            @if (subject.ManagerName != "Trống")
                                            {
                                                <span class="text-sm font-medium text-gray-900 dark:text-white">@subject.ManagerName</span>
                                            }
                                            else
                                            {
                                                <span class="text-xs text-gray-500 italic">Trống</span>
                                            }
                                        </td>

                                        <td class="px-6 py-4">
                                            @if (subject.IsActive)
                                            {
                                                <span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400 rounded-full text-xs font-semibold whitespace-nowrap">
                                                    Đang mở
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="px-2.5 py-1 bg-rose-50 text-rose-700 dark:bg-rose-500/10 dark:text-rose-400 rounded-full text-xs font-semibold whitespace-nowrap">
                                                    Đang ẩn
                                                </span>
                                            }
                                        </td>

                                        <td class="px-6 py-4 text-right whitespace-nowrap">
                                            <div class="flex items-center justify-end gap-1">
                                                <form asp-page="/Admin/Subjects" asp-page-handler="ToggleStatus" method="post" class="inline m-0 p-0">
                                                    <input type="hidden" name="id" value="@subject.Id" />
                                                    <button type="submit" class="p-2 transition @(subject.IsActive ? "text-slate-400 hover:text-slate-600 dark:text-slate-500 dark:hover:text-slate-400" : "text-amber-500 hover:text-amber-600")"
                                                            title="@(subject.IsActive ? "Ẩn môn học" : "Hiện môn học")">
                                                        <i class="fa-solid @(subject.IsActive ? "fa-eye" : "fa-eye-slash")"></i>
                                                    </button>
                                                </form>

                                                <button onclick="openEditModal(@subject.Id, '@subject.Code.Replace("'", "\\'")', '@subject.Name.Replace("'", "\\'")')"
                                                        class="text-emerald-500 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300 transition p-2" title="Sửa">
                                                    <i class="fa-solid fa-pen"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

<div id="editSubjectModal" class="fixed inset-0 z-[100] hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl w-full max-w-md p-6 shadow-2xl transition-all">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Cập nhật Môn học</h2>
        <form asp-page="/Admin/Subjects" asp-page-handler="UpdateSubject" method="post" class="space-y-4">
            <input type="hidden" name="id" id="editSubjectId" />
            <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1.5">Mã môn</label>
                <input type="text" name="code" id="editSubjectCode" readonly class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all cursor-not-allowed opacity-70" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1.5">Tên môn học</label>
                <input type="text" name="name" id="editSubjectName" required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all" />
            </div>
            <div class="flex justify-end gap-2 mt-4">
                <button type="button" onclick="closeEditModal()" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 rounded-lg text-sm font-semibold hover:bg-slate-200 dark:hover:bg-slate-700 transition">Hủy</button>
                <button type="submit" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-semibold transition shadow-sm shadow-emerald-500/30">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

<script>
    function confirmDeleteSubject(id, name) {
        if (confirm(`Bạn có chắc chắn muốn xóa môn học "${name}" không?`)) {
            const form = document.createElement('form');
            form.method = 'post';
            form.action = `/Admin/DeleteSubject/${id}`;
            document.body.appendChild(form);
            form.submit();
        }
    }

    function switchSubjectTab(tab) {
        const manualTab = document.getElementById('tabSubManual');
        const bulkTab = document.getElementById('tabSubBulk');
        const manualForm = document.getElementById('formSubManual');
        const bulkForm = document.getElementById('formSubBulk');

        const activeClasses = ['bg-white', 'dark:bg-slate-700', 'shadow-sm', 'text-gray-900', 'dark:text-white'];
        const inactiveClasses = ['text-slate-500', 'hover:text-slate-700', 'dark:text-slate-400', 'dark:hover:text-slate-200'];

        if (tab === 'manual') {
            manualForm.classList.remove('hidden');
            bulkForm.classList.add('hidden');
            
            manualTab.classList.add(...activeClasses);
            manualTab.classList.remove(...inactiveClasses);
            
            bulkTab.classList.remove(...activeClasses);
            bulkTab.classList.add(...inactiveClasses);
        } else {
            manualForm.classList.add('hidden');
            bulkForm.classList.remove('hidden');
            
            bulkTab.classList.add(...activeClasses);
            bulkTab.classList.remove(...inactiveClasses);
            
            manualTab.classList.remove(...activeClasses);
            manualTab.classList.add(...inactiveClasses);
        }
    }

    function openEditModal(id, code, name) {
        document.getElementById('editSubjectId').value = id;
        document.getElementById('editSubjectCode').value = code;
        document.getElementById('editSubjectName').value = name;
        document.getElementById('editSubjectModal').classList.remove('hidden');
    }

    function closeEditModal() {
        document.getElementById('editSubjectModal').classList.add('hidden');
    }

    function openSubjectHistoryModal(id, name) {
        document.getElementById('subTermHistoryTitle').innerText = 'Nhiệm kỳ môn: ' + name;
        const modal = document.getElementById('subTermHistoryModal');
        const container = document.getElementById('subTermHistoryModalContainer');
        const list = document.getElementById('subTermHistoryList');
        
        list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4"><i class="fa-solid fa-spinner fa-spin mr-2"></i>Đang tải lịch sử...</li>';
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => {
            container.classList.remove('scale-95');
            container.classList.add('scale-100');
        }, 10);

        fetch(`/Admin/Subjects?handler=SubjectHistory&subjectId=${id}`)
            .then(res => res.json())
            .then(data => {
                if (data && data.length > 0) {
                    list.innerHTML = data.map(item => {
                        const endAtStr = item.endAt ? item.endAt : '...';
                        const statusClass = item.endAt ? 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400' : 'bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 font-bold';
                        return `
                            <li class="flex items-center justify-between p-3 rounded-xl border border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/30">
                                <div class="flex items-center gap-3">
                                    <span class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-500/20 text-blue-600 dark:text-blue-400 flex items-center justify-center">
                                        <i class="fa-solid fa-user"></i>
                                    </span>
                                    <span class="text-sm font-semibold text-slate-800 dark:text-slate-200">${item.lecturerName}</span>
                                </div>
                                <span class="text-xs px-2.5 py-1 rounded-lg ${statusClass}">
                                    ${item.startAt} - ${endAtStr}
                                </span>
                            </li>
                        `;
                    }).join('');
                } else {
                    list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4">Môn học này chưa từng được gán giảng viên nào quản lý.</li>';
                }
            })
            .catch(err => {
                console.error(err);
                list.innerHTML = '<li class="text-center text-red-500 text-sm py-4">Lỗi tải dữ liệu.</li>';
            });
    }

    function closeSubTermHistoryModal() {
        const modal = document.getElementById('subTermHistoryModal');
        const container = document.getElementById('subTermHistoryModalContainer');
        container.classList.remove('scale-100');
        container.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }, 150);
    }
</script>

<!-- Subject Term History Modal -->
<div id="subTermHistoryModal" class="fixed inset-0 z-50 hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl w-full max-w-lg flex flex-col shadow-2xl transition-all scale-95 duration-200" id="subTermHistoryModalContainer">
        <!-- Header -->
        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-900/50 rounded-t-3xl">
            <div>
                <h3 class="text-lg font-bold text-slate-800 dark:text-slate-100" id="subTermHistoryTitle">Lịch sử Giảng viên</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Danh sách các Giảng viên phụ trách qua từng nhiệm kỳ.</p>
            </div>
            <button onclick="closeSubTermHistoryModal()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <!-- Body -->
        <div class="p-6 overflow-y-auto max-h-[60vh]">
            <ul id="subTermHistoryList" class="space-y-3">
                <li class="text-center text-slate-500 text-sm py-4">Đang tải...</li>
            </ul>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 rounded-b-3xl flex justify-end">
            <button type="button" onclick="closeSubTermHistoryModal()" class="px-5 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors">Đóng</button>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 20px;
    }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #334155;
    }
</style>
