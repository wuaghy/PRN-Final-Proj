@page
@model RagChatbot.PresentationRazorPage.Pages.Document.IndexModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Tài liệu";
    var currentUserIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
    int.TryParse(currentUserIdStr, out int currentUserId);
}

<div class="flex-1 overflow-y-auto bg-slate-50 dark:bg-slate-950 transition-colors duration-200">
    <div class="max-w-6xl mx-auto px-6 py-8 space-y-8">

        <div class="flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-500/10 flex items-center justify-center shadow-sm">
                <i class="fa-solid fa-folder-open text-emerald-600 dark:text-emerald-400"></i>
            </span>
            <div>
                <h1 class="text-xl font-bold text-gray-800 dark:text-slate-100">Quản lý tài liệu</h1>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 font-medium">Upload và quản lý tài liệu học tập</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            @if (User.IsInRole("Lecturer"))
            {
                <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm transition-colors duration-200">
                    <h2 class="text-sm font-bold text-gray-800 dark:text-slate-100 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-cloud-arrow-up text-emerald-500 dark:text-emerald-400 text-xs"></i> Upload tài liệu
                    </h2>
                    <form asp-page-handler="Upload" method="post" enctype="multipart/form-data" class="space-y-3" onsubmit="uploadDocumentAjax(event, this)">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-300 mb-1">Môn học</label>
                            <select name="subjectId" id="subject-select" required
                                    class="w-full bg-white dark:bg-slate-950 border border-slate-300 dark:border-slate-700 rounded-lg px-3 py-2 text-sm text-gray-800 dark:text-slate-100 focus:border-emerald-500 dark:focus:border-emerald-500 focus:ring-1 focus:ring-emerald-200 dark:focus:ring-emerald-500/20 outline-none transition-all">
                                <option value="" disabled selected="@(!Model.ViewModel.LastSelectedSubjectId.HasValue)" class="text-slate-400 dark:text-slate-500">-- Chọn môn học --</option>
                                @if (Model.ViewModel.Subjects != null)
                                {
                                    foreach (var s in Model.ViewModel.Subjects)
                                    {
                                        bool isSelected = Model.ViewModel.LastSelectedSubjectId.HasValue && Model.ViewModel.LastSelectedSubjectId.Value == s.Id;
                                        if (!s.IsActive)
                                        {
                                            <option value="@s.Id" selected="@isSelected" disabled class="text-slate-400 italic">@s.Code - @s.Name (Đang tắt)</option>
                                        }
                                        else
                                        {
                                            <option value="@s.Id" selected="@isSelected">@s.Code - @s.Name</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 dark:text-slate-300 mb-1">File (PDF, DOCX, TXT, XLSX, PPTX)</label>
                            <input type="file" name="files" accept=".pdf,.docx,.txt,.xlsx,.pptx" required id="fileInput"
                                   class="hidden" onchange="updateFileName(this)" multiple />
                            <label for="fileInput"
                                   class="flex items-center gap-3 w-full bg-slate-50 dark:bg-slate-950 border border-slate-300 dark:border-slate-700 border-dashed rounded-lg px-3 py-3 cursor-pointer hover:border-emerald-500 dark:hover:border-emerald-500 hover:bg-emerald-50/50 dark:hover:bg-slate-900 transition-all group">
                                <i class="fa-solid fa-file-arrow-up text-slate-400 dark:text-slate-500 group-hover:text-emerald-500 dark:group-hover:text-emerald-400"></i>
                                <span id="fileNameLabel" class="text-sm font-medium text-slate-500 dark:text-slate-400 group-hover:text-emerald-700 dark:group-hover:text-emerald-400">Nhấn để chọn file...</span>
                            </label>
                        </div>
                        <button type="submit" id="btnUpload"
                                class="w-full bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold py-2 rounded-lg shadow-md shadow-emerald-600/20 transition-all">
                            Upload tài liệu
                        </button>
                    </form>
                </div>
            }
        </div>

        <div id="subject-list-container">
        @if (Model.ViewModel.Subjects != null && Model.ViewModel.Subjects.Any())
        {
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm transition-colors duration-200">
                <div class="px-5 py-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-950/50">
                    <h2 class="text-sm font-bold text-gray-800 dark:text-slate-100 flex items-center gap-2">
                        <i class="fa-solid fa-layer-group text-emerald-500 dark:text-emerald-400 text-xs"></i> Môn học (@Model.ViewModel.Subjects.Count())
                    </h2>
                </div>
                <div class="divide-y divide-slate-100 dark:divide-slate-800">
                    @foreach (var s in Model.ViewModel.Subjects)
                    {
                        <div class="flex items-center gap-4 px-5 py-3 hover:bg-slate-50 dark:hover:bg-slate-800/50 group transition-colors" id="subject-row-@s.Id">
                            <span class="w-8 h-8 rounded-lg bg-emerald-100 dark:bg-slate-800 flex items-center justify-center flex-shrink-0">
                                <i class="fa-solid fa-book text-emerald-600 dark:text-emerald-400 text-xs"></i>
                            </span>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2">
                                    <p class="text-sm font-bold text-slate-700 dark:text-slate-100 subject-name-display truncate">@s.Name</p>
                                    @if (!s.IsActive)
                                    {
                                        <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-rose-100 text-rose-600 dark:bg-rose-500/20 dark:text-rose-400 whitespace-nowrap">Đang tắt</span>
                                    }
                                </div>
                                <p class="text-xs text-slate-500 dark:text-slate-400 font-medium">@s.Code - @s.Documents.Count() tài liệu</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        </div>

        <div id="document-container" class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm transition-colors duration-200">
            <div class="px-5 py-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-950/50 flex items-center justify-between">
                <h2 class="text-sm font-bold text-gray-800 dark:text-slate-100 flex items-center gap-2">
                    <i class="fa-solid fa-file-lines text-emerald-500 dark:text-emerald-400 text-xs"></i> Tài liệu (@Model.ViewModel.Documents.Count())
                </h2>
                @if (User.IsInRole("HeadOfDepartment"))
                {
                    <span class="px-2.5 py-1 rounded bg-blue-500/10 text-blue-500 text-xs font-bold border border-blue-500/20">
                        Chế độ Giám sát & Quản lý Bộ môn
                    </span>
                }
            </div>

            @if (!Model.ViewModel.Documents.Any())
            {
                <div class="px-5 py-12 text-center bg-white dark:bg-slate-900">
                    <i class="fa-solid fa-inbox text-slate-300 dark:text-slate-700 text-4xl mb-3"></i>
                    <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Chưa có tài liệu nào. Hãy upload tài liệu đầu tiên!</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-950/50">
                                <th class="px-5 py-3 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Tên tài liệu</th>
                                <th class="px-5 py-3 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Môn học</th>
                                <th class="px-5 py-3 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Trạng thái</th>
                                <th class="px-5 py-3 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Ngày upload</th>
                                <th class="px-5 py-3 text-right text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="document-list-body" class="divide-y divide-slate-100 dark:divide-slate-800 bg-white dark:bg-slate-900">
                            @foreach (var doc in Model.ViewModel.Documents)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 group transition-colors" id="doc-row-@doc.Id">
                                    <td class="px-5 py-3">
                                        <div class="flex items-center gap-2.5">
                                            @{
                                                string iconClass = "fa-file-lines text-emerald-500";
                                                string lowerFileName = doc.FileName.ToLowerInvariant();
                                                if (lowerFileName.EndsWith(".pdf")) { iconClass = "fa-file-pdf text-red-500"; }
                                                else if (lowerFileName.EndsWith(".docx")) { iconClass = "fa-file-word text-blue-500"; }
                                                else if (lowerFileName.EndsWith(".xlsx") || lowerFileName.EndsWith(".xls")) { iconClass = "fa-file-excel text-emerald-600"; }
                                                else if (lowerFileName.EndsWith(".pptx") || lowerFileName.EndsWith(".ppt")) { iconClass = "fa-file-powerpoint text-orange-500"; }
                                            }
                                            <i class="fa-solid @iconClass text-sm flex-shrink-0"></i>
                                            <div>
                                                <span class="font-medium text-gray-800 dark:text-slate-100 max-w-xs truncate doc-name-display" title="@doc.FileName">@(string.IsNullOrWhiteSpace(doc.DisplayName) ? doc.FileName : doc.DisplayName)</span>
                                                <div class="text-[10px] text-slate-500 dark:text-slate-400 mt-0.5 flex items-center gap-1">
                                                    <i class="fa-solid fa-user-pen opacity-70"></i> Tải lên bởi: <span class="font-semibold text-slate-600 dark:text-slate-300">@doc.UploaderFullName</span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-5 py-3">
                                        <span class="px-2.5 py-1 rounded-md bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 text-xs font-bold border border-emerald-100 dark:border-emerald-500/20">@doc.Subject?.Code</span>
                                    </td>
                                    <td class="px-5 py-3">
                                        <div class="flex flex-col gap-1.5 items-start">
                                            @if (doc.IsActive)
                                            {
                                                <span class="px-2.5 py-1 rounded-full bg-emerald-100 dark:bg-emerald-500/20 text-emerald-800 dark:text-emerald-300 text-xs font-bold border border-emerald-200 dark:border-emerald-500/30">Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="px-2.5 py-1 rounded-full bg-rose-100 dark:bg-rose-500/20 text-rose-800 dark:text-rose-300 text-xs font-bold border border-rose-200 dark:border-rose-500/30">Đã tắt</span>
                                            }

                                            @if (doc.Status == "Indexed")
                                            {
                                                if (doc.DocumentChunks.Count == 0)
                                                {
                                                    <span class="px-2.5 py-1 rounded-full bg-yellow-50 dark:bg-yellow-500/10 text-yellow-700 dark:text-yellow-400 text-xs font-bold border border-yellow-200 dark:border-yellow-500/20" title="PDF bị scan/flatten, không trích xuất được text">⚠️ Indexed (trống)</span>
                                                }
                                                else
                                                {
                                                    <button data-id="@doc.Id" data-filename="@doc.FileName" onclick="viewChunks(this)" class="px-2.5 py-1 rounded-full bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 text-xs font-bold border border-emerald-200 dark:border-emerald-500/20 hover:bg-emerald-100 dark:hover:bg-emerald-500/20 transition-all cursor-pointer">✔️ Indexed - @doc.DocumentChunks.Count chunks</button>
                                                }
                                            }
                                            else if (doc.Status == "Processing")
                                            {
                                                <span class="px-2.5 py-1 rounded-full bg-blue-50 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 text-xs font-bold border border-blue-200 dark:border-blue-500/20 animate-pulse">⚙️ Processing...</span>
                                            }
                                            else if (doc.Status == "Failed")
                                            {
                                                <span class="px-2.5 py-1 rounded-full bg-red-50 dark:bg-red-500/10 text-red-700 dark:text-red-400 text-xs font-bold border border-red-200 dark:border-red-500/20">❌ Failed</span>
                                            }
                                            else
                                            {
                                                <span class="px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 text-xs font-bold border border-slate-200 dark:border-slate-700">⏳ Pending</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-5 py-3 text-slate-500 dark:text-slate-400 text-xs whitespace-nowrap font-medium">
                                        @doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td class="px-5 py-3 text-right">
                                        <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-all">
                                            @{
                                                bool isAdmin = User.IsInRole("Admin");
                                                bool isHod = User.IsInRole("HeadOfDepartment");
                                                bool isLecturer = User.IsInRole("Lecturer");
                                                bool isOwner = doc.UploaderId == currentUserId;
                                            }
                                            @if (isHod || (isLecturer && isOwner))
                                            {
                                                <button data-id="@doc.Id" onclick="toggleDocActive(this)"
                                                        class="px-2 py-1.5 rounded-lg text-xs font-semibold text-slate-400 dark:text-slate-500 hover:text-amber-500 dark:hover:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 border border-transparent transition-all"
                                                        title="@(doc.IsActive ? "Tắt tài liệu" : "Bật tài liệu")">
                                                    <i class="fa-solid @(doc.IsActive ? "fa-toggle-on text-emerald-500" : "fa-toggle-off text-slate-400") text-base"></i>
                                                </button>
                                            }
                                            @if (isLecturer && isOwner)
                                            {
                                                <button data-id="@doc.Id" data-currentname="@(string.IsNullOrWhiteSpace(doc.DisplayName) ? doc.FileName : doc.DisplayName)" onclick="inlineRenameDocument(this)"
                                                        class="px-2 py-1.5 rounded-lg text-xs font-semibold text-slate-400 dark:text-slate-500 hover:text-blue-500 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-500/10 border border-transparent transition-all"
                                                        title="Đổi tên hiển thị">
                                                    <i class="fa-solid fa-pen"></i>
                                                </button>
                                                <button data-id="@doc.Id" data-filename="@doc.FileName" onclick="deleteDocument(this)"
                                                        class="px-2 py-1.5 rounded-lg text-xs font-semibold text-slate-400 dark:text-slate-500 hover:text-red-500 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10 border border-transparent hover:border-red-200 dark:hover:border-red-500/20 transition-all">
                                                    <i class="fa-solid fa-trash text-[10px]"></i>
                                                </button>
                                            }
                                            @if (isAdmin)
                                            {
                                                <button data-id="@doc.Id" data-filename="@doc.FileName" onclick="openReportModal(this)"
                                                        class="px-2 py-1.5 rounded-lg text-xs font-semibold text-slate-400 dark:text-slate-500 hover:text-orange-500 dark:hover:text-orange-400 hover:bg-orange-50 dark:hover:bg-orange-500/10 border border-transparent transition-all"
                                                        title="Báo cáo tài liệu này">
                                                    <i class="fa-solid fa-flag"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div id="chunkModal" class="fixed inset-0 z-50 hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl w-full max-w-4xl max-h-[85vh] flex flex-col shadow-2xl transition-all scale-95 duration-200" id="chunkModalContainer">
        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <div>
                <h3 class="text-base font-bold text-gray-800 dark:text-slate-100" id="chunkModalTitle">Danh sách Chunks</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5" id="chunkModalSubtitle">Tập tin: abc.pdf</p>
            </div>
            <button onclick="closeChunkModal()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        </div>
        <div class="flex-1 overflow-y-auto p-6 space-y-4" id="chunkModalContent">
        </div>
    </div>
</div>

<div id="reportModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 dark:bg-slate-950/80 backdrop-blur-sm">
    <div class="bg-white dark:bg-slate-900 w-full max-w-md mx-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-2xl overflow-hidden">
        <div class="p-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 flex items-center justify-between">
            <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2 text-sm sm:text-base">
                <i class="fa-solid fa-flag text-orange-500"></i> Báo cáo Tài liệu
            </h3>
            <button onclick="closeReportModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
        <div class="p-5 space-y-4 text-left">
            <input type="hidden" id="reportDocId" />
            <p class="text-sm font-semibold text-slate-800 dark:text-slate-200" id="reportDocName"></p>
            <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Lý do báo cáo</label>
                <textarea id="reportReason" rows="4" placeholder="Nhập chi tiết lý do báo cáo để gửi cho Trưởng bộ môn..."
                          class="w-full px-3 py-2 text-sm bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:border-orange-500 text-slate-800 dark:text-slate-100 placeholder-slate-400 resize-none"></textarea>
            </div>
        </div>
        <div class="p-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end gap-2.5 bg-slate-50/50 dark:bg-slate-900/30">
            <button onclick="closeReportModal()" class="px-4 py-2 text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
                Hủy bỏ
            </button>
            <button onclick="submitReport()" id="btnSubmitReport" class="px-4 py-2 text-sm font-semibold text-white bg-orange-600 hover:bg-orange-500 active:bg-orange-700 rounded-lg transition-colors flex items-center gap-2 shadow-md shadow-orange-500/10">
                <i class="fa-solid fa-paper-plane"></i> Gửi Báo Cáo
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>

    <script>
        function updateFileName(input) {
            if (input.files && input.files.length > 1) {
                document.getElementById('fileNameLabel').textContent = `Đã chọn ${input.files.length} tập tin`;
            } else {
                document.getElementById('fileNameLabel').textContent = input.files[0]?.name ?? 'Nhấn để chọn file...';
            }
        }

        function openChunkModal(title, subtitle) {
            document.getElementById('chunkModalTitle').textContent = title;
            document.getElementById('chunkModalSubtitle').textContent = subtitle;
            const modal = document.getElementById('chunkModal');
            modal.classList.remove('hidden');
            setTimeout(() => {
                document.getElementById('chunkModalContainer').classList.remove('scale-95');
                document.getElementById('chunkModalContainer').classList.add('scale-100');
            }, 10);
        }

        function closeChunkModal() {
            document.getElementById('chunkModalContainer').classList.remove('scale-100');
            document.getElementById('chunkModalContainer').classList.add('scale-95');
            setTimeout(() => {
                document.getElementById('chunkModal').classList.add('hidden');
            }, 150);
        }

        // Đọc data từ element nút bấm nhận được
        async function viewChunks(btn) {
            const docId = btn.dataset.id;
            const fileName = btn.dataset.filename;

            const contentDiv = document.getElementById('chunkModalContent');

            contentDiv.className = "overflow-y-auto max-h-[calc(100vh-180px)] space-y-4 pr-2";

            contentDiv.innerHTML = `
                <div class="flex flex-col items-center justify-center py-12">
                    <i class="fa-solid fa-circle-notch fa-spin text-emerald-500 text-3xl mb-3"></i>
                    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Đang tải danh sách chunks...</p>
                </div>
            `;
            openChunkModal('Xem nội dung Chunks', `Tài liệu: ${fileName}`);

            try {
                const res = await fetch(`?handler=DocumentChunks&id=${docId}`);
                const data = await res.json();

                if (data.success && data.chunks.length > 0) {
                    contentDiv.innerHTML = '';
                    data.chunks.forEach((chunk, index) => {
                        const pageLabel = chunk.pageNumber ? `Trang ${chunk.pageNumber}` : 'N/A';
                        const chunkCard = document.createElement('div');
                        chunkCard.className = 'bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800/80 rounded-2xl p-5 relative overflow-hidden transition-all hover:border-emerald-500/50 dark:hover:border-emerald-500/30';
                        chunkCard.innerHTML = `
                            <div class="flex items-center justify-between mb-2">
                                <span class="px-2 py-0.5 rounded bg-emerald-100 dark:bg-emerald-950 text-emerald-700 dark:text-emerald-400 text-[10px] font-bold border border-emerald-200 dark:border-emerald-900/30">Chunk #${index + 1}</span>
                                <span class="text-xs font-semibold text-slate-500 dark:text-slate-400"><i class="fa-regular fa-file mr-1"></i>${pageLabel}</span>
                            </div>
                            <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed font-medium whitespace-pre-wrap">${escapeHtml(chunk.content)}</p>
                        `;
                        contentDiv.appendChild(chunkCard);
                    });
                } else {
                    contentDiv.innerHTML = `
                        <div class="flex flex-col items-center justify-center py-12">
                            <i class="fa-solid fa-inbox text-slate-300 dark:text-slate-700 text-4xl mb-3"></i>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Không tìm thấy chunks nào cho tài liệu này.</p>
                        </div>
                    `;
                }
            } catch (err) {
                contentDiv.innerHTML = `
                    <div class="flex flex-col items-center justify-center py-12 text-red-500">
                        <i class="fa-solid fa-circle-exclamation text-3xl mb-3"></i>
                        <p class="text-sm font-medium">Lỗi kết nối máy chủ: ${err.message}</p>
                    </div>
                `;
            }
        }

        function escapeHtml(text) {
            const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        function deleteDocument(btn) {
            const id = btn.dataset.id;
            const fileName = btn.dataset.filename;

            const executeDelete = async () => {
                const res = await fetch('/Document/Index?handler=DeleteDocument', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: `id=${id}`
                });
                const data = await res.json();
                if (data.success) document.getElementById(`doc-row-${id}`)?.remove();
            };

            // Cơ chế kiểm tra an toàn nếu bạn chưa tạo custom confirm modal giao diện
            if (typeof showConfirmModal === 'function') {
                showConfirmModal('Xóa tài liệu', `Xóa "${fileName}" và toàn bộ vector chunks?`, executeDelete);
            } else {
                if (confirm(`Bạn chắc chắn muốn xóa "${fileName}" và toàn bộ vector chunks?`)) {
                    executeDelete();
                }
            }
        }

        function inlineRenameDocument(btn) {
            const id = btn.dataset.id;
            const currentName = btn.dataset.currentname;

            const row = document.getElementById(`doc-row-${id}`);
            const display = row.querySelector('.doc-name-display');
            const input = document.createElement('input');
            input.type = 'text';
            input.value = currentName;
            input.className = 'bg-white dark:bg-slate-950 border border-blue-500 dark:border-blue-500 rounded px-2 py-0.5 text-sm text-gray-800 dark:text-slate-100 outline-none w-48 shadow-sm focus:ring-1 focus:ring-blue-200 dark:focus:ring-blue-500/20';
            display.replaceWith(input);
            input.focus(); input.select();

            const save = async () => {
                const newName = input.value.trim();
                const span = document.createElement('span');
                span.className = 'font-medium text-gray-800 dark:text-slate-100 max-w-xs truncate doc-name-display';
                if (!newName || newName === currentName) { span.textContent = currentName; input.replaceWith(span); return; }
                const res = await fetch('/Document/Index?handler=RenameDocument', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: `id=${id}&displayName=${encodeURIComponent(newName)}`
                });
                const data = await res.json();
                span.textContent = data.success ? data.displayName : currentName;
                input.replaceWith(span);
                if (data.success) window.location.reload();
            };
            input.addEventListener('blur', save);
            input.addEventListener('keydown', e => {
                if (e.key === 'Enter') { e.preventDefault(); input.blur(); }
                if (e.key === 'Escape') {
                    const s = document.createElement('span');
                    s.className = 'font-medium text-gray-800 dark:text-slate-100 max-w-xs truncate doc-name-display';
                    s.textContent = currentName;
                    input.replaceWith(s);
                }
            });
        }

        async function toggleDocActive(btn) {
            const id = btn.dataset.id;
            const res = await fetch('/Document/Index?handler=ToggleDocumentActive', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: `id=${id}`
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.message || 'Lỗi hệ thống');
            }
        }

        function openReportModal(btn) {
            document.getElementById('reportDocId').value = btn.dataset.id;
            document.getElementById('reportDocName').textContent = "Tài liệu: " + btn.dataset.filename;
            document.getElementById('reportReason').value = "";
            const modal = document.getElementById("reportModal");
            modal.classList.remove("hidden");
            modal.classList.add("flex");
        }

        function closeReportModal() {
            const modal = document.getElementById("reportModal");
            modal.classList.add("hidden");
            modal.classList.remove("flex");
        }

        async function submitReport() {
            const id = document.getElementById('reportDocId').value;
            const reason = document.getElementById('reportReason').value.trim();
            const btnSubmit = document.getElementById('btnSubmitReport');

            if (!reason) {
                alert("Vui lòng nhập lý do báo cáo.");
                return;
            }

            btnSubmit.disabled = true;
            btnSubmit.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Đang gửi...`;

            try {
                const res = await fetch('/Document/Index?handler=ReportDocument', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: `id=${id}&reason=${encodeURIComponent(reason)}`
                });
                const data = await res.json();
                if (data.success) {
                    showToast('success', 'Báo cáo thành công! Đã gửi email cảnh báo đến Trưởng bộ môn.');
                    closeReportModal();
                } else {
                    showToast('error', data.message || 'Có lỗi xảy ra.');
                }
            } catch (err) {
                console.error(err);
                showToast('error', 'Có lỗi xảy ra trong quá trình báo cáo.');
            } finally {
                btnSubmit.disabled = false;
                btnSubmit.innerHTML = `<i class="fa-solid fa-paper-plane"></i> Gửi Báo Cáo`;
            }
        }

        function showToast(type, message) {
            let container = document.getElementById('toast-container');
            if (!container) {
                container = document.createElement('div');
                container.id = 'toast-container';
                container.className = 'fixed bottom-6 right-6 z-[9999] flex flex-col gap-3 pointer-events-none';
                document.body.appendChild(container);
            }
            
            const isError = type === 'error';
            const iconColor = isError ? 'red' : 'emerald';
            const title = isError ? 'Lỗi' : 'Thành công';
            const icon = isError ? 'fa-exclamation' : 'fa-check';
            
            const toastHtml = `
                <div class="toast-item pointer-events-auto flex items-start gap-3 p-4 bg-white dark:bg-slate-800 border border-${iconColor}-200 dark:border-${iconColor}-500/20 shadow-xl rounded-xl min-w-[300px]" style="animation: slideInRight 0.3s ease-out forwards;">
                    <div class="w-8 h-8 rounded-full bg-${iconColor}-100 dark:bg-${iconColor}-500/20 flex items-center justify-center shrink-0">
                        <i class="fa-solid ${icon} text-${iconColor}-600 dark:text-${iconColor}-400"></i>
                    </div>
                    <div class="flex-1 pt-1.5">
                        <h4 class="text-sm font-bold text-gray-900 dark:text-white">${title}</h4>
                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">${message}</p>
                    </div>
                    <button onclick="this.closest('.toast-item').remove()" class="text-slate-400 hover:text-slate-600 transition-colors pt-1">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            `;
            
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = toastHtml.trim();
            const toast = tempDiv.firstElementChild;
            container.appendChild(toast);
            
            if (!document.getElementById('toast-styles')) {
                const style = document.createElement('style');
                style.id = 'toast-styles';
                style.innerHTML = `
                    @@keyframes slideInRight { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
                    @@keyframes fadeOutToast { from { opacity: 1; transform: scale(1); } to { opacity: 0; transform: scale(0.9); } }
                `;
                document.head.appendChild(style);
            }
            
            setTimeout(() => {
                toast.style.animation = 'fadeOutToast 0.3s ease-out forwards';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        async function uploadDocumentAjax(e, form) {
            e.preventDefault();
            const btn = document.getElementById('btnUpload');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang tải lên...';
            btn.disabled = true;

            try {
                const formData = new FormData(form);
                const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const res = await fetch('/Document/Index?handler=Upload', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        ...(token ? { 'RequestVerificationToken': token } : {})
                    },
                    body: formData
                });
                const data = await res.json();

                if (data.success) {
                    form.reset();
                    document.getElementById('fileNameLabel').textContent = 'Nhấn để chọn file...';
                    console.log("✈️ Upload thành công! Đang chờ SignalR đẩy dữ liệu mới về...");
                    showToast('success', 'Tải tài liệu lên thành công!');
                } else {
                    showToast('error', data.message);
                }
            } catch (err) {
                console.error(err);
                showToast('error', 'Có lỗi xảy ra trong quá trình tải tài liệu lên!');
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        // Khởi tạo SignalR Realtime Hub
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/appNotificationHub")
            .withAutomaticReconnect()
            .build();

        async function softReloadPage() {
            console.log("🔔 SignalR: Nhận thông báo cập nhật dữ liệu!");
            try {
                const url = new URL(window.location.href);
                url.searchParams.set('_t', new Date().getTime());
                const res = await fetch(url.toString(), { cache: "no-store" });
                const html = await res.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, "text/html");

                let hasUpdated = false;

                // Update documents
                const currentDoc = document.getElementById('document-container');
                const newDoc = doc.getElementById('document-container');
                if (currentDoc && newDoc) {
                    currentDoc.innerHTML = newDoc.innerHTML;
                    hasUpdated = true;
                }

                // Update subject list
                const currentSubList = document.getElementById('subject-list-container');
                const newSubList = doc.getElementById('subject-list-container');
                if (currentSubList && newSubList) {
                    currentSubList.innerHTML = newSubList.innerHTML;
                    hasUpdated = true;
                }

                // Update subject dropdown
                const currentSelect = document.getElementById('subject-select');
                const newSelect = doc.getElementById('subject-select');
                if (currentSelect && newSelect) {
                    const selectedVal = currentSelect.value;
                    currentSelect.innerHTML = newSelect.innerHTML;
                    if (selectedVal) currentSelect.value = selectedVal; // restore selection
                    hasUpdated = true;
                }

                if (hasUpdated) {
                    console.log("✅ Đồng bộ hóa danh sách ngầm thành công!");
                } else {
                    window.location.reload();
                }
            } catch (err) {
                console.error("Lỗi cập nhật DOM, kích hoạt cơ chế F5 dự phòng:", err);
                window.location.reload();
            }
        }

        connection.on("DocumentListChanged", softReloadPage);
        connection.on("SubjectListChanged", softReloadPage);

        connection.start()
            .then(() => console.log("🚀 Đồng bộ thời gian thực (SignalR) hoạt động bình thường!"))
            .catch(err => console.error("❌ SignalR Hub lỗi kết nối: ", err.toString()));
    </script>
}