@page
@model RagChatbot.PresentationRazorPage.Pages.Hod.IndexModel
@{
    ViewData["Title"] = "Môn học của tôi";
}

<div class="max-w-6xl mx-auto p-4 sm:p-6 lg:p-8 transition-colors duration-200">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center">
                <i class="fa-solid fa-book"></i>
            </span>
            Môn học bộ môn
        </h1>
    </div>

    <form id="assignment-form" method="post" asp-page-handler="AssignLecturers" onsubmit="return confirmBatchAssignments(this, event);">
    <div id="subject-container" class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-800/60 bg-slate-50/50 dark:bg-slate-900/50 flex items-center justify-between">
            <h3 class="text-base font-bold text-gray-900 dark:text-white flex items-center gap-2">
                <i class="fa-solid fa-layer-group text-emerald-500 dark:text-emerald-400"></i>
                Danh sách Môn học
            </h3>
            <span class="bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 text-xs font-bold px-2.5 py-1 rounded-full">
                @Model.Subjects.Count() môn học
            </span>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm text-slate-600 dark:text-slate-300">
                <thead class="bg-slate-50 dark:bg-slate-950/50 text-xs uppercase font-semibold text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-slate-800">
                    <tr>
                        <th scope="col" class="px-6 py-4">Mã Môn</th>
                        <th scope="col" class="px-6 py-4">Tên Môn học</th>
                        <th scope="col" class="px-6 py-4">Giảng viên phụ trách</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800/60" id="subject-list">
                    @if (!Model.Subjects.Any())
                    {
                        <tr>
                            <td colspan="3" class="px-6 py-12 text-center text-slate-500">Chưa có môn học nào thuộc quản lý của bạn.</td>
                        </tr>
                    }
                    else
                    {
                        var subjectList = Model.Subjects.ToList();
                        for (var index = 0; index < subjectList.Count; index++)
                        {
                            var subject = subjectList[index];
                            <tr data-assignment-row class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
                                 <td class="px-6 py-4 font-mono text-xs font-bold text-slate-500 dark:text-slate-400">@subject.Code</td>
                                 <td class="px-6 py-4 font-bold text-gray-900 dark:text-slate-100">
                                     <a href="javascript:void(0)" onclick="openSubjectHistoryModal(@subject.Id, '@subject.Name.Replace("'", "\\'")')" class="hover:text-blue-500 transition-colors cursor-pointer decoration-blue-500/30 underline-offset-4 hover:underline">@subject.Name</a>
                                 </td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <input type="hidden" name="assignments[@index].SubjectId" value="@subject.Id" />
                                        <input type="hidden" name="assignments[@index].OriginalLecturerId" value="@subject.LecturerId" />
                                        <label for="assignment-lecturer-@index" class="sr-only">Giảng viên phụ trách môn @subject.Code</label>
                                        <select id="assignment-lecturer-@index"
                                                name="assignments[@index].LecturerId"
                                                data-assignment-select
                                                data-original-lecturer-id="@subject.LecturerId"
                                                onchange="updateAssignmentRow(this)"
                                                class="text-sm rounded-lg border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 px-2 py-1.5 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
                                            <option value="">— Chưa gán —</option>
                                            @foreach (var lecturer in Model.Lecturers)
                                            {
                                                var name = $"{lecturer.LastName} {lecturer.FirstName}".Trim();
                                                if (subject.LecturerId == lecturer.Id)
                                                {
                                                    <option value="@lecturer.Id" selected>@name</option>
                                                }
                                                else
                                                {
                                                    <option value="@lecturer.Id">@name</option>
                                                }
                                            }
                                        </select>
                                        <div data-document-cleanup-option class="hidden basis-full mt-2 rounded-xl border border-amber-200 bg-amber-50 p-3 dark:border-amber-500/30 dark:bg-amber-500/10">
                                            <label class="flex cursor-pointer items-start gap-3 text-sm text-amber-900 dark:text-amber-100">
                                                <input type="checkbox" name="assignments[@index].RemoveCurrentSubjectDocuments" value="true"
                                                       class="mt-0.5 size-4 rounded border-amber-400 text-amber-600 focus:ring-amber-500" />
                                                <span>
                                                    <span class="block font-semibold">Xóa toàn bộ tài liệu hiện tại của môn</span>
                                                    <span class="mt-1 block text-xs text-pretty text-amber-700 dark:text-amber-300">Xóa tất cả tài liệu của môn này, không phân biệt người tải lên. Thao tác không thể hoàn tác ở mức dữ liệu.</span>
                                                </span>
                                            </label>
                                        </div>
                                     </div>
                                 </td>
                             </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Subjects.Any())
        {
            <div class="flex flex-col gap-3 border-t border-slate-200 bg-slate-50/70 px-6 py-4 dark:border-slate-800 dark:bg-slate-950/30 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <p id="assignment-change-summary" class="text-sm font-medium text-slate-700 dark:text-slate-200">Chưa có thay đổi nào.</p>
                    <p data-external-change-notice class="mt-1 hidden text-xs text-amber-700 dark:text-amber-300">Danh sách môn học vừa thay đổi ở nơi khác. Hãy tải lại trang trước khi tiếp tục.</p>
                </div>
                <button id="save-assignments-button" type="submit" disabled
                        class="inline-flex min-h-10 items-center justify-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 dark:focus:ring-offset-slate-900">
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                    Lưu phân công
                </button>
            </div>
        }
    </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        let assignmentFormDirty = false;

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/appNotificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("SubjectListChanged", async function () {
            try {
                if (assignmentFormDirty) {
                    document.querySelector('[data-external-change-notice]')?.classList.remove('hidden');
                    return;
                }

                const url = new URL(window.location.href);
                url.searchParams.set('_t', new Date().getTime());
                const res = await fetch(url.toString(), { cache: "no-store" });
                const html = await res.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, "text/html");

                const currentContainer = document.getElementById('subject-container');
                const newContainer = doc.getElementById('subject-container');
                if (currentContainer && newContainer) {
                    currentContainer.innerHTML = newContainer.innerHTML;
                    initializeAssignmentForm();
                }
            } catch (err) {
                console.error("Error fetching subject data:", err);
            }
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });

        function getChangedAssignmentSelects() {
            return Array.from(document.querySelectorAll('[data-assignment-select]'))
                .filter(select => select.value !== (select.dataset.originalLecturerId || ''));
        }

        function updateAssignmentRow(select) {
            const row = select.closest('[data-assignment-row]');
            const option = row?.querySelector('[data-document-cleanup-option]');
            const checkbox = option?.querySelector('input[type="checkbox"]');
            const originalLecturerId = select.dataset.originalLecturerId || '';
            const isChanged = select.value !== originalLecturerId;
            const isReassignment = Boolean(select.value) && Boolean(originalLecturerId) && isChanged;

            option?.classList.toggle('hidden', !isReassignment);
            if (!isReassignment && checkbox) checkbox.checked = false;
            row?.classList.toggle('bg-emerald-50', isChanged);
            row?.classList.toggle('dark:bg-emerald-500/5', isChanged);
            refreshAssignmentSummary();
        }

        function refreshAssignmentSummary() {
            const changedCount = getChangedAssignmentSelects().length;
            const summary = document.getElementById('assignment-change-summary');
            const button = document.getElementById('save-assignments-button');
            assignmentFormDirty = changedCount > 0;

            if (summary) {
                summary.textContent = changedCount > 0
                    ? `${changedCount} môn học đang chờ lưu.`
                    : 'Chưa có thay đổi nào.';
            }
            if (button) button.disabled = changedCount === 0;
        }

        function initializeAssignmentForm() {
            document.querySelectorAll('[data-assignment-select]').forEach(select => {
                const option = select.closest('[data-assignment-row]')?.querySelector('[data-document-cleanup-option]');
                option?.classList.add('hidden');
            });
            assignmentFormDirty = false;
            refreshAssignmentSummary();
        }

        function confirmBatchAssignments(form, event) {
            if (form.dataset.confirmed === 'true') {
                delete form.dataset.confirmed;
                document.getElementById('save-assignments-button')?.setAttribute('disabled', 'disabled');
                return true;
            }

            const changedSelects = getChangedAssignmentSelects();
            if (changedSelects.length === 0) {
                event.preventDefault();
                refreshAssignmentSummary();
                return false;
            }

            const assignedCount = changedSelects.filter(select => !select.dataset.originalLecturerId && select.value).length;
            const reassignedCount = changedSelects.filter(select => select.dataset.originalLecturerId && select.value).length;
            const unassignedCount = changedSelects.filter(select => select.dataset.originalLecturerId && !select.value).length;
            const cleanupCount = changedSelects.filter(select => {
                const option = select.closest('[data-assignment-row]')?.querySelector('[data-document-cleanup-option]');
                return option && !option.classList.contains('hidden') && option.querySelector('input[type="checkbox"]')?.checked;
            }).length;
            const hasSensitiveChanges = reassignedCount > 0 || unassignedCount > 0 || cleanupCount > 0;
            const message = `Bạn sắp lưu ${changedSelects.length} thay đổi: ${assignedCount} gán mới, ${reassignedCount} chuyển giảng viên, ${unassignedCount} gỡ phân công.`
                + (cleanupCount > 0
                    ? ` ${cleanupCount} môn sẽ bị xóa toàn bộ tài liệu hiện tại. Thao tác xóa không thể hoàn tác.`
                    : ' Các tài liệu hiện tại sẽ được giữ nguyên.');
            const submitBatch = () => {
                form.dataset.confirmed = 'true';
                form.requestSubmit();
            };

            event.preventDefault();
            if (typeof showConfirmModal === 'function') {
                showConfirmModal(
                    'Xác nhận lưu phân công',
                    message,
                    submitBatch,
                    'Lưu phân công',
                    hasSensitiveChanges
                );
            } else if (confirm(message)) {
                submitBatch();
            }
            return false;
        }

        initializeAssignmentForm();

        function openSubjectHistoryModal(id, name) {
            document.getElementById('subTermHistoryTitle').innerText = 'Nhiệm kỳ môn: ' + name;
            const modal = document.getElementById('subTermHistoryModal');
            const container = document.getElementById('subTermHistoryModalContainer');
            const list = document.getElementById('subTermHistoryList');
            
            list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4"><i class="fa-solid fa-spinner fa-spin mr-2"></i>Đang tải lịch sử...</li>';
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                container.classList.remove('scale-95');
                container.classList.add('scale-100');
            }, 10);

            fetch(`/Hod/Index?handler=SubjectHistory&subjectId=${id}`)
                .then(res => res.json())
                .then(data => {
                    if (data && data.length > 0) {
                        list.innerHTML = data.map(item => {
                            const endAtStr = item.endAt ? item.endAt : '...';
                            const statusClass = item.endAt ? 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400' : 'bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 font-bold';
                            return `
                                <li class="flex items-center justify-between p-3 rounded-xl border border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/30">
                                    <div class="flex items-center gap-3">
                                        <span class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-500/20 text-blue-600 dark:text-blue-400 flex items-center justify-center">
                                            <i class="fa-solid fa-user"></i>
                                        </span>
                                        <span class="text-sm font-semibold text-slate-800 dark:text-slate-200">${item.lecturerName}</span>
                                    </div>
                                    <span class="text-xs px-2.5 py-1 rounded-lg ${statusClass}">
                                        ${item.startAt} - ${endAtStr}
                                    </span>
                                </li>
                            `;
                        }).join('');
                    } else {
                        list.innerHTML = '<li class="text-center text-slate-500 text-sm py-4">Môn học này chưa từng được gán giảng viên nào quản lý.</li>';
                    }
                })
                .catch(err => {
                    console.error(err);
                    list.innerHTML = '<li class="text-center text-red-500 text-sm py-4">Lỗi tải dữ liệu.</li>';
                });
        }

        function closeSubTermHistoryModal() {
            const modal = document.getElementById('subTermHistoryModal');
            const container = document.getElementById('subTermHistoryModalContainer');
            container.classList.remove('scale-100');
            container.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 150);
        }
    </script>
}

<!-- Subject Term History Modal -->
<div id="subTermHistoryModal" class="fixed inset-0 z-50 hidden bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl w-full max-w-lg flex flex-col shadow-2xl transition-all scale-95 duration-200" id="subTermHistoryModalContainer">
        <!-- Header -->
        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-900/50 rounded-t-3xl">
            <div>
                <h3 class="text-lg font-bold text-slate-800 dark:text-slate-100" id="subTermHistoryTitle">Lịch sử Giảng viên</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Danh sách các Giảng viên phụ trách qua từng nhiệm kỳ.</p>
            </div>
            <button onclick="closeSubTermHistoryModal()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <!-- Body -->
        <div class="p-6 overflow-y-auto max-h-[60vh]">
            <ul id="subTermHistoryList" class="space-y-3">
                <li class="text-center text-slate-500 text-sm py-4">Đang tải...</li>
            </ul>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 rounded-b-3xl flex justify-end">
            <button type="button" onclick="closeSubTermHistoryModal()" class="px-5 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors">Đóng</button>
        </div>
    </div>
</div>
