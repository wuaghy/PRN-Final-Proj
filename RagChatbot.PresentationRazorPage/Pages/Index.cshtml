@page
@model RagChatbot.PresentationRazorPage.Pages.IndexModel
@{
    ViewData["Title"] = "Chat";
}

<div class="flex h-[calc(100vh-3.5rem)] overflow-hidden">

    <!-- ── SIDEBAR TRÁI: Topics ─────────────────────────────── -->
    <aside class="w-60 flex-shrink-0 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col shadow-[2px_0_10px_rgba(0,0,0,0.02)] z-10 transition-colors duration-200">
        <div class="px-4 pt-4 pb-3 border-b border-slate-100 dark:border-slate-800">
            <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Môn học</p>
        </div>

        <div class="flex-1 overflow-y-auto py-2 px-2 space-y-2">
            @{
                var groupedSubjects = Model.ViewModel.Subjects
                    .GroupBy(s => string.IsNullOrEmpty(s.DepartmentName) ? "Chưa phân bộ môn" : s.DepartmentName)
                    .OrderBy(g => g.Key == "Chưa phân bộ môn" ? 1 : 0)
                    .ThenBy(g => g.Key);
            }
            @foreach (var group in groupedSubjects)
            {
                <div class="department-group">
                    <button type="button" onclick="toggleDepartment(this)" class="flex items-center justify-between w-full px-2 py-1.5 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider hover:bg-slate-100 dark:hover:bg-slate-800 rounded transition-colors">
                        <div class="flex items-center gap-1.5">
                            <i class="fa-solid fa-layer-group text-slate-400"></i>
                            <span class="truncate">@group.Key</span>
                        </div>
                        <i class="fa-solid fa-chevron-down text-[10px] transition-transform duration-200 -rotate-90"></i>
                    </button>
                    <div class="department-subjects mt-1 space-y-0.5 hidden">
                        @foreach (var subject in group)
                        {
                            <div class="topic-item group flex items-center gap-2 px-2 py-2 rounded-lg cursor-pointer"
                                 data-id="@subject.Id" data-name="@subject.Name"
                                 onclick="selectSubject(@subject.Id, '@subject.Name.Replace("'", "\\'")', this)">
                                <span class="w-7 h-7 rounded-md bg-emerald-100 dark:bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
                                    <i class="fa-solid fa-book-open text-emerald-600 dark:text-emerald-400 text-xs"></i>
                                </span>
                                <span class="flex-1 text-sm font-medium text-slate-700 dark:text-slate-200 truncate topic-name group-hover:text-emerald-700 dark:group-hover:text-emerald-400">@subject.Name</span>
                                <!-- Action buttons -->
                                @if (User.IsInRole("Admin"))
                                {
                                    <span class="hidden group-hover:flex items-center gap-1 flex-shrink-0">
                                        <button onclick="event.stopPropagation(); renameSubject(@subject.Id, this)"
                                            class="w-6 h-6 rounded flex items-center justify-center text-slate-400 dark:text-slate-500 hover:text-emerald-600 dark:hover:text-emerald-300 hover:bg-emerald-50 dark:hover:bg-emerald-500/10"
                                            title="Đổi tên">
                                            <i class="fa-solid fa-pen text-[10px]"></i>
                                        </button>
                                        <button onclick="event.stopPropagation(); deleteSubject(@subject.Id, '@subject.Name.Replace("'", "\\'")')"
                                            class="w-6 h-6 rounded flex items-center justify-center text-slate-400 dark:text-slate-500 hover:text-red-500 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10"
                                            title="Xóa">
                                            <i class="fa-solid fa-trash text-[10px]"></i>
                                        </button>
                                    </span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Connection status -->
        <div class="px-3 py-3 border-t border-slate-100 dark:border-slate-800 flex items-center gap-2 bg-slate-50/50 dark:bg-slate-950/50">
            <span id="statusDot" class="w-2 h-2 rounded-full bg-red-500 flex-shrink-0 shadow-sm"></span>
            <span id="statusText" class="text-xs font-medium text-slate-500 dark:text-slate-400">Disconnected</span>
        </div>
    </aside>

    <!-- ── CHAT AREA ──────────────────────────────────────────── -->
    <div class="flex-1 flex flex-col min-w-0 bg-slate-50 dark:bg-slate-950 transition-colors duration-200">
        <!-- Chat header -->
        <div class="flex items-center justify-between px-5 py-3 border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm flex-shrink-0 z-10 transition-colors duration-200">
            <div>
                <h2 id="chatTitle" class="text-sm font-bold text-gray-800 dark:text-slate-100">Chọn môn học để bắt đầu</h2>
                <p id="chatSubtitle" class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">RAG Chatbot Workspace</p>
            </div>
        </div>

        <!-- Messages -->
        <div id="chatMessages" class="flex-1 overflow-y-auto px-5 py-4 space-y-5">
            <div class="flex justify-center">
                <span class="px-4 py-1.5 rounded-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-600 dark:text-slate-300 shadow-sm">
                    Chọn môn học từ sidebar để bắt đầu chat
                </span>
            </div>
        </div>

        <!-- Input -->
        <div class="px-4 py-4 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 shadow-[0_-2px_10px_rgba(0,0,0,0.02)] flex-shrink-0 transition-colors duration-200 relative">

            @if (User.IsInRole("Học sinh") || User.IsInRole("Student"))
            {
                <div id="stopGenerationContainer" class="absolute left-1/2 -top-12 -translate-x-1/2 hidden z-20">
                    <button onclick="stopGeneration()" class="flex items-center gap-2 px-4 py-1.5 bg-slate-800 hover:bg-slate-700 text-slate-100 text-xs font-semibold rounded-full shadow-lg border border-slate-700 transition-all">
                        <i class="fa-solid fa-stop text-[10px] text-red-400"></i> Dừng tạo
                    </button>
                </div>

                <form id="chatForm" class="flex items-end gap-3 max-w-4xl mx-auto">
                    <input type="hidden" id="currentSubjectId" />
                    <input type="hidden" id="currentSessionId" />
                    <div class="flex-1 bg-white dark:bg-slate-950 rounded-xl border border-slate-300 dark:border-slate-700 shadow-sm focus-within:border-emerald-500 focus-within:ring-2 focus-within:ring-emerald-100 dark:focus-within:border-emerald-500 dark:focus-within:ring-emerald-500/20 transition-all">
                        <textarea id="messageInput" rows="1"
                              class="w-full bg-transparent border-0 focus:ring-0 resize-none px-4 py-3 text-sm text-gray-800 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 block"
                              placeholder="Chọn môn học trước..." disabled></textarea>
                    </div>
                    <button type="submit" id="sendBtn"
                            class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500 to-green-600 hover:from-emerald-600 hover:to-green-700 text-white flex items-center justify-center flex-shrink-0 disabled:opacity-50 disabled:from-slate-300 disabled:to-slate-400 dark:disabled:from-slate-700 dark:disabled:to-slate-800 shadow-md shadow-emerald-500/20 transition-all"
                            disabled>
                        <i class="fa-solid fa-paper-plane text-sm"></i>
                    </button>
                </form>
            }
            else
            {
                <div class="max-w-4xl mx-auto text-center py-3 px-5 text-sm font-medium text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-900/30 rounded-xl flex items-center justify-center gap-2 shadow-sm animate-fade-in">
                    <i class="fa-solid fa-circle-info text-base text-amber-500"></i>
                    <span>Tài khoản của bạn thuộc vai trò Quản trị/Giảng viên. Tính năng tương tác trực tiếp với Trợ lý AI chỉ dành riêng cho tài khoản <strong>Học sinh</strong>.</span>
                </div>

                <div class="hidden">
                    <div id="stopGenerationContainer"></div>
                    <form id="chatForm">
                        <input type="hidden" id="currentSubjectId" />
                        <input type="hidden" id="currentSessionId" />
                        <textarea id="messageInput"></textarea>
                        <button type="submit" id="sendBtn"></button>
                    </form>
                </div>
            }
        </div>
    </div>

</div>

@section Scripts {
<script>
let currentSubjectId = null;
let currentSessionId = "";
let isReceivingStream = false;
let currentAssistantMessageDiv = null;
let currentAssistantMarkdown = "";
let isAiThinking = false;

// ── SignalR ──────────────────────────────────────────────────
const connection = new signalR.HubConnectionBuilder()
    .withUrl("/chatHub")
    .configureLogging(signalR.LogLevel.Warning)
    .build();

async function startConnection() {
    try {
        if (connection.state === signalR.HubConnectionState.Connected) return;
        await connection.start();
        updateStatus(true);
        if (currentSubjectId) connection.invoke("LoadSubjectHistory", currentSubjectId).catch(console.error);
    } catch (err) {
        console.error(err);
        setTimeout(startConnection, 5000);
    }
}

connection.onclose(async () => { updateStatus(false); await startConnection(); });

function updateStatus(connected) {
    document.getElementById("statusDot").className = `w-2 h-2 rounded-full flex-shrink-0 ${connected ? 'bg-emerald-500' : 'bg-red-500'}`;
    document.getElementById("statusText").textContent = connected ? "Connected" : "Disconnected";
}

startConnection();

// ── Select Subject ───────────────────────────────────────────
function toggleDepartment(btn) {
    const icon = btn.querySelector('.fa-chevron-down');
    const content = btn.nextElementSibling;
    icon.classList.toggle('-rotate-90');
    content.classList.toggle('hidden');
}

function selectSubject(id, name, el) {
    currentSubjectId = id;
    currentSessionId = "";

    // Sidebar highlight
    document.querySelectorAll('.topic-item').forEach(t => t.classList.remove('active'));
    el.classList.add('active');

    document.getElementById("chatTitle").textContent = name;
    document.getElementById("chatSubtitle").textContent = "Đang tải lịch sử...";
    document.getElementById("messageInput").disabled = false;
    document.getElementById("messageInput").placeholder = "Hỏi về " + name + "...";
    document.getElementById("sendBtn").disabled = false;
    document.getElementById("messageInput").focus();

    document.getElementById("chatMessages").innerHTML = `
        <div class="flex justify-center">
            <span class="px-4 py-1.5 rounded-full bg-surface-700 text-xs text-slate-400 animate-pulse">Đang tải lịch sử...</span>
        </div>`;

    if (connection.state === signalR.HubConnectionState.Connected)
        connection.invoke("LoadSubjectHistory", id).catch(console.error);
}

// ── SignalR ChatHub Callbacks ────────────────────────────────
connection.on("SessionCreated", id => { currentSessionId = id; });

connection.on("SessionLoaded", (sessionId, messages) => {
    currentSessionId = sessionId;
    const container = document.getElementById("chatMessages");
    container.innerHTML = "";

    document.getElementById("chatSubtitle").textContent =
        messages && messages.length > 0 ? `${messages.length} tin nhắn` : "Phiên chat mới";

    if (!messages || messages.length === 0) {
        container.innerHTML = `<div class="flex justify-center"><span class="px-4 py-1.5 rounded-full bg-surface-700 text-xs text-slate-400">Bắt đầu phiên chat mới ✨</span></div>`;
        return;
    }

    messages.forEach(msg => appendMessage(msg.role, msg.content, msg.citations));
    container.scrollTop = container.scrollHeight;
});

connection.on("ReceiveToken", (token, isEnd) => {
    const container = document.getElementById("chatMessages");

    if (!isReceivingStream && !isEnd && token === "") {
        removeThinkingIndicator();
        isReceivingStream = true;
        currentAssistantMarkdown = "";
        if (!currentAssistantMessageDiv) createAiBubble();
        currentAssistantMessageDiv.innerHTML = '<span class="text-brand-400 animate-pulse font-bold text-lg">▍</span>';
        container.scrollTop = container.scrollHeight;
    } else if (isReceivingStream && !isEnd) {
        currentAssistantMarkdown += token;
        currentAssistantMessageDiv.innerHTML = marked.parse(currentAssistantMarkdown) +
            '<span class="text-brand-400 animate-pulse font-bold text-lg inline-block ml-1">▍</span>';
        container.scrollTop = container.scrollHeight;
    } else if (isEnd) {
        isReceivingStream = false;
        if (currentAssistantMessageDiv) {
            let citationsJson = token;
            try {
                if (token && token.trim().startsWith("{")) {
                    const parsed = JSON.parse(token);
                    if (parsed && typeof parsed === "object" && !Array.isArray(parsed) && parsed.finalResponse !== undefined) {
                        currentAssistantMarkdown = parsed.finalResponse;
                        citationsJson = JSON.stringify(parsed.citations);
                    }
                }
            } catch (e) {
                console.error("Error parsing end-of-stream token", e);
            }

            currentAssistantMessageDiv.innerHTML = marked.parse(currentAssistantMarkdown);
            if (citationsJson && citationsJson !== "null" && citationsJson !== "[]") {
                renderCitations(citationsJson, currentAssistantMessageDiv);
            }
        }
        container.scrollTop = container.scrollHeight;
        setChatInputState(true);
        hideStopButton();
    }
});

connection.on("ReceiveError", msg => {
    removeThinkingIndicator();
    isReceivingStream = false;
    setChatInputState(true);
    hideStopButton();
    if (currentAssistantMessageDiv) {
        if (currentAssistantMarkdown.length > 0) {
            currentAssistantMessageDiv.innerHTML = marked.parse(currentAssistantMarkdown) + `<div class="text-red-400 text-sm mt-2"><i class="fa-solid fa-circle-exclamation mr-1"></i>${msg}</div>`;
        } else {
            currentAssistantMessageDiv.innerHTML = `<div class="text-red-400 text-sm"><i class="fa-solid fa-circle-exclamation mr-1"></i>${msg}</div>`;
        }
    }
});

// ── Chat Form ────────────────────────────────────────────────
document.getElementById("chatForm").addEventListener("submit", async e => {
    e.preventDefault();
    if (!currentSubjectId) return;
    const input = document.getElementById("messageInput");
    const msg = input.value.trim();
    if (!msg) return;
    input.value = "";
    appendMessage("user", msg, null);

    setChatInputState(false);
    try {
        showThinkingIndicator();
        showStopButton();
        await connection.send("SendMessage", currentSessionId, currentSubjectId, msg, []);
    } catch(err) {
        removeThinkingIndicator();
        setChatInputState(true);
        hideStopButton();
        if (currentAssistantMessageDiv)
            currentAssistantMessageDiv.innerHTML = `<div class="text-red-400 text-sm"><i class="fa-solid fa-circle-exclamation mr-1"></i>Có lỗi xảy ra.</div>`;
    }
});

document.getElementById("messageInput").addEventListener("keydown", e => {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); document.getElementById("chatForm").dispatchEvent(new Event("submit")); }
});

// ── UI Helpers ───────────────────────────────────────────────
function setChatInputState(enabled) {
    const input = document.getElementById("messageInput");
    const sendBtn = document.getElementById("sendBtn");
    
    if (!enabled) {
        input.disabled = true;
        sendBtn.disabled = true;
        input.placeholder = "AI đang xử lý...";
    } else {
        if (!currentSubjectId) return;
        input.disabled = false;
        sendBtn.disabled = false;
        input.placeholder = "Hỏi về " + document.getElementById("chatTitle").textContent + "...";
        input.focus();
    }
}

function showStopButton() {
    document.getElementById("stopGenerationContainer").classList.remove("hidden");
}

function hideStopButton() {
    document.getElementById("stopGenerationContainer").classList.add("hidden");
}

function stopGeneration() {
    if (currentSessionId && connection.state === signalR.HubConnectionState.Connected) {
        connection.invoke("StopGeneration", currentSessionId).catch(console.error);
        hideStopButton();
    }
}

function appendMessage(role, content, citations) {
    const container = document.getElementById("chatMessages");
    const wrapper = document.createElement("div");

    if (role === "user") {
        wrapper.className = "flex flex-row-reverse items-start gap-3";
        wrapper.innerHTML = `
            <span class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-800 flex items-center justify-center flex-shrink-0 mt-1 shadow-sm">
                <i class="fa-solid fa-user text-[11px] text-slate-500 dark:text-slate-300"></i>
            </span>
            <div class="bg-emerald-600 dark:bg-emerald-600 text-white rounded-2xl rounded-tr-sm px-5 py-3 text-sm max-w-[75%] shadow-md">${escHtml(content)}</div>`;
    } else {
        wrapper.className = "flex items-start gap-3";
        const bubble = document.createElement("div");
        bubble.className = "flex-1 bg-white dark:bg-slate-900 rounded-2xl rounded-tl-sm px-5 py-4 text-sm text-gray-800 dark:text-slate-100 prose prose-sm dark:prose-invert max-w-none border border-slate-200 dark:border-slate-700 shadow-sm transition-colors duration-200";
        bubble.innerHTML = marked.parse(content);
        if (citations) renderCitations(citations, bubble);

        wrapper.innerHTML = `<span class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-green-600 flex items-center justify-center flex-shrink-0 mt-1 shadow-md shadow-emerald-500/30">
            <i class="fa-solid fa-robot text-[11px] text-white"></i></span>`;
        wrapper.appendChild(bubble);
    }

    container.appendChild(wrapper);
    container.scrollTop = container.scrollHeight;
}

function createAiBubble() {
    const container = document.getElementById("chatMessages");
    const wrapper = document.createElement("div");
    wrapper.className = "flex items-start gap-3";
    const bubble = document.createElement("div");
    bubble.className = "flex-1 bg-white dark:bg-slate-900 rounded-2xl rounded-tl-sm px-5 py-4 text-sm text-gray-800 dark:text-slate-100 border border-slate-200 dark:border-slate-700 shadow-sm transition-colors duration-200";
    wrapper.innerHTML = `<span class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-green-600 flex items-center justify-center flex-shrink-0 mt-1 shadow-md shadow-emerald-500/30">
        <i class="fa-solid fa-robot text-[11px] text-white"></i></span>`;
    wrapper.appendChild(bubble);
    container.appendChild(wrapper);
    currentAssistantMessageDiv = bubble;
}

function showThinkingIndicator() {
    createAiBubble();
    currentAssistantMarkdown = "";
    currentAssistantMessageDiv.innerHTML = `
        <div class="flex items-center gap-2 text-emerald-600">
            <span class="text-xs italic font-medium">AI đang xử lý</span>
            <span class="flex gap-1">
                <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-bounce" style="animation-delay:0s"></span>
                <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-bounce" style="animation-delay:.15s"></span>
                <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-bounce" style="animation-delay:.3s"></span>
            </span>
        </div>`;
    isAiThinking = true;
    isReceivingStream = false;
}

function removeThinkingIndicator() {
    if (isAiThinking && currentAssistantMessageDiv) {
        currentAssistantMessageDiv.innerHTML = "";
        isAiThinking = false;
    }
}

function renderCitations(citationsJson, el) {
    try {
        const cits = JSON.parse(citationsJson);
        if (!cits || cits.length === 0) return;
        const div = document.createElement("div");
        div.className = "mt-4 pt-3 border-t border-slate-200 dark:border-slate-700 text-xs text-slate-500 dark:text-slate-400";
        div.innerHTML = `<p class="font-semibold mb-1 text-slate-600 dark:text-slate-300">Nguồn tham khảo:</p><ul class="space-y-1">` +
            cits.map((c,i) => {
                const displayIdx = (c.Index !== undefined && c.Index !== null) ? c.Index : (i + 1);
                return `<li class="flex items-start gap-1.5">
                    <span class="text-emerald-600 dark:text-emerald-400 font-bold">[${displayIdx}]</span>
                    <span class="font-medium hover:text-emerald-700 dark:hover:text-emerald-400 cursor-help" title="${c.ContentSnippet}">${c.FileName} – trang ${c.Page}</span>
                </li>`;
            }).join('') + `</ul>`;
        el.appendChild(div);
    } catch(e) {}
}

function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Topic Management ─────────────────────────────────────────
function renameSubject(id, btn) {
    const item = btn.closest('.topic-item');
    const nameEl = item.querySelector('.topic-name');
    const oldName = nameEl.textContent;

    const input = document.createElement('input');
    input.type = 'text';
    input.value = oldName;
    input.className = 'flex-1 bg-surface-600 border border-brand-500 rounded px-2 py-0.5 text-xs text-white outline-none w-full';
    nameEl.replaceWith(input);
    input.focus();
    input.select();

    const save = async () => {
        const newName = input.value.trim();
        if (!newName || newName === oldName) { input.replaceWith(createNameSpan(oldName)); return; }
        const res = await fetch('/Document?handler=RenameSubject', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${id}&name=${encodeURIComponent(newName)}`
        });
        const data = await res.json();
        input.replaceWith(createNameSpan(data.success ? data.name : oldName));
        if (data.success && currentSubjectId == id) document.getElementById("chatTitle").textContent = data.name;
    };

    input.addEventListener('blur', save);
    input.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); input.blur(); } if (e.key === 'Escape') { input.replaceWith(createNameSpan(oldName)); } });
}

function createNameSpan(text) {
    const span = document.createElement('span');
    span.className = 'flex-1 text-sm font-medium truncate topic-name';
    span.textContent = text;
    return span;
}

function deleteSubject(id, name) {
    showConfirmModal('Xóa môn học', `Xóa "${name}" sẽ xóa toàn bộ tài liệu và lịch sử chat. Không thể khôi phục!`, async () => {
        const res = await fetch('/Document?handler=DeleteSubject', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${id}`
        });
        const data = await res.json();
        if (data.success) {
            document.querySelector(`.topic-item[data-id="${id}"]`)?.remove();
            if (currentSubjectId == id) {
                currentSubjectId = null;
                currentSessionId = "";
                document.getElementById("chatTitle").textContent = "Chọn môn học để bắt đầu";
                document.getElementById("chatSubtitle").textContent = "RAG Chatbot";
                document.getElementById("chatMessages").innerHTML = `<div class="flex justify-center"><span class="px-4 py-1.5 rounded-full bg-surface-700 text-xs text-slate-400">Chọn môn học từ sidebar để bắt đầu chat</span></div>`;
                document.getElementById("docFilterPanel").classList.add("hidden");
                document.getElementById("messageInput").disabled = true;
                document.getElementById("sendBtn").disabled = true;
            }
        }
    });
}
</script>
}

