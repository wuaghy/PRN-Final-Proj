@page
@model RagChatbot.PresentationRazorPage.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="max-w-4xl mx-auto p-4 sm:p-6 lg:p-8 mt-6">
    <div class="bg-white/90 dark:bg-slate-900/90 backdrop-blur-2xl border border-white/40 dark:border-slate-700/50 rounded-3xl p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:shadow-[0_8px_30px_rgb(0,0,0,0.1)] relative overflow-hidden transition-all duration-300">
        <!-- Decoration blur blobs -->
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10">
            <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white mb-8 flex items-center gap-4">
                <span class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-400 to-teal-500 text-white flex items-center justify-center shadow-lg shadow-emerald-500/30 ring-4 ring-emerald-50 dark:ring-emerald-900/20">
                    <i class="fa-solid fa-user text-xl"></i>
                </span>
                Hồ sơ của bạn
            </h1>

            

            <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
                <!-- User Info -->
                <div class="md:col-span-5 space-y-6">
                    <div>
                        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100 mb-5 flex items-center gap-2">
                            <i class="fa-solid fa-address-card text-emerald-500"></i>
                            Thông tin tài khoản
                        </h2>
                    </div>
                    <div class="space-y-4">
                        <div class="bg-slate-50 dark:bg-slate-800/40 p-5 rounded-2xl border border-slate-100 dark:border-slate-700/50 transition-colors hover:bg-white dark:hover:bg-slate-800 shadow-sm">
                            <p class="text-xs font-bold text-slate-400 dark:text-slate-500 mb-1.5 uppercase tracking-wider">Họ và Tên</p>
                            <p class="text-base font-semibold text-slate-900 dark:text-slate-100">@Model.UserProfile.LastName @Model.UserProfile.FirstName</p>
                        </div>
                        <div class="bg-slate-50 dark:bg-slate-800/40 p-5 rounded-2xl border border-slate-100 dark:border-slate-700/50 transition-colors hover:bg-white dark:hover:bg-slate-800 shadow-sm">
                            <p class="text-xs font-bold text-slate-400 dark:text-slate-500 mb-1.5 uppercase tracking-wider">Email liên hệ</p>
                            <p class="text-base font-semibold text-slate-900 dark:text-slate-100 break-all">@Model.UserProfile.Email</p>
                        </div>
                        <div class="bg-slate-50 dark:bg-slate-800/40 p-5 rounded-2xl border border-slate-100 dark:border-slate-700/50 transition-colors hover:bg-white dark:hover:bg-slate-800 shadow-sm">
                            <p class="text-xs font-bold text-slate-400 dark:text-slate-500 mb-1.5 uppercase tracking-wider">Vai trò truy cập</p>
                            <div class="mt-1">
                                @if (Model.UserProfile.Role == "Admin") { <span class="bg-purple-100 text-purple-700 dark:bg-purple-500/20 dark:text-purple-300 px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm inline-block">Quản trị viên (Admin)</span> }
                                else if (Model.UserProfile.Role == "Student") { <span class="bg-blue-100 text-blue-700 dark:bg-blue-500/20 dark:text-blue-300 px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm inline-block">Học sinh</span> }
                                else if (Model.UserProfile.Role == "Lecturer") { <span class="bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-300 px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm inline-block">Giảng viên</span> }
                                else if (Model.UserProfile.Role == "HeadOfDepartment") { <span class="bg-orange-100 text-orange-700 dark:bg-orange-500/20 dark:text-orange-300 px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm inline-block">Trưởng Bộ môn</span> }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Divider for Mobile -->
                <div class="block md:hidden h-px bg-slate-200 dark:bg-slate-800 my-2"></div>

                <!-- Change Password Form -->
                <div class="md:col-span-7">
                    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 sm:p-8 shadow-sm h-full flex flex-col justify-center relative overflow-hidden">
                        <!-- Tiny accent -->
                        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-emerald-500/10 to-transparent rounded-bl-full pointer-events-none"></div>

                        <h2 class="text-lg font-bold text-slate-800 dark:text-slate-100 mb-6 flex items-center gap-2">
                            <i class="fa-solid fa-shield-halved text-emerald-500"></i>
                            Đổi mật khẩu bảo mật
                        </h2>
                        <form asp-page="/Profile/Index" asp-page-handler="ChangePassword" method="post" class="space-y-5">
                            <div>
                                <label class="block text-sm font-bold text-slate-600 dark:text-slate-300 mb-2">Mật khẩu hiện tại</label>
                                <div class="relative group">
                                    <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400 group-focus-within:text-emerald-500 transition-colors"><i class="fa-solid fa-lock text-sm"></i></span>
                                    <input type="password" name="oldPassword" required class="w-full pl-11 pr-4 py-3 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl text-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all dark:text-white" placeholder="Nhập mật khẩu hiện tại" />
                                </div>
                            </div>
                            
                            <div class="h-px bg-slate-100 dark:bg-slate-800/60 my-2"></div>

                            <div>
                                <label class="block text-sm font-bold text-slate-600 dark:text-slate-300 mb-2">Mật khẩu mới</label>
                                <div class="relative group">
                                    <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400 group-focus-within:text-emerald-500 transition-colors"><i class="fa-solid fa-key text-sm"></i></span>
                                    <input type="password" name="newPassword" required class="w-full pl-11 pr-4 py-3 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl text-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all dark:text-white" placeholder="Tạo mật khẩu mới an toàn" />
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-600 dark:text-slate-300 mb-2">Xác nhận mật khẩu mới</label>
                                <div class="relative group">
                                    <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400 group-focus-within:text-emerald-500 transition-colors"><i class="fa-solid fa-check-double text-sm"></i></span>
                                    <input type="password" name="confirmPassword" required class="w-full pl-11 pr-4 py-3 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-700 rounded-xl text-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all dark:text-white" placeholder="Nhập lại mật khẩu mới" />
                                </div>
                            </div>
                            
                            <button type="submit" class="w-full mt-4 bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3.5 px-4 rounded-xl shadow-lg shadow-emerald-500/30 transition-all transform hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-2">
                                <span>Cập nhật mật khẩu</span>
                                <i class="fa-solid fa-arrow-right text-sm"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
