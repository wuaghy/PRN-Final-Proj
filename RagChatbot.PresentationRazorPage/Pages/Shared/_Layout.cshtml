<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="RAG Chatbot – Hỏi đáp thông minh từ tài liệu học tập của bạn." />
    <title>@ViewData["Title"] – RAG Chatbot</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <script>
        // Prevent FOUC (Flash of Unstyled Content)
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }

        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: {
                            50:  '#eef2ff',
                            100: '#e0e7ff',
                            400: '#818cf8',
                            500: '#6366f1',
                            600: '#4f46e5',
                            700: '#4338ca',
                        },
                        surface: {
                            900: '#0f172a',
                            800: '#1e293b',
                            700: '#273549',
                            600: '#334155',
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }

        /* Sidebar active item */
        .topic-item.active {
            background: linear-gradient(90deg, rgba(16,185,129,0.1), rgba(16,185,129,0.02));
            border-left: 3px solid #10b981;
            color: #047857;
        }

        .topic-item {
            border-left: 3px solid transparent;
            transition: all 0.15s;
        }

            .topic-item:hover {
                background: rgba(16,185,129,0.05);
                color: #047857;
            }

        /* Nav link active */
        .nav-link.active {
            color: #047857;
            background: rgba(16,185,129,0.1);
            font-weight: 600;
        }

        /* Smooth transitions */
        * {
            transition-property: background-color, border-color, color, opacity;
            transition-duration: 150ms;
        }

        input, textarea, button {
            transition: none;
        }

        /* Glass card */
        .glass {
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0,0,0,0.05);
        }

        /* Modal overlay */
        #confirmModal, #contactModal {
            backdrop-filter: blur(4px);
        }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-100 min-h-screen flex flex-col transition-colors duration-200">

    <header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 flex-shrink-0 z-30 shadow-sm transition-colors duration-200 sticky top-0">
        <div class="px-4 flex items-center justify-between h-14">
            <a asp-page="/Index"
               class="flex items-center gap-2.5 font-bold text-gray-800 dark:text-slate-100 text-base select-none">
                <span class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center shadow-md shadow-emerald-500/20">
                    <i class="fa-solid fa-robot text-sm text-white"></i>
                </span>
                <span>RAG <span class="text-emerald-600 dark:text-emerald-400">Chatbot</span></span>
            </a>

            <div class="flex items-center gap-4">
                <nav class="flex items-center gap-1 border-r border-slate-200 dark:border-slate-800 pr-4">

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-page="/Admin/Dashboard"
                           class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                            <i class="fa-solid fa-chart-pie text-xs"></i> Dashboard
                        </a>

                        <a asp-page="/Admin/Index"
                           class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                            <i class="fa-solid fa-users text-xs"></i> QL Người dùng
                        </a>

                        <a asp-page="/Admin/Departments"
                           class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                            <i class="fa-solid fa-building text-xs"></i> QL Bộ môn
                        </a>

                        <a asp-page="/Admin/HeadOfDepartments"
                           class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                            <i class="fa-solid fa-user-shield text-xs"></i> QL Trưởng BM
                        </a>
                        <a asp-page="/Admin/Subjects"
                           class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                            <i class="fa-solid fa-book text-xs"></i> QL Môn học
                        </a>
                    }

                    @if (User.IsInRole("Student"))
                    {
                        <a asp-page="/Index"
                           class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                            <i class="fa-solid fa-comments text-xs"></i> Chat
                        </a>

                        <a asp-page="/Document/Browse"
                           class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                            <i class="fa-solid fa-book-open text-xs"></i> Thư viện tài liệu
                        </a>

                        <button onclick="toggleContactModal(true)"
                                class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-orange-600 dark:hover:text-orange-400 hover:bg-orange-50 dark:hover:bg-orange-500/10 transition-colors cursor-pointer">
                            <i class="fa-solid fa-triangle-exclamation text-xs text-orange-500 animate-pulse"></i> Báo lỗi & Góp ý
                        </button>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Lecturer") || User.IsInRole("HeadOfDepartment"))
                    {
                        <a asp-page="/Document/Index"
                           class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                            <i class="fa-solid fa-folder-open text-xs"></i> Tài liệu
                        </a>
                    }
                </nav>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="flex items-center gap-3">
                        <a href="/Profile" class="flex items-center gap-2 text-sm text-slate-600 dark:text-emerald-100 hover:bg-slate-100 dark:hover:bg-slate-800 px-3 py-1.5 rounded-xl transition-colors cursor-pointer" title="Xem hồ sơ">
                            <i class="fa-solid fa-circle-user text-lg text-emerald-500"></i>
                            <span class="font-medium text-gray-800 dark:text-slate-100">@User.Identity.Name</span>
                        </a>
                        <button id="themeToggleBtn" onclick="toggleTheme()" class="text-sm text-slate-500 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 px-2 py-1 rounded transition-colors" title="Chuyển chế độ Sáng/Tối">
                            <i id="themeToggleIcon" class="fa-solid fa-moon"></i>
                        </button>
                        <form asp-page="/Auth/Logout" method="post" class="m-0">
                            <button type="submit" class="text-sm text-slate-500 dark:text-slate-300 hover:text-red-500 dark:hover:text-red-400 px-2 py-1 rounded transition-colors" title="Đăng xuất">
                                <i class="fa-solid fa-right-from-bracket"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </header>

    <div id="confirmModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 dark:bg-slate-950/80 backdrop-blur-sm">
        <div class="glass dark:bg-slate-900/95 rounded-2xl p-6 w-full max-w-sm mx-4 shadow-xl dark:border-slate-800">
            <div class="flex items-center gap-3 mb-3">
                <span class="w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center flex-shrink-0">
                    <i class="fa-solid fa-triangle-exclamation text-red-500 dark:text-red-400"></i>
                </span>
                <div>
                    <p class="font-semibold text-gray-900 dark:text-slate-100" id="confirmTitle">Xác nhận xóa</p>
                    <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5" id="confirmMessage">Bạn có chắc muốn xóa mục này?</p>
                </div>
            </div>
            <div class="flex gap-2 mt-5 justify-end">
                <button onclick="closeConfirmModal()"
                        class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-700 transition-colors">
                    Hủy
                </button>
                <button id="confirmOkBtn"
                        class="px-4 py-2 rounded-lg text-sm font-medium bg-red-500 hover:bg-red-600 text-white shadow-sm shadow-red-500/30">
                    Xóa
                </button>
            </div>
        </div>
    </div>

    <div id="contactModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 dark:bg-slate-950/80 backdrop-blur-sm">
        <div class="bg-white dark:bg-slate-900 w-full max-w-md mx-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-2xl overflow-hidden">
            <div class="p-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 flex items-center justify-between">
                <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2 text-sm sm:text-base">
                    <i class="fa-solid fa-paper-plane text-indigo-500"></i> Gửi Yêu Cầu Hỗ Trợ
                </h3>
                <button onclick="toggleContactModal(false)" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>
            <div class="p-5 space-y-4 text-left">
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Loại yêu cầu</label>
                    <select id="contactType" class="w-full px-3 py-2 text-sm bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:border-indigo-500 text-slate-800 dark:text-slate-100 cursor-pointer">
                        <option value="0">Góp ý cải tiến hệ thống</option>
                        <option value="1">Báo lỗi Chatbot (RAG sai kiến thức)</option>
                        <option value="2">Lỗi tài khoản / Premium</option>
                        <option value="3">Khác</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Nội dung chi tiết</label>
                    <textarea id="contactContent" rows="4" placeholder="Nhập chi tiết lỗi hoặc ý kiến đóng góp của bạn tại đây..."
                              class="w-full px-3 py-2 text-sm bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:border-indigo-500 text-slate-800 dark:text-slate-100 placeholder-slate-400 resize-none"></textarea>
                </div>
            </div>
            <div class="p-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end gap-2.5 bg-slate-50/50 dark:bg-slate-900/30">
                <button onclick="toggleContactModal(false)" class="px-4 py-2 text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
                    Hủy bỏ
                </button>
                <button onclick="submitContactForm()" id="btnSubmitContact" class="px-4 py-2 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-500 active:bg-indigo-700 rounded-lg transition-colors flex items-center gap-2 shadow-md shadow-indigo-500/10">
                    <i class="fa-solid fa-circle-check"></i> Gửi đi
                </button>
            </div>
        </div>
    </div>

    <partial name="_ToastNotifications" />

    <main class="flex-1 flex flex-col">
        @RenderBody()
    </main>

    <script>
        // ── Confirm Modal helpers ────────────────────────────────
        let _confirmCallback = null;
        function showConfirmModal(title, message, onConfirm) {
            document.getElementById('confirmTitle').textContent = title;
            document.getElementById('confirmMessage').textContent = message;
            _confirmCallback = onConfirm;
            document.getElementById('confirmModal').classList.remove('hidden');
            document.getElementById('confirmModal').classList.add('flex');
        }
        function closeConfirmModal() {
            document.getElementById('confirmModal').classList.add('hidden');
            document.getElementById('confirmModal').classList.remove('flex');
            _confirmCallback = null;
        }
        document.getElementById('confirmOkBtn').addEventListener('click', () => {
            if (_confirmCallback) _confirmCallback();
            closeConfirmModal();
        });

        // ── 🔥 Hàm Điều Khiển Contact Modal (Đóng/Mở Pop-up) ─────────────────
        function toggleContactModal(show) {
            const modal = document.getElementById("contactModal");
            if (show) {
                modal.classList.remove("hidden");
                modal.classList.add("flex");
                document.getElementById("contactContent").value = "";
            } else {
                modal.classList.add("hidden");
                modal.classList.remove("flex");
            }
        }

        // ── 🔥 Hàm AJAX Gửi Liên Hệ/Báo Lỗi Lên Controller ─────────────────
        async function submitContactForm() {
            const contentInput = document.getElementById("contactContent");
            const typeInput = document.getElementById("contactType");
            const btnSubmit = document.getElementById("btnSubmitContact");

            const content = contentInput.value.trim();
            const type = typeInput.value;

            if (!content) {
                alert("Vui lòng nhập nội dung góp ý hoặc báo lỗi trước khi gửi!");
                contentInput.focus();
                return;
            }

            btnSubmit.disabled = true;
            btnSubmit.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Đang gửi...`;

            const formData = new FormData();
            formData.append("content", content);
            formData.append("type", type);
            formData.append("relatedId", "");

            try {
                const response = await fetch('/Contact/SendContact', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message);
                    toggleContactModal(false);
                } else {
                    alert("Thất bại: " + result.message);
                }
            } catch (error) {
                console.error("Lỗi gửi liên hệ:", error);
                alert("Có lỗi kết nối hệ thống, vui lòng thử lại sau!");
            } finally {
                btnSubmit.disabled = false;
                btnSubmit.innerHTML = `<i class="fa-solid fa-circle-check"></i> Gửi đi`;
            }
        }

        // Tối ưu hóa logic Highlighting Nav Link linh hoạt theo URL cụ thể
        const currentPath = window.location.pathname.toLowerCase().replace(/\/$/, "");
        document.querySelectorAll('.nav-link').forEach(link => {
            const href = link.getAttribute('href')?.toLowerCase() ?? '';

            // Xử lý logic chuẩn hóa so sánh chuỗi URL
            if (currentPath === href ||
               (currentPath === "" && href.includes("home/index")) ||
               (currentPath.startsWith(href) && href !== "/admin" && href !== "")) {
                link.classList.add('active');
            } else if (href === "/admin" && (currentPath === "/admin" || currentPath === "/admin/index")) {
                // Trường hợp đặc biệt của trang quản lý Giảng viên mặc định
                link.classList.add('active');
            }
        });

        // Theme Toggle logic
        function updateThemeIcon() {
            const icon = document.getElementById('themeToggleIcon');
            if (icon) {
                if (document.documentElement.classList.contains('dark')) {
                    icon.className = 'fa-solid fa-sun';
                } else {
                    icon.className = 'fa-solid fa-moon';
                }
            }
        }
        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.theme = 'light';
            } else {
                document.documentElement.classList.add('dark');
                localStorage.theme = 'dark';
            }
            updateThemeIcon();
        }
        // Initial setup for icon
        updateThemeIcon();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
