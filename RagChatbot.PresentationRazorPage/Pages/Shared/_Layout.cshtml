<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="RAG Chatbot – Hỏi đáp thông minh từ tài liệu học tập của bạn." />
    <title>@ViewData["Title"] – RAG Chatbot</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <script>
        // Prevent FOUC (Flash of Unstyled Content)
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }

        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: {
                            50:  '#eef2ff',
                            100: '#e0e7ff',
                            400: '#818cf8',
                            500: '#6366f1',
                            600: '#4f46e5',
                            700: '#4338ca',
                        },
                        surface: {
                            900: '#0f172a',
                            800: '#1e293b',
                            700: '#273549',
                            600: '#334155',
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }

        /* Sidebar active item */
        .topic-item.active {
            background: linear-gradient(90deg, rgba(16,185,129,0.1), rgba(16,185,129,0.02));
            border-left: 3px solid #10b981;
            color: #047857;
        }

        .topic-item {
            border-left: 3px solid transparent;
            transition: all 0.15s;
        }

            .topic-item:hover {
                background: rgba(16,185,129,0.05);
                color: #047857;
            }

        /* Nav link active */
        .nav-link.active {
            color: #047857;
            background: rgba(16,185,129,0.1);
            font-weight: 600;
        }

        /* Smooth transitions */
        * {
            transition-property: background-color, border-color, color, opacity;
            transition-duration: 150ms;
        }

        input, textarea, button {
            transition: none;
        }

        /* Glass card */
        .glass {
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0,0,0,0.05);
        }

        /* Modal overlay */
        #confirmModal, #contactModal {
            backdrop-filter: blur(4px);
        }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-100 min-h-screen flex flex-col transition-colors duration-200">
@{
    var isManagementUser = User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("HeadOfDepartment") || User.IsInRole("Lecturer"));
    var currentPath = ViewContext.HttpContext.Request.Path.Value ?? "";
}

    <!-- Shared Modals -->
    <div id="confirmModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 dark:bg-slate-950/80 backdrop-blur-sm">
        <div class="glass dark:bg-slate-900/95 rounded-2xl p-6 w-full max-w-sm mx-4 shadow-xl dark:border-slate-800">
            <div class="flex items-center gap-3 mb-3">
                <span id="confirmIconContainer" class="size-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center flex-shrink-0">
                    <i id="confirmIcon" class="fa-solid fa-triangle-exclamation text-red-500 dark:text-red-400" aria-hidden="true"></i>
                </span>
                <div>
                    <p class="font-semibold text-gray-900 dark:text-slate-100" id="confirmTitle">Xác nhận xóa</p>
                    <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5" id="confirmMessage">Bạn có chắc muốn xóa mục này?</p>
                </div>
            </div>
            <div class="flex gap-2 mt-5 justify-end">
                <button onclick="closeConfirmModal()"
                        class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-700 transition-colors">
                    Hủy
                </button>
                <button id="confirmOkBtn"
                        class="px-4 py-2 rounded-lg text-sm font-medium bg-red-500 hover:bg-red-600 text-white shadow-sm shadow-red-500/30">
                    Xóa
                </button>
            </div>
        </div>
    </div>

    <div id="contactModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 dark:bg-slate-950/80 backdrop-blur-sm">
        <div class="bg-white dark:bg-slate-900 w-full max-w-md mx-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-2xl overflow-hidden">
            <div class="p-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 flex items-center justify-between">
                <h3 class="font-bold text-slate-900 dark:text-white flex items-center gap-2 text-sm sm:text-base">
                    <i class="fa-solid fa-paper-plane text-indigo-500"></i> Gửi Yêu Cầu Hỗ Trợ
                </h3>
                <button onclick="toggleContactModal(false)" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>
            <div class="p-5 space-y-4 text-left">
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Loại yêu cầu</label>
                    <select id="contactType" class="w-full px-3 py-2 text-sm bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:border-indigo-500 text-slate-800 dark:text-slate-100 cursor-pointer">
                        <option value="GeneralFeedback">Góp ý cải tiến hệ thống</option>
                        <option value="ChatIssue">Báo lỗi Chatbot (RAG sai kiến thức)</option>
                        <option value="DocumentIssue">Lỗi tài liệu / học liệu</option>
                        <option value="AccountIssue">Lỗi tài khoản / Premium</option>
                        <option value="Other">Khác</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Nội dung chi tiết</label>
                    <textarea id="contactContent" rows="4" placeholder="Nhập chi tiết lỗi hoặc ý kiến đóng góp của bạn tại đây..."
                              class="w-full px-3 py-2 text-sm bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg focus:outline-none focus:border-indigo-500 text-slate-800 dark:text-slate-100 placeholder-slate-400 resize-none"></textarea>
                </div>
            </div>
            <div class="p-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end gap-2.5 bg-slate-50/50 dark:bg-slate-900/30">
                <button onclick="toggleContactModal(false)" class="px-4 py-2 text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
                    Hủy bỏ
                </button>
                <button onclick="submitContactForm()" id="btnSubmitContact" class="px-4 py-2 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-500 active:bg-indigo-700 rounded-lg transition-colors flex items-center gap-2 shadow-md shadow-indigo-500/10">
                    <i class="fa-solid fa-circle-check"></i> Gửi đi
                </button>
            </div>
        </div>
    </div>

    <partial name="_ToastNotifications" />

    @if (isManagementUser)
    {
        <div class="flex h-screen overflow-hidden w-full">
            <!-- Sidebar -->
            <aside class="w-64 bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-300 flex-shrink-0 flex flex-col border-r border-slate-200 dark:border-slate-800 transition-colors">
                <!-- Sidebar Brand/Logo -->
                <div class="h-16 flex items-center px-6 border-b border-slate-200 dark:border-slate-800 gap-2.5 font-bold text-gray-800 dark:text-white text-base select-none">
                    <span class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center shadow-md shadow-emerald-500/20">
                        <i class="fa-solid fa-robot text-sm text-white"></i>
                    </span>
                    <span>RAG <span class="text-emerald-600 dark:text-emerald-400">Chatbot</span></span>
                </div>

                <!-- Sidebar Navigation Links -->
                <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto">
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-3 mb-2">Hệ thống</div>
                        
                        var isDashboard = currentPath.Equals("/Admin", StringComparison.OrdinalIgnoreCase) || currentPath.Equals("/Admin/Index", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/Index" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isDashboard ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-chart-pie w-4"></i> Dashboard Chung
                        </a>

                        var isFinance = currentPath.StartsWith("/Admin/FinancialDashboard", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/FinancialDashboard" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isFinance ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-wallet w-4"></i> Báo cáo Tài chính AI
                        </a>

                        var isUsers = currentPath.StartsWith("/Admin/Student", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/Student" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isUsers ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-user-graduate w-4"></i> QL Học sinh
                        </a>

                        var isHods = currentPath.StartsWith("/Admin/HeadOfDepartments", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/HeadOfDepartments" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isHods ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-user-shield w-4"></i> QL Trưởng BM
                        </a>

                        var isLecturers = currentPath.StartsWith("/Admin/Lecturers", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/Lecturers" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isLecturers ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-graduation-cap w-4"></i> QL Giảng viên
                        </a>

                        var isDepts = currentPath.StartsWith("/Admin/Departments", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/Departments" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isDepts ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-building w-4"></i> QL Bộ môn
                        </a>

                        var isSubjects = currentPath.StartsWith("/Admin/Subjects", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/Subjects" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isSubjects ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-book w-4"></i> QL Môn học
                        </a>

                        var isAudit = currentPath.StartsWith("/Admin/AuditLogs", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/AuditLogs" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isAudit ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-list-check w-4"></i> Nhật ký kiểm toán
                        </a>

                        var isChunking = currentPath.StartsWith("/Admin/ChunkingConfig", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/ChunkingConfig" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isChunking ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-layer-group w-4"></i> Cấu hình Chunking
                        </a>

                        var isSettings = currentPath.StartsWith("/Admin/Settings", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/Settings" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isSettings ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-gear w-4"></i> Cấu hình Giá & API
                        </a>

                        var isContacts = currentPath.StartsWith("/Admin/Contacts", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Admin/Contacts" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isContacts ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-triangle-exclamation w-4"></i> Yêu cầu hỗ trợ
                        </a>
                    }
                    else if (User.IsInRole("HeadOfDepartment"))
                    {
                        <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-3 mb-2">Trưởng bộ môn</div>
                        
                        var isDocs = currentPath.StartsWith("/Document", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Document/Index" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isDocs ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-folder-open w-4"></i> Tài liệu bộ môn
                        </a>

                        var isAssign = currentPath.StartsWith("/Hod", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Hod/Index" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isAssign ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-user-plus w-4"></i> Phân công giảng dạy
                        </a>
                    }
                    else if (User.IsInRole("Lecturer"))
                    {
                        <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-3 mb-2">Giảng viên</div>

                        var isDocs = currentPath.StartsWith("/Document", StringComparison.OrdinalIgnoreCase);
                        <a asp-page="/Document/Index" class="nav-link flex items-center gap-2.5 py-2.5 rounded-xl text-sm font-medium transition-all @(isDocs ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-semibold border-l-4 border-emerald-500 pl-2" : "text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 pl-3")">
                            <i class="fa-solid fa-folder-open w-4"></i> Tài liệu cá nhân
                        </a>
                    }
                </nav>

                <!-- Sidebar Profile Footer -->
                <div class="p-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
                    <div class="flex items-center gap-2 min-w-0">
                        <i class="fa-solid fa-circle-user text-xl text-emerald-500 flex-shrink-0"></i>
                        <div class="flex flex-col min-w-0">
                            <span class="text-xs font-semibold text-gray-800 dark:text-slate-100 truncate">@User.Identity?.Name</span>
                            <span class="text-[10px] text-slate-400 dark:text-slate-500">
                                @(User.IsInRole("Admin") ? "Admin" : User.IsInRole("HeadOfDepartment") ? "Trưởng bộ môn" : "Giảng viên")
                            </span>
                        </div>
                    </div>
                    <div class="flex items-center gap-1">
                        <button onclick="toggleTheme()" class="text-slate-500 dark:text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" title="Chuyển chế độ Sáng/Tối">
                            <i class="fa-solid fa-moon"></i>
                        </button>
                        <form asp-page="/Auth/Logout" method="post" class="m-0">
                            <button type="submit" class="text-slate-500 dark:text-slate-400 hover:text-red-500 dark:hover:text-red-400 p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" title="Đăng xuất">
                                <i class="fa-solid fa-right-from-bracket"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </aside>

            <!-- Right Content Panel -->
            <div class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden bg-slate-50 dark:bg-slate-950 transition-colors">
                <!-- Slim Top Header -->
                <header class="h-16 border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 flex items-center justify-between px-8 flex-shrink-0 transition-colors">
                    <div class="text-sm font-semibold text-slate-500 dark:text-slate-400">
                        Bảng điều khiển RAG
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-xs text-slate-400 dark:text-slate-500">Hệ thống hỏi đáp học tập</span>
                    </div>
                </header>

                <!-- Scrollable Main Content -->
                <main class="flex-1 overflow-y-auto p-6">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 flex-shrink-0 z-30 shadow-sm transition-colors duration-200 sticky top-0">
            <div class="px-4 flex items-center justify-between h-14">
                <a asp-page="/Index"
                   class="flex items-center gap-2.5 font-bold text-gray-800 dark:text-slate-100 text-base select-none">
                    <span class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center shadow-md shadow-emerald-500/20">
                        <i class="fa-solid fa-robot text-sm text-white"></i>
                    </span>
                    <span>RAG <span class="text-emerald-600 dark:text-emerald-400">Chatbot</span></span>
                </a>

                <div class="flex items-center gap-4">
                    <nav class="flex items-center gap-1 border-r border-slate-200 dark:border-slate-800 pr-4">
                        @if (User.IsInRole("Student"))
                        {
                            <a asp-page="/Index"
                               class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                                <i class="fa-solid fa-comments text-xs"></i> Chat
                            </a>

                            <a asp-page="/Document/Browse"
                               class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                                <i class="fa-solid fa-book-open text-xs"></i> Thư viện tài liệu
                            </a>

                            <a asp-page="/Premium"
                               class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-500/10 transition-colors">
                                <i class="fa-solid fa-crown text-xs text-amber-500"></i> Nâng cấp Premium
                            </a>

                            <button onclick="toggleContactModal(true)"
                                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-500 dark:text-slate-300 hover:text-orange-600 dark:hover:text-orange-400 hover:bg-orange-50 dark:hover:bg-orange-500/10 transition-colors cursor-pointer">
                                <i class="fa-solid fa-triangle-exclamation text-xs text-orange-500 animate-pulse"></i> Báo lỗi & Góp ý
                            </button>
                        }
                    </nav>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="flex items-center gap-3">
                            <a href="/Profile" class="flex items-center gap-2 text-sm text-slate-600 dark:text-emerald-100 hover:bg-slate-100 dark:hover:bg-slate-800 px-3 py-1.5 rounded-xl transition-colors cursor-pointer" title="Xem hồ sơ">
                                <i class="fa-solid fa-circle-user text-lg text-emerald-500"></i>
                                <span class="font-medium text-gray-800 dark:text-slate-100">@User.Identity?.Name</span>
                            </a>
                            <button id="themeToggleBtn" onclick="toggleTheme()" class="text-sm text-slate-500 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 px-2 py-1 rounded transition-colors" title="Chuyển chế độ Sáng/Tối">
                                <i id="themeToggleIcon" class="fa-solid fa-moon"></i>
                            </button>
                            <form asp-page="/Auth/Logout" method="post" class="m-0">
                                <button type="submit" class="text-sm text-slate-500 dark:text-slate-300 hover:text-red-500 dark:hover:text-red-400 px-2 py-1 rounded transition-colors" title="Đăng xuất">
                                    <i class="fa-solid fa-right-from-bracket"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </header>

        <main class="flex-1 flex flex-col">
            @RenderBody()
        </main>
    }

    <script>
        // ── Confirm Modal helpers ────────────────────────────────
        let _confirmCallback = null;
        function showConfirmModal(title, message, onConfirm, okBtnText = "Xóa", isDanger = true) {
            document.getElementById('confirmTitle').textContent = title;
            document.getElementById('confirmMessage').textContent = message;
            _confirmCallback = onConfirm;
            const okBtn = document.getElementById('confirmOkBtn');
            const iconContainer = document.getElementById('confirmIconContainer');
            const icon = document.getElementById('confirmIcon');
            if (okBtn) {
                okBtn.textContent = okBtnText;
                if (isDanger) {
                    okBtn.className = "px-4 py-2 rounded-lg text-sm font-medium bg-red-500 hover:bg-red-600 text-white shadow-sm shadow-red-500/30";
                } else {
                    okBtn.className = "px-4 py-2 rounded-lg text-sm font-medium bg-emerald-600 hover:bg-emerald-700 text-white shadow-sm shadow-emerald-500/30";
                }
            }
            if (iconContainer && icon) {
                iconContainer.className = isDanger
                    ? "size-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center flex-shrink-0"
                    : "size-10 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center flex-shrink-0";
                icon.className = isDanger
                    ? "fa-solid fa-triangle-exclamation text-red-500 dark:text-red-400"
                    : "fa-solid fa-circle-exclamation text-amber-600 dark:text-amber-400";
            }
            document.getElementById('confirmModal').classList.remove('hidden');
            document.getElementById('confirmModal').classList.add('flex');
        }
        function closeConfirmModal() {
            document.getElementById('confirmModal').classList.add('hidden');
            document.getElementById('confirmModal').classList.remove('flex');
            _confirmCallback = null;
        }
        document.getElementById('confirmOkBtn').addEventListener('click', () => {
            if (_confirmCallback) _confirmCallback();
            closeConfirmModal();
        });

        // ── 🔥 Hàm Điều Khiển Contact Modal (Đóng/Mở Pop-up) ─────────────────
        function toggleContactModal(show) {
            const modal = document.getElementById("contactModal");
            if (show) {
                modal.classList.remove("hidden");
                modal.classList.add("flex");
                document.getElementById("contactContent").value = "";
            } else {
                modal.classList.add("hidden");
                modal.classList.remove("flex");
            }
        }

        // ── 🔥 Hàm AJAX Gửi Liên Hệ/Báo Lỗi Lên Controller ─────────────────
        async function submitContactForm() {
            const contentInput = document.getElementById("contactContent");
            const typeInput = document.getElementById("contactType");
            const btnSubmit = document.getElementById("btnSubmitContact");

            const content = contentInput.value.trim();
            const type = typeInput.value;

            if (!content) {
                alert("Vui lòng nhập nội dung góp ý hoặc báo lỗi trước khi gửi!");
                contentInput.focus();
                return;
            }

            btnSubmit.disabled = true;
            btnSubmit.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Đang gửi...`;

            const formData = new FormData();
            formData.append("content", content);
            formData.append("type", type);
            formData.append("relatedId", "");

            try {
                const response = await fetch('/Contact/SendContact', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message);
                    toggleContactModal(false);
                } else {
                    alert("Thất bại: " + result.message);
                }
            } catch (error) {
                console.error("Lỗi gửi liên hệ:", error);
                alert("Có lỗi kết nối hệ thống, vui lòng thử lại sau!");
            } finally {
                btnSubmit.disabled = false;
                btnSubmit.innerHTML = `<i class="fa-solid fa-circle-check"></i> Gửi đi`;
            }
        }

        // Tối ưu hóa logic Highlighting Nav Link linh hoạt theo URL cụ thể
        const currentPath = window.location.pathname.toLowerCase().replace(/\/$/, "");
        document.querySelectorAll('.nav-link').forEach(link => {
            const href = (link.getAttribute('href')?.toLowerCase() ?? '').replace(/\/$/, "");

            // Xử lý logic chuẩn hóa so sánh chuỗi URL
            if (currentPath === href ||
               (currentPath === "" && href.includes("home/index")) ||
               (currentPath.startsWith(href + "/") && href !== "/admin" && href !== "")) {
                link.classList.add('active');
            } else if (href === "/admin" && (currentPath === "/admin" || currentPath === "/admin/index")) {
                // Trường hợp đặc biệt của trang quản lý Giảng viên mặc định
                link.classList.add('active');
            }
        });

        // Theme Toggle logic
        function updateThemeIcon() {
            const icon = document.getElementById('themeToggleIcon');
            if (icon) {
                if (document.documentElement.classList.contains('dark')) {
                    icon.className = 'fa-solid fa-sun';
                } else {
                    icon.className = 'fa-solid fa-moon';
                }
            }
        }
        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.theme = 'light';
            } else {
                document.documentElement.classList.add('dark');
                localStorage.theme = 'dark';
            }
            updateThemeIcon();
        }
        // Initial setup for icon
        updateThemeIcon();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
