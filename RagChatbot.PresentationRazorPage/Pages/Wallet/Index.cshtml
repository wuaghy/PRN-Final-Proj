@page
@model RagChatbot.PresentationRazorPage.Pages.Wallet.IndexModel
@{
    ViewData["Title"] = "Kết quả thanh toán VNPAY";

    string alertClass = "bg-amber-950 border-amber-500 text-amber-200";

    if (ViewData["Message"] != null)
    {
        string message = ViewData["Message"].ToString() ?? "";

        if (message.Contains("🎉"))
        {
            alertClass = "bg-emerald-950 border-emerald-500 text-emerald-200";
        }
        else if (message.Contains("❌"))
        {
            alertClass = "bg-rose-950 border-rose-500 text-rose-200";
        }
    }
}

<div class="container mx-auto max-w-2xl mt-12 p-6 bg-[#0f172a] rounded-lg shadow-xl text-white border border-slate-800">
    <h2 class="text-2xl font-bold mb-4 border-b border-slate-700 pb-3 flex items-center gap-2 text-teal-400">
        💳 Kết quả thanh toán qua VNPAY
    </h2>

    @if (ViewData["Message"] != null)
    {
        <div class="border p-4 rounded-md my-5 @alertClass shadow-inner font-medium text-base">
            @ViewData["Message"]
        </div>
    }
    else
    {
        <div class="bg-slate-800 border border-slate-700 p-4 rounded-md my-5 text-slate-300 text-sm">
            💡 Chào mừng bạn đến với trang thanh toán ví. Vui lòng quay lại trang tài liệu để chọn chức năng nâng cấp tài khoản Premium.
        </div>
    }

    <div class="mt-6">
        <a href="/Document/Browse" class="bg-teal-600 hover:bg-teal-700 text-white font-semibold px-5 py-2.5 rounded-md transition duration-200 shadow-md inline-block">
            📁 Quay lại Thư viện tài liệu
        </a>
    </div>
</div>